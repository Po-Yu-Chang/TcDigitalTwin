    <Property Name="Status" Id="{ccf81927-043d-434c-9f2d-0605c0f6abc2}" FolderPath="HandShake\">
      <Declaration><![CDATA[PROPERTY Status : ST_FanucUI1]]></Declaration>
      <Get Name="Get" Id="{34501a67-89c8-465a-b238-38c5b4605ac6}">
        <Declaration><![CDATA[VAR
END_VAR
