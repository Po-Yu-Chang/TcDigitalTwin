    <Method Name="Enable" Id="{d6452130-06a4-4b03-9e85-1071184db1ab}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD Enable : BOOL
VAR_INPUT
iTrigger:BOOL;
END_VAR
VAR
	_RobotEnable:BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_RobotEnable:=iTrigger (*AND NOT Fault()*);

_UI1.UI01_IMSP:=_RobotEnable;
_UI1.UI02_Hold:=_RobotEnable;
_UI1.UI03_SFSP:=_RobotEnable;
_UI1.UI08_Enable:=_RobotEnable;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="EStop" Id="{d0568f40-b052-42be-a0f8-d45c1a9b95a7}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD EStop
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_UI1.UI03_SFSP:=FALSE;]]></ST>
      </Implementation>
    </Method>
    <Property Name="FanucRobot_MotionStatus" Id="{5f69344f-7f0a-4846-9adc-c1a5e377b175}" FolderPath="HandShake\">
      <Declaration><![CDATA[PROPERTY FanucRobot_MotionStatus : ST_Fanuc_Status]]></Declaration>
      <Get Name="Get" Id="{c8f5df37-a69d-4e0c-8408-22ea6f345c3f}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[FanucRobot_MotionStatus := _DI1;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Fault" Id="{5786630b-c79e-45db-abf4-bb0ce3df87fc}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD Fault : BOOL
VAR_INPUT
END_VAR
VAR_INST
	bConectionError : BOOL;
	bRetryError: BOOL;
END_VAR
VAR
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//bConectionError := (_EIPConnectionState <>0) OR (_FanucEIPState <> 0);
bConectionError := (iTestCnt >= 10);
bRetryError := (iRetryCnt > 3);//Edited by Jidien Kachu in 2025/10/28
tofTempOffFaultReport.IN := NOT _UI1.UI01_IMSP OR NOT _UI1.UI03_SFSP OR NOT _UI1.UI08_Enable;//Stop report for a while when twincat off the control flags by Albert 20250912
//Edited by Jidien Kachu in 2025/10/28
Fault:=((_UO1.UO06_Fault OR _UO1.UO09_BattAlarm OR _DI1.Error) (*AND (eState= E_MethodStatus_Basic.STATE_EXECUTING)*) AND NOT tofTempOffFaultReport.Q) OR bConectionError OR _UO1.UO08_TPEnabled OR bRetryError;]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetModelState" Id="{84684909-97c4-4c1d-88c5-578deecdb205}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD GetModelState
VAR_INPUT
END_VAR
VAR_OUTPUT
    xDone : BOOL;
    xBusy : BOOL;
    xError : BOOL;
    xAborted : BOOL;
    iErrorID : UDINT;
	UniqueErrorCode : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[xError := Error;
iErrorID := INT_TO_UDINT(ErrorCode.nInt);]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetName" Id="{286e5c35-9036-4531-9db3-ece6debb9b2d}" FolderPath="Method\">
