    <Method Name="M_ActiveRSR01" Id="{c552c3cd-353a-47d5-89f3-e9c40429c882}" FolderPath="Method\ModeControl\">
      <Declaration><![CDATA[METHOD M_ActiveRSR01
VAR_INPUT
END_VAR
VAR_OUTPUT
	bCompleted : BOOL;
END_VAR
VAR_INST	
	rTrigReset : R_TRIG;
END_VAR
VAR
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[rTrigReset(CLK:=Reset);

CASE eState OF
    E_MethodStatus_Basic.STATE_DORMANT:
        Enable(FALSE);
        M_Reset(FALSE);
        _uiRSR01_Step        := 0;
        uiRobotExecutingStep := 0;
        uiRobotResettingStep := 0;
        _RSR1_Ready          := FALSE;
        _RSR2_Completed      := FALSE;
        _RSR3_Ready          := FALSE;
        TON_Reset_delay.IN   := FALSE;
        _RSR1_Ready          := FALSE;
		Ton_Reset_SwitchDelay.IN := FALSE;
        IF _eOpMode = RSR01 OR _eOpMode = RSR02 OR _eOpMode = RSR03 THEN
            eState := E_MethodStatus_Basic.STATE_EXECUTING;
        END_IF
		//Edited by Jidien Kachu in 2025/10/09
//		_rawOut_DO[32].5;
//		_rawOut_DO[32].6;
//		_rawOut_DO[33].2;
		_rawIn_DI[24].7;
		_rawIn_DI[25].0;
		_rawIn_DI[25].4;
		
		iRetryCnt := 0; //Edited by Jidien Kachu in 2025/10/27
		
    E_MethodStatus_Basic.STATE_EXECUTING:
        CASE uiRobotExecutingStep OF
            0:
                Enable(iTrigger := TRUE);
                TON_Restart_delay.IN := TRUE;
				Ton_Reset_SwitchDelay.IN := FALSE;
				_DO6.RSR1_Retry := FALSE; //Edited by Jidien Kachu in 2025/10/09
                IF TON_Restart_delay.Q AND NOT _DI1.Error AND NOT iTestCnt >= 10 THEN
                    uiRobotExecutingStep := 10;					
                END_IF
            10:
                TON_Restart_delay.IN := FALSE;
                M_Reset(iTrigger := TRUE);
                _UI1.UI04_CycleStop  := TRUE;
                TON_ResetFixDelay.IN := TRUE;

                IF TON_ResetFixDelay.Q THEN
                    uiRobotExecutingStep := 100;
                END_IF
            100:
                TON_ResetFixDelay.IN := FALSE;
                TON_Reset_delay.in   := TRUE;
                M_Reset(iTrigger := FALSE);
                _UI1.UI04_CycleStop := FALSE;

                IF TON_Reset_delay.Q THEN
                    IF _UO1.UO01_CmdEnabled AND _UO1.UO02_SystemReady THEN
                        _Error                := FALSE;
						Enable(iTrigger := TRUE); // 20250428 Albert
                        _VelocityCommand.nInt := 1;
                        uiRobotExecutingStep  := 200;
                    ELSIF Error THEN
                        eState := E_MethodStatus_Basic.STATE_ERROR;
                    END_IF
                END_IF
            200:
                // Clear Fanuc robot's action
                TON_Reset_delay.IN                                            := FALSE;
                GVL_ADS.AutoMode_WarehouseMotoWithRobotMove.HandShake.Execute := FALSE;
                GVL_ADS.AutoMode_RobotAbsMove.HandShake.Execute               := FALSE;
                _DO1.bExecute                                                 := FALSE; // Warehouse with robot clampA
                _DO2.bExecute                                                 := FALSE; // Warehouse with robot clampB
                _DO3.bExecute                                                 := FALSE; // AbsMove with robot clampA
                _DO4.bExecute                                                 := FALSE; // AbsMove with robot clampB
                uiRobotExecutingStep                                          := 300;
				_Status := '';
				
            300:
                // Active RSR1
                _UI1.UI09_RSR1         := TRUE;
                Ton_SetProgTimeOut.IN  := TRUE; // Switch to RSR1 start.
                Ton_RSR_SwitchDelay.IN := TRUE;

                IF _UO1.UO11_ACK1 THEN
                    uiRobotExecutingStep := 400;
                ELSIF Error OR Ton_SetProgTimeOut.Q THEN
                    _Error  := TRUE;
                    _Status := GVL_ErrorCode.GC_MSG_0217;
					bINP := TRUE; 
                END_IF
				//Edited by Jidien Kachu in 2025/10/27
				IF reset THEN
                    IF _UO1.UO01_CmdEnabled AND _UO1.UO02_SystemReady THEN
                        _Error                := FALSE;
						Enable(iTrigger := TRUE); // 20250428 Albert
                        _VelocityCommand.nInt := 1;
						_UI1.UI09_RSR1         := FALSE;
       		         Ton_SetProgTimeOut.IN  := FALSE; // Switch to RSR1 start.
            	    Ton_RSR_SwitchDelay.IN := FALSE;
                        uiRobotExecutingStep  := 200;
                    ELSIF Error THEN
                        eState := E_MethodStatus_Basic.STATE_ERROR;
                    END_IF
				END_IF
            400:
                // Close RSR1 command
                Ton_SetProgTimeOut.IN := FALSE; // Switch to RSR1 close.

                IF Ton_RSR_SwitchDelay.Q THEN
                    _UI1.UI09_RSR1       := FALSE;
                    uiRobotExecutingStep := 500;
                END_IF
            500:
                // Allow Robot auto / manual job
                IF (GVL_ADS.AutoMode_RobotAbsMove.HandShake.Busy OR GVL_ADS.AutoMode_RobotAbsMove.HandShake.Done) AND
                    (GVL_ADS.AutoMode_WarehouseMotoWithRobotMove.HandShake.Busy OR GVL_ADS.AutoMode_WarehouseMotoWithRobotMove.HandShake.Done) (*AND
                    (GVL_ADS.ADS_MotoCalibrationData.WDataCore.HandShake.Busy OR GVL_ADS.ADS_MotoCalibrationData.WDataCore.HandShake.Done) AND
                    (GVL_ADS.ADS_MotoCalibrationData.AbslutCore.HandShake.Busy OR GVL_ADS.ADS_MotoCalibrationData.AbslutCore.HandShake.Done)*)
                    THEN
                    bCompleted := FALSE;
                ELSE
                    bCompleted := TRUE;
                END_IF
				M_ManualService();
                //_VelocityCommand.nInt                           := GVL_ADS.FanucRobot_General.Command.RobotVelocity;
                _RSR1_Ready                                     := TRUE;

//                IF _DI1.Error THEN //Edited by Jidien Kachu in 2025/10/13
				IF _UO1.UO06_Fault THEN
                    _Abort := TRUE;
                END_IF
        END_CASE

        IF _Abort THEN
            eState := E_MethodStatus_Basic.STATE_ABORTING;
        ELSIF (Hold OR _DI1.Error) AND NOT Error THEN //Edited by Jidien Kachu in 2025/10/09
            eState := E_MethodStatus_Basic.STATE_Holding;
		ELSIF _UO1.UO06_Fault THEN
	        //_Abort := TRUE;

//			_Error  := TRUE;
//			_Status := GVL_ErrorCode.GC_MSG_0214;
//			eState  := E_MethodStatus_Basic.STATE_ERROR;
        END_IF
    E_MethodStatus_Basic.STATE_DONE:
        ;
    E_MethodStatus_Basic.STATE_ABORTING:
        eState := E_MethodStatus_Basic.STATE_ERROR;
    E_MethodStatus_Basic.STATE_Aborted:
        ;
    E_MethodStatus_Basic.STATE_ERROR:
        Enable(iTrigger := FALSE);
        _RSR1_Ready := FALSE;

        IF reset THEN
            eState := E_MethodStatus_Basic.STATE_RESETTING;
        END_IF

        IF NOT Estop AND NOT Error THEN
            eState := E_MethodStatus_Basic.STATE_RESETTING;
        END_IF
    E_MethodStatus_Basic.STATE_RESETTING:
		CASE uiRobotResettingStep OF
			0 : 
				_Error                   := FALSE;
				_Abort := false;
				_Status                  := '';
				M_ResetAllCommand();
				Ton_START_SwitchDelay.IN := FALSE;
				Ton_Reset_SwitchDelay.IN := FALSE;
				TON_Restart_delay.IN := FALSE;
				uiRobotResettingStep := 10;
				iTestCnt := 0;
				_UI1.UI04_CycleStop := FALSE;
			10:
				M_Reset(iTrigger :=TRUE);
				TON_Restart_delay.IN := TRUE;
				_UI1.UI04_CycleStop := TRUE;
				IF TON_Restart_delay.Q THEN
					M_EnableWith4Input(TRUE	,TRUE,TRUE,FALSE);
					uiRobotResettingStep := 20;
				END_IF
			20:
				TON_Restart_delay.IN := FALSE;
				M_Reset(iTrigger :=FALSE);
        		//Enable(iTrigger := TRUE);
				_UI1.UI04_CycleStop := FALSE;
				IF NOT  _UO1.UO06_Fault THEN
					M_EnableWith4Input(TRUE	,TRUE,TRUE,FALSE);
					uiRobotResettingStep := 50;
				END_IF
				IF reset THEN
					uiRobotResettingStep := 0;
				END_IF
			30 :
				M_Reset(iTrigger :=TRUE);
				uiRobotResettingStep := 40;
			40:
				M_Reset(iTrigger :=FALSE);
				uiRobotResettingStep := 50;
			50:
				IF reset THEN
					uiRobotResettingStep := 0;
				END_IF
				IF NOT Error AND NOT hold THEN
					eState := E_MethodStatus_Basic.STATE_DORMANT;
				END_IF
		END_CASE
    E_MethodStatus_Basic.STATE_Holding:
        _UI1.UI02_Hold := FALSE;

        IF _UO1.UO04_PrgPaused AND NOT _UO1.UO03_PrgRunning THEN
            Halt    := TRUE;
            _Status := GVL_ErrorCode.GC_MSG_0215;
            eState  := E_MethodStatus_Basic.STATE_Held;
        END_IF
//		IF reset THEN
//			eState         := E_MethodStatus_Basic.STATE_RESETTING;
//		END_IF

		IF rTrigReset.Q THEN
			Ton_Reset_SwitchDelay.IN := TRUE;
		END_IF
		IF Ton_Reset_SwitchDelay.Q THEN
			uiRobotResettingStep:=0;
			eState:=E_MethodStatus_Basic.STATE_RESETTING;
		END_IF
		
    E_MethodStatus_Basic.STATE_Held:
		bINP := TRUE;
        IF reset AND NOT Hold THEN
            Halt := FALSE;
        END_IF

        IF NOT Halt AND Start THEN
            _UI1.UI02_Hold := TRUE;
            eState         := E_MethodStatus_Basic.STATE_UnHold;
        END_IF
		RobotErrId := M_GetErrorCode();//Edited by Jidien Kachu in 2025/10/13
//		IF iRetryCnt > 3 THEN
//			_Status := GVL_ErrorCode.GC_MSG_0211;
//		ELSE
			CASE RobotErrId OF
				1:
				_Status := GVL_ErrorCode.GC_MSG_0220;
				2:
				_Status := GVL_ErrorCode.GC_MSG_0208;
				3:
				_Status := GVL_ErrorCode.GC_MSG_0221;
				4:
				_Status := GVL_ErrorCode.GC_MSG_0205;
				5:
				_Status := GVL_ErrorCode.GC_MSG_0206;
				6:
				_Status := GVL_ErrorCode.GC_MSG_0207;
				7:
				_Status := GVL_ErrorCode.GC_MSG_0209;
				8:		
				_Status := GVL_ErrorCode.GC_MSG_0216;
			END_CASE
//		END_IF
		
		
    E_MethodStatus_Basic.STATE_UnHold:
        Ton_START_SwitchDelay.IN := TRUE;
		_UI1.UI06_Start          := NOT Ton_START_SwitchDelay.Q;
//		_UI1.UI06_Start := TRUE;

        IF NOT _UO1.UO04_PrgPaused AND _UO1.UO03_PrgRunning AND NOT _UI1.UI06_Start AND NOT _DI1.Error AND iRetryCnt <= 3 THEN
            Ton_START_SwitchDelay.IN := FALSE;
			Ton_Reset_SwitchDelay.IN := FALSE;
			_DO6.RSR1_Retry := FALSE;
			_UI1.UI06_Start := FALSE;
            eState                   := E_MethodStatus_Basic.STATE_EXECUTING;
			_Status := '';
//			iRetryCnt := iRetryCnt + 1;
        END_IF
		(* Edited by Jidien kachu in 2025/10/09 *)
		IF _DI1.Error AND iRetryCnt <= 3 AND RobotErrId <> 8 THEN
			CASE RobotErrId OF
				1..7:
				_DO6.RSR1_Retry := TRUE;
			END_CASE
		END_IF
		(*======================================*)
		IF rTrigReset.Q THEN
			Ton_Reset_SwitchDelay.IN := TRUE;
			
		END_IF
		IF Ton_Reset_SwitchDelay.Q THEN
			uiRobotResettingStep:=0;
			eState:=E_MethodStatus_Basic.STATE_RESETTING;
			iRetryCnt := 0;
		END_IF
		
END_CASE

IF Estop THEN
   // _Error  := TRUE;
    _Status := GVL_ErrorCode.GC_MSG_0204;
	eState  := E_MethodStatus_Basic.STATE_ERROR;
ELSIF _UO1.UO08_TPEnabled THEN
    _Error  := TRUE;
    _Status := GVL_ErrorCode.GC_MSG_0219;
	eState  := E_MethodStatus_Basic.STATE_ERROR;
ELSIF _UO1.UO09_BattAlarm THEN
    _Error  := TRUE;
    _Status := GVL_ErrorCode.GC_MSG_0213;
	eState  := E_MethodStatus_Basic.STATE_ERROR;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ActiveRSR02" Id="{852e35c1-33f2-4795-83cd-808f6b0ff594}" FolderPath="Method\ModeControl\">
      <Declaration><![CDATA[METHOD M_ActiveRSR02
VAR_INPUT
END_VAR
VAR_OUTPUT
	bCompleted : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eState OF
	E_MethodStatus_Basic.STATE_DORMANT:
		// 允許 RSR02 在 Error 8 (not in home pos) 時啟動
		// 因為 Error 8 只能透過 RSR02 回到 Home 才能清除
		IF (NOT _Error OR M_GetErrorCode() = 8) AND _UO1.UO02_SystemReady THEN
        	enable(TRUE);
		ELSE
			Enable(FALSE);
		END_IF
        M_Reset(FALSE);
        _uiRSR01_Step := 0;
		uiRobotExecutingStep := 0;
        uiRobotResettingStep := 0;
		_RSR1_Ready := FALSE;
		_RSR2_Completed := FALSE;
		_RSR3_Ready:=FALSE;
		TON_Reset_delay.IN := FALSE;
		IF _eOpMode = RSR01 OR _eOpMode = RSR02 OR _eOpMode = RSR03 THEN
			eState := E_MethodStatus_Basic.STATE_EXECUTING;
		END_IF
	E_MethodStatus_Basic.STATE_EXECUTING:
		CASE uiRobotExecutingStep OF
			0:
				Hold := FALSE;
                Enable(iTrigger := TRUE);
				TON_Restart_delay.IN := TRUE;
				_UI1.UI09_RSR1 := FALSE;//Edited by Jidien Kachu in 2025/10/27
				_UI1.UI10_RSR2 := FALSE;//Edited by Jidien Kachu in 2025/10/27
				IF TON_Restart_delay.Q THEN
					uiRobotExecutingStep := 10;
				END_IF
				Ton_START_SwitchDelay.IN := FALSE; //Edited by Jidien Kachu in 2025/10/29
			10:
				TON_Restart_delay.IN := FALSE;
                M_Reset(iTrigger := TRUE);
				_UI1.UI04_CycleStop := TRUE;
				TON_ResetFixDelay.in := TRUE;
				IF TON_ResetFixDelay.Q THEN
	                uiRobotExecutingStep := 100;
				END_IF
			100:
				TON_ResetFixDelay.in := FALSE;
				TON_Reset_delay.in := TRUE;
                M_Reset(iTrigger := FALSE);
				_UI1.UI04_CycleStop := FALSE;
				IF TON_Reset_delay.Q THEN
					IF _UO1.UO01_CmdEnabled AND _UO1.UO02_SystemReady THEN
						_VelocityCommand.nInt := 1;
						uiRobotExecutingStep := 200;
					// ❌ 移除: RSR02 專門用來回 Home，不應該因為 "not in home pos" 錯誤而中斷
					// Error 8 (not in home pos) 只有執行 RSR02 回到 Home 才能清除
					ELSIF Error AND M_GetErrorCode() <> 8 THEN
						eState := E_MethodStatus_Basic.STATE_ERROR;
					// 如果是 Error 8，繼續執行 RSR02
					ELSIF Error AND M_GetErrorCode() = 8 THEN
						_VelocityCommand.nInt := 1;
						uiRobotExecutingStep := 200;
					END_IF
				END_IF
			200:
				// Clear Fanuc robot's action
				GVL_ADS.AutoMode_WarehouseMotoWithRobotMove.HandShake.Execute := FALSE;
				GVL_ADS.AutoMode_RobotAbsMove.HandShake.Execute := FALSE;
				_DO1.bExecute := FALSE;
				_DO2.bExecute := FALSE;
				_DO3.bExecute := FALSE;
				_DO4.bExecute := FALSE;
				uiRobotExecutingStep := 300;
			300:
				// Switch RSR02
				_UI1.UI10_RSR2 := TRUE;
		
				IF _UO1.UO12_ACK2 THEN
					uiRobotExecutingStep := 400;
				END_IF
			400:
				_UI1.UI10_RSR2 := FALSE;
				IF (_DI1.Done OR _UO1.UO07_AtPerch )  
				THEN
					uiRobotExecutingStep := 9900;
				END_IF
			9900:
				eState := E_MethodStatus_Basic.STATE_DONE;
		END_CASE
	E_MethodStatus_Basic.STATE_DONE:
		_RSR2_Completed := TRUE;
		bCompleted := TRUE;
	E_MethodStatus_Basic.STATE_ABORTING:
		;
	E_MethodStatus_Basic.STATE_Aborted:
		;
	E_MethodStatus_Basic.STATE_ERROR:
		Enable(iTrigger := FALSE);
		IF reset THEN
			eState := E_MethodStatus_Basic.STATE_RESETTING;
		END_IF
		IF NOT Estop AND NOT Error THEN
			eState := E_MethodStatus_Basic.STATE_RESETTING;
		END_IF
	E_MethodStatus_Basic.STATE_RESETTING:
		eState := E_MethodStatus_Basic.STATE_DORMANT;
END_CASE
IF Estop OR _UO1.UO08_TPEnabled THEN
	eState := E_MethodStatus_Basic.STATE_ERROR;
	_Error := TRUE;
	_Status := GVL_ErrorCode.GC_MSG_0204;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ActiveRSR03" Id="{b3fc9105-3a60-403e-b13b-10e04e5bab64}" FolderPath="Method\ModeControl\">
      <Declaration><![CDATA[METHOD M_ActiveRSR03
VAR_INPUT
END_VAR
VAR_OUTPUT
	bCompleted : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _uiRSR03_Step OF
	0:
		// Stop Prog
		_RSR1_Ready := FALSE;
		_RSR2_Completed := FALSE;
		_RSR3_Ready:=FALSE;
		_UI1.UI04_CycleStop := TRUE;
		IF NOT _UO1.UO04_PrgPaused AND NOT _UO1.UO03_PrgRunning THEN
			_uiRSR03_Step := 100;
		END_IF
	100:
		// Close cycle stop
		_UI1.UI04_CycleStop := FALSE;
		// Set current prog - RSR03
		_UI1.UI11_RSR3 := TRUE;
		IF _UO1.UO13_ACK3 THEN
			_uiRSR03_Step := 200;
		END_IF
	200:
		// Clear RSR03 command 
		_UI1.UI11_RSR3 := FALSE;
		_uiRSR03_Step := 300;
	300:
		// Allow Read / Write offset data
		IF ( GVL_ADS.FanucRobot_ReadAllOffsetData.Status.Busy  OR GVL_ADS.FanucRobot_ReadAllOffsetData.Status.Done) AND
			(GVL_ADS.FanucRobot_ReadSingleOffsetData.Status.Busy OR GVL_ADS.FanucRobot_ReadSingleOffsetData.Status.Done) AND
			(GVL_ADS.FanucRobot_WirteSingleOffsetData.Status.Busy OR GVL_ADS.FanucRobot_WirteSingleOffsetData.Status.Done ) AND
			(GVL_ADS.FanucRobot_WriteAllOffsetData.Status.Busy OR GVL_ADS.FanucRobot_WriteAllOffsetData.Status.Done) 
		THEN
			_RSR3_Ready := FALSE;
			bCompleted := FALSE;
		ELSE
			_RSR3_Ready := FALSE;
			bCompleted := TRUE;
		END_IF 
		
END_CASE

CASE eState OF
	E_MethodStatus_Basic.STATE_DORMANT:
        Enable(FALSE);
        M_Reset(FALSE);
        _uiRSR01_Step := 0;
		uiRobotExecutingStep := 0;
        uiRobotResettingStep := 0;
		_RSR1_Ready := FALSE;
		_RSR2_Completed := FALSE;
		_RSR3_Ready:=FALSE;
		TON_Reset_delay.IN := FALSE;
		IF _eOpMode = RSR01 OR _eOpMode = RSR02 OR _eOpMode = RSR03 THEN
			eState := E_MethodStatus_Basic.STATE_EXECUTING;
		END_IF
	E_MethodStatus_Basic.STATE_EXECUTING:
		CASE uiRobotExecutingStep OF
			0:
                Enable(iTrigger := TRUE);
				TON_Restart_delay.IN := TRUE;
				IF TON_Restart_delay.Q THEN
					uiRobotExecutingStep := 10;
				END_IF
			10:
				TON_Restart_delay.IN := FALSE;
                M_Reset(iTrigger := TRUE);
				_UI1.UI04_CycleStop := TRUE;
				TON_ResetFixDelay.IN := TRUE;
				IF TON_ResetFixDelay.Q THEN
                	uiRobotExecutingStep := 100;
				END_IF
			100:
				TON_ResetFixDelay.IN := FALSE;
				TON_Reset_delay.in := TRUE;
                M_Reset(iTrigger := FALSE);
				_UI1.UI04_CycleStop := FALSE;
				IF TON_Reset_delay.Q THEN
					IF _UO1.UO01_CmdEnabled AND _UO1.UO02_SystemReady THEN
						_VelocityCommand.nInt := 1;
						uiRobotExecutingStep := 200;
					ELSIF Error THEN
						eState := E_MethodStatus_Basic.STATE_ERROR;
					END_IF
				END_IF
			200:
				// Clear Fanuc robot's action
				TON_Reset_delay.IN := FALSE;
				GVL_ADS.AutoMode_WarehouseMotoWithRobotMove.HandShake.Execute := FALSE;
				GVL_ADS.AutoMode_RobotAbsMove.HandShake.Execute := FALSE;
				_DO1.bExecute := FALSE; // Warehouse with robot clampA
				_DO2.bExecute := FALSE; // Warehouse with robot clampB
				_DO3.bExecute := FALSE; // AbsMove with robot clampA
				_DO4.bExecute := FALSE; // AbsMove with robot clampB
				uiRobotExecutingStep := 300;
			300:
				// Active RSR1
                _UI1.UI11_RSR3 := TRUE;
                IF _UO1.UO13_ACK3 THEN
                    uiRobotExecutingStep := 400;
				ELSIF Error THEN
					_Error := TRUE;
					_Status:=GVL_ErrorCode.GC_MSG_0218;
                END_IF
			400:
				// Allow Read / Write offset data
				IF ( GVL_ADS.FanucRobot_ReadAllOffsetData.Status.Busy  OR GVL_ADS.FanucRobot_ReadAllOffsetData.Status.Done) AND
					(GVL_ADS.FanucRobot_ReadSingleOffsetData.Status.Busy OR GVL_ADS.FanucRobot_ReadSingleOffsetData.Status.Done) AND
					(GVL_ADS.FanucRobot_WirteSingleOffsetData.Status.Busy OR GVL_ADS.FanucRobot_WirteSingleOffsetData.Status.Done ) AND
					(GVL_ADS.FanucRobot_WriteAllOffsetData.Status.Busy OR GVL_ADS.FanucRobot_WriteAllOffsetData.Status.Done) 
				THEN
					_RSR3_Ready := FALSE;
					bCompleted := FALSE;
				ELSE
					_RSR3_Ready := FALSE;
					bCompleted := TRUE;
				END_IF 
		END_CASE
	E_MethodStatus_Basic.STATE_DONE:
		;
	E_MethodStatus_Basic.STATE_ABORTING:
		;
	E_MethodStatus_Basic.STATE_Aborted:
		;
	E_MethodStatus_Basic.STATE_ERROR:
		Enable(iTrigger := FALSE);
		IF Reset THEN
			eState := E_MethodStatus_Basic.STATE_RESETTING;
		END_IF
		IF  Estop AND NOT Error THEN
			eState := E_MethodStatus_Basic.STATE_RESETTING;
		END_IF
	E_MethodStatus_Basic.STATE_RESETTING:
		eState := E_MethodStatus_Basic.STATE_DORMANT;
END_CASE

IF Estop OR _UO1.UO08_TPEnabled THEN
	eState := E_MethodStatus_Basic.STATE_ERROR;
	_Error := TRUE;
	_Status := GVL_ErrorCode.GC_MSG_0204;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ClearState" Id="{1952fa3e-6dba-4673-9d16-d8027aada721}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD M_ClearState : BOOL;
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
eState := E_MethodStatus_Basic.STATE_DORMANT;
uiRobotExecutingStep := 0;
uiRobotResettingStep := 0;
M_ClearState := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ControlRSR01" Id="{bcb4fe96-4792-4404-912c-6714ffc321c9}" FolderPath="Method\ModeControl\">
      <Declaration><![CDATA[METHOD M_ControlRSR01
VAR_INPUT
END_VAR
VAR_OUTPUT
	bCompleted : BOOL;
	ModeChanging : BOOL;
	ModeChanged : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ModeChanging := FALSE;
ModeChanged := TRUE;
M_ActiveRSR01(bCompleted => bCompleted);

IF OpMode <> _eOpMode (*AND (bCompleted OR bINP)*) THEN
    _uiRSR01_Step := 0;
    eState := E_MethodStatus_Basic.STATE_DORMANT;
    _eOpMode := OpMode;
	bINP := FALSE;
	_Error  := FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ControlRSR02" Id="{8e129eae-e0be-4da0-a048-edee41293866}" FolderPath="Method\ModeControl\">
      <Declaration><![CDATA[METHOD M_ControlRSR02
VAR_INPUT
END_VAR
VAR_OUTPUT
    bCompleted : BOOL;
    ModeChanging : BOOL;
    ModeChanged : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ModeChanging := FALSE;
ModeChanged := TRUE;
M_ActiveRSR02(bCompleted => bCompleted);

IF OpMode <> _eOpMode AND bCompleted THEN
    _uiRSR02_Step := 0;
    eState := E_MethodStatus_Basic.STATE_DORMANT;
    _eOpMode := OpMode;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ControlRSR03" Id="{83abdd3b-2b3b-4c43-85dc-c5894cb7ff45}" FolderPath="Method\ModeControl\">
      <Declaration><![CDATA[METHOD M_ControlRSR03

VAR_INPUT
END_VAR
VAR_OUTPUT
    bCompleted : BOOL;
    ModeChanging : BOOL;
    ModeChanged : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[ModeChanging := FALSE;
ModeChanged := TRUE;
M_ActiveRSR03(bCompleted => bCompleted);

IF OpMode <> _eOpMode AND bCompleted THEN
	_uiRSR03_Step := 0;
	eState := E_MethodStatus_Basic.STATE_DORMANT;
	_eOpMode := OpMode;
END_IF]]></ST>
      </Implementation>
    </Method>
