    <Method Name="M_Kawasaki_API" Id="{a99effd1-dac7-4001-a6a2-2106ed5eb6cc}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD M_Kawasaki_API
VAR_INPUT
	WarehouseClampA_Handshake : UINT;
	WarehouseClampB_Handshake : UINT;
	AbsMoveClampA_Handshake : UINT;
	AbsMoveClampB_Handshake : UINT;
END_VAR
VAR_OUTPUT
	Status : UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[MEMMOVE(destAddr:=ADR(_DO1),srcAddr:=ADR(WarehouseClampA_Handshake),n:=2);
MEMMOVE(destAddr:=ADR(_DO2),srcAddr:=ADR(WarehouseClampB_Handshake),n:=2);
MEMMOVE(destAddr:=ADR(_DO3),srcAddr:=ADR(AbsMoveClampA_Handshake),n:=2);
MEMMOVE(destAddr:=ADR(_DO4),srcAddr:=ADR(AbsMoveClampB_Handshake),n:=2);
IF NOT _UO1.UO08_TPEnabled THEN
	MEMMOVE(destAddr:=ADR(Status),srcAddr:=ADR(_DI1),n:=2);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ManualService" Id="{2546a455-5a0b-40b7-b479-3a695cf9c66f}" FolderPath="Method\ManualService\">
      <Declaration><![CDATA[METHOD M_ManualService
VAR_INPUT
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF ManualCtrl.ClampA_Open AND _DI1.ClampA_Open THEN 
	ManualCtrl.ClampA_Open := FALSE;
	_DO5.ClampA_Open :=FALSE;
END_IF
IF ManualCtrl.ClampB_Open AND _DI1.ClampB_Open THEN 
	ManualCtrl.ClampB_Open := FALSE;
	_DO5.ClampB_Open :=FALSE;
END_IF
IF ManualCtrl.ClampA_close AND NOT _DI1.ClampA_Open THEN 
	ManualCtrl.ClampA_close := FALSE;
	_DO5.ClampA_Close :=FALSE;
END_IF
IF ManualCtrl.ClampB_close AND NOT _DI1.ClampB_Open THEN 
	ManualCtrl.ClampB_close := FALSE;
	_DO5.ClampB_Close :=FALSE;
END_IF

_DO5.ClampA_close := ManualCtrl.ClampA_close;
_DO5.ClampA_Open := ManualCtrl.ClampA_Open;
_DO5.ClampB_Close := ManualCtrl.ClampB_close;
_DO5.ClampB_Open := ManualCtrl.ClampB_Open;
_DO6.ByPassClampSensor := ManualCtrl.ByPassClampSensor;
//GVL_ADS.FanucRobot_General.Status.ClampA_Open := _DI1.ClampA_Open;
//GVL_ADS.FanucRobot_General.Status.ClampA_Sensor := _DI1.ClampA_Sensor;
//GVL_ADS.FanucRobot_General.Status.ClampB_Open := _DI1.ClampB_Open;
//GVL_ADS.FanucRobot_General.Status.ClampB_Sensor := _DI1.ClampB_Sensor;
ManualCtrl.ClampA_Open_Status 	:= _DI1.ClampA_Open;
ManualCtrl.ClampA_SensorStatus 	:= _DI1.ClampA_Sensor;
ManualCtrl.ClampB_Open_Status 	:= _DI1.ClampB_Open;
ManualCtrl.ClampB_SensorStatus 	:= _DI1.ClampB_Sensor;

ManualCtrl.bStorageA_LaserStatus	:= bStorageA_LaserStatus;
ManualCtrl.bStorageB_LaserStatus := bStorageB_LaserStatus;
ManualCtrl.bRoundBelt_LaserStatus := bRoundBelt_LaserStatus;
ManualCtrl.bPrep_LaserStatus := bPrep_LaserStatus;
ManualCtrl.bNeedle_LaserStatus := bNeedle_LaserStatus;
ManualCtrl.bConveyor_LaserStatus := bConveyor_LaserStatus;
ManualCtrl.bRemoval_LaserStatus := bRemoval_LaserStatus;

//Laser Detect 
ManualCtrl.ClampA1_Laser_Status := bClampA1_Laser_DetectStatus;
ManualCtrl.ClampB1_Laser_Status := bClampB1_Laser_DetectStatus;
ManualCtrl.ClampA2_Laser_Status := bClampA2_Laser_DetectStatus;
ManualCtrl.ClampB2_Laser_Status := bClampB2_Laser_DetectStatus;

//CCD
ManualCtrl.bRemoval_Vision_Status := bRoundBelt_Vision_Status;
ManualCtrl.bPrep_Vision_Status := bPrep_Vision_Status;
ManualCtrl.bNeedle_Vision_Status := bNeedle_Vision_Status;
ManualCtrl.bRemoval_Vision_Status := bRemoval_Vision_Status;

//Laser byPass edit min 2025/10/16
bStorageA_LaserSwitch	:= ManualCtrl.bStorageA_LaserSwitch;
bStorageB_LaserSwitch	:= ManualCtrl.bStorageB_LaserSwitch;
bRoundBelt_LaserSwitch := ManualCtrl.bRoundBelt_LaserSwitch;
bPrep_LaserSwitch := ManualCtrl.bPrep_LaserSwitch;
bNeedle_LaserSwitch := ManualCtrl.bNeedle_LaserSwitch;
bConveyor_LaserSwitch	:= ManualCtrl.bConveyor_LaserSwitch;
bRemoval_LaserSwitch := ManualCtrl.bRemoval_LaserSwitch;

//CCD
bRoundBelt_Vision_Switch := ManualCtrl.bRoundBelt_Vision_Switch;
bPrep_Vision_Switch := ManualCtrl.bPrep_Vision_Switch;
bNeedle_Vision_Switch := ManualCtrl.bNeedle_Vision_Switch;
bRemoval_Vision_Switch := ManualCtrl.bRemoval_Vision_Switch;

]]></ST>
      </Implementation>
    </Method>
