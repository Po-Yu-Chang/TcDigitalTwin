    </LineIds>
    <LineIds Name="FB_WareHouseInnerPickToRoundBelt.M_STATE_DORMANT">
      <LineId Id="3" Count="40" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="FB_WareHouseInnerPickToRoundBelt.M_STATE_ERROR">
      <LineId Id="3" Count="6" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="FB_WareHouseInnerPickToRoundBelt.M_STATE_EXECUTING">
      <LineId Id="3" Count="1649" />
