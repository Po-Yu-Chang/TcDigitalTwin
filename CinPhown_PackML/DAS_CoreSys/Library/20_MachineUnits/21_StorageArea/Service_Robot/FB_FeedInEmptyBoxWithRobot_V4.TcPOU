<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_FeedInEmptyBoxWithRobot_V4" Id="{93752edc-72b5-476d-b8ce-d0eb98bfaeae}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_FeedInEmptyBoxWithRobot_V4 EXTENDS FB_ObjectBase_V2 IMPLEMENTS IBasicElement
VAR_INPUT
    // Below are the components being controlled.
    Robot           : REFERENCE TO FB_FanucRobot_Basic_V2; // Fanuc Robot
    PullOutConveyor : REFERENCE TO FB_PullOutConveyorAction; // Allocated area pull out conveyor
    DiffSizeCV  	: REFERENCE TO FB_Motor; // Allocated area feed in conveyor(diff and same size conveyor)
	SameSizeCV 		: REFERENCE TO FB_Motor;
    WareHouse       : REFERENCE TO FB_WareHouse; // Storage area warehouse A and warehouse B conveyor and sensor
    //SameSizeFullSensor : REFERENCE TO BOOL; 				 // Because the same size sensor implement FB_ConveyorSameSize, so use reference to connect it
    Info  			: ST_FeedInEmptyBox_Info; // Setting the feedin emptybox action's parameter
    Input 			: REFERENCE TO ST_InputTable;
    Stop  			: BOOL;
END_VAR
VAR_OUTPUT
	AClampMoveDone	: BOOL;
	BClampMoveDone	: BOOL;
END_VAR
VAR
    tonPlaceSensorDelay    : TON;
    tonFeedInConveyorDelay : TON;
    tonTimeOut             : TON;
	bTimeOutIN			   : BOOL;
    tonFeedBoxTimeout      : TON;
	TON_WaitRobotClear	   : TON;
    strStatus              : STRING;
    _UniqueErrorCode       : STRING;
//    _Abort                 : BOOL;
    uiResumeStep           : UDINT;
	uiResumePlaceBothStep  : UINT;
	uiResumePlaceSingleStep: UINT;
    PreviousStrStatus      : STRING;
    PreviousErrorCode      : STRING;
	
	WorkingConveyor			: REFERENCE TO FB_Motor;
	SelectedSensor			: BOOL;
	bWorkingConveyorMoveForward : BOOL;
	bWorkingConveyorMoveBackward : BOOL;
	
	uiPickUpBothStep            : UDINT;
    uiPlaceBothStep             : UINT;
	uiPlaceSingleStep			: UINT;
	
	// Clamp work
	_AClampDoingWork	: BOOL;
	_BClampDoingWork	: BOOL;
	
	uiResumePickUpBothStep : UDINT;
	
	_bRetry	: BOOL;

	// Safe Pause
	bPauseLatched : BOOL;
	uiPauseFromStep : UDINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SUPER^.A10_StateControl();
A00_BasicUnits();

(*============================================================
Create Date : 2025/12/01
Last Update	: 2025/12/01
Change Log  : 2025/11/24，send flag A clamp done and B clamp done for C# use to SQL // Owner : Gamin
			  2025/12/1 ，Create V3__ import Kinsus version to fix Singal Clamp doing 	//Owner : Gamin
			  2026/03/23，新增 V4版本，新增輸送帶續做後移動功能。
			  2026/04/02，修正 STATE_Error 狀態。
============================================================*)]]></ST>
    </Implementation>
    <Folder Name="Method" Id="{fba50727-22e6-4558-84de-5a22fcc094ce}" />
    <Folder Name="RobotClampStatus" Id="{bf92ef22-64fe-44a6-9b6a-235a9c57887c}" />
    <Folder Name="State" Id="{27b0155a-a810-4df7-b93f-62ae7c59d085}" />
    <Action Name="A00_BasicUnits" Id="{95a3a71e-0315-49e4-b200-10c553dca66e}">
      <Implementation>
        <ST><![CDATA[tonTimeOut(IN:= bTimeOutIN AND NOT THIS^.Stop, PT:=T#60S);
tonFeedBoxTimeout(PT:=T#15s);
tonPlaceSensorDelay();
tonFeedInConveyorDelay(PT:=T#500MS);
TON_WaitRobotClear(PT := T#5S);]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_BothClampReleasedBox" Id="{b1721c87-b5a2-4328-a4ca-7445a04338a4}" FolderPath="RobotClampStatus\">
      <Declaration><![CDATA[METHOD PRIVATE M_BothClampReleasedBox : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_BothClampReleasedBox := THIS^.M_ClampAReleasedBox() AND THIS^.M_ClampBReleasedBox();]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckCommand" Id="{3cda13d0-7c2b-461e-be6f-4b9f0970b330}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD M_CheckCommand : BOOL
VAR_INPUT
END_VAR

VAR_INST
	CheckBehavior : BOOL; // True : Behavior is correct
	CheckWareHouseSetting : BOOL; // True : WareHouse setting is correct
	CheckPullOutConveyorSetting : BOOL; // True : PullOut Conveyor setting is correct
	CheckPickUpArea : BOOL; // True : PickUp Area is correct
	CheckPlaceArea : BOOL; // True : Place Area is correct
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Memory clear
CheckBehavior := FALSE;
CheckWareHouseSetting := TRUE;
CheckPullOutConveyorSetting := TRUE;
CheckPickUpArea := TRUE;
CheckPlaceArea := TRUE;

// Check command is correct
IF info.ClampA_Setting.Behavior = E_ClampWork.Work OR info.ClampB_Setting.Behavior = E_ClampWork.Work THEN
	CheckBehavior := TRUE;
ELSE
	CheckBehavior := FALSE;
	strStatus := 'No clamp selected to work';
END_IF

IF info.ClampA_Setting.Behavior = E_ClampWork.Work THEN
	IF info.ClampA_Setting.PickUpArea = E_FeedInEmptyBox_PickUpArea.Undefined THEN
		CheckPickUpArea := FALSE;
		strStatus := 'ClampA pickup area undefined';
	END_IF
	IF info.ClampA_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.Undefine THEN
		CheckPlaceArea := FALSE;
		strStatus := 'ClampA place area undefined';
	END_IF
	IF info.ClampA_Setting.PickUpArea = E_FeedInEmptyBox_PickUpArea.PullOutConveyor AND
	   info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.Undefined THEN
		CheckPullOutConveyorSetting := FALSE;
		strStatus := 'ClampA pullout slide undefined';
	END_IF
END_IF

IF info.ClampB_Setting.Behavior = E_ClampWork.Work THEN
	IF info.ClampB_Setting.PickUpArea = E_FeedInEmptyBox_PickUpArea.Undefined THEN
		CheckPickUpArea := FALSE;
		strStatus := 'ClampB pickup area undefined';
	END_IF
	IF info.ClampB_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.Undefine THEN
		CheckPlaceArea := FALSE;
		strStatus := 'ClampB place area undefined';
	END_IF
	IF info.ClampB_Setting.PickUpArea = E_FeedInEmptyBox_PickUpArea.PullOutConveyor AND
	   info.ClampB_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.Undefined THEN
		CheckPullOutConveyorSetting := FALSE;
		strStatus := 'ClampB pullout slide undefined';
	END_IF
END_IF

M_CheckCommand := CheckBehavior AND CheckWareHouseSetting AND CheckPullOutConveyorSetting AND CheckPickUpArea AND CheckPlaceArea;

IF NOT (CheckBehavior AND CheckWareHouseSetting AND CheckPullOutConveyorSetting AND CheckPickUpArea AND CheckPlaceArea) THEN
	Status := strStatus;
	_Error := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
