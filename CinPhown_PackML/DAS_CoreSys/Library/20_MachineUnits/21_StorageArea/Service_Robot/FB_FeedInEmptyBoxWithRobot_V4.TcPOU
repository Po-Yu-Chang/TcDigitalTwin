		Robot.M_ResetAllCommand(); // Clear command and go to place box
		IF NOT Robot._di1.Done THEN
			IF THIS^.M_HasBothClampBox() THEN
				uiExecutingStep := 80000; // only place clampA
			ELSE
				uiResumeStep:=37100;
				_Abort :=TRUE;
				strStatus := 'FB_FeedInEmptyBoxWithRobot_V4 Step 37180: mixed pickup finished but both clamp sensor not valid';
			END_IF
		END_IF
    38000: // ClampBoth pickup from PulloutConveyor
        DAS_CoreSys.MachineControl.fballocatearea.M_GetPulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);

        CASE uiPickUpBothStep OF
            0: // ClampA target slide move the box to front side
                IF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I3_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideB_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSIF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I4_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideA_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSE
                    strStatus := 'Not define PulloutConveyor Slide';
					Status := strStatus;
                    _Error := TRUE;
                END_IF

                IF DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Done THEN
                    BoxReady_1st     := TRUE;
                    uiPickUpBothStep := 10;
                END_IF

            10: // wait Robot Allow continue
                IF Robot._DI1.Notification THEN
            		DAS_CoreSys.MachineControl.fballocatearea.M_StopStoragePulloutAction();

                    IF NOT DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Done THEN
                        uiPickUpBothStep := 20;
                    END_IF

                END_IF
            20: // ClampB target slide move the box to front slide
                IF Info.ClampB_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I3_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideB_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSIF Info.ClampB_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I4_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideA_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSE
                    strStatus := 'Not define PulloutConveyor Slide';
					Status := strStatus;
                    _Error := TRUE;
                END_IF

                IF DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Done THEN
                    BoxReady_2nd     := TRUE;
                    uiPickUpBothStep := 99;
                END_IF
            99:
        // wait reset
        END_CASE
		bTimeOutIN :=TRUE;	
        Robot.M_StartPullOutConveyorPickUpBox_ClampBoth(ClampA_Address := Info.ClampA_Setting.PullOutConveyorSetting,
                                                        ClampB_Address := Info.ClampB_Setting.PullOutConveyorSetting,
                                                        BoxReady_1     := BoxReady_1st,
                                                        BoxReady_2     := BoxReady_2nd);

			IF Robot._DI1.Done AND uiPickUpBothStep = 99 THEN
				bTimeOutIN:=FALSE;
				IF THIS^.M_HasBothClampBox() THEN
					uiExecutingStep := 80000; // go to place step
				ELSE
					uiResumeStep:=38000;
					_Abort :=TRUE;
					strStatus := 'FB_FeedInEmptyBoxWithRobot_V4 Step 38000: both clamp pickup finished but clamp sensor not valid';
				END_IF
			END_IF
		
			
			IF tonTimeOut.Q THEN
				bTimeOutIN:=FALSE;
				_Abort :=TRUE;	
				uiResumeStep:=38000;		
				strStatus := M_FormatManagedStatus(
					AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
					InnerMessage := GVL_ErrorCode.GC_MSG_0096);
				Status := strStatus;
				Error := TRUE;
			END_IF
			IF DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Error THEN
				uiResumeStep 	:= 38000;
				uiResumePickUpBothStep := uiPickUpBothStep;
				strStatus 		:= DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Status;
				Status := strStatus;
				Error := TRUE;
				_Abort 			:= TRUE;
			END_IF
			
    60000: // Only ClampA place box
        // Clear command
        WareHouse.M_ResetReloadBox();
        Robot.M_ResetAllCommand();

        IF NOT THIS^.M_HasClampABox() THEN
			_Abort :=TRUE;
			uiResumeStep:=60000;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
				InnerMessage := GVL_ErrorCode.GC_MSG_0121);
        // Check robot RSR1 not working
        ELSIF NOT Robot._DI1.Done AND NOT (Robot._DI1.AbsMoveA OR Robot._DI1.AbsMoveB OR Robot._DI1.WarehouseA OR Robot._DI1.WarehouseB) THEN
            uiExecutingStep := 61000;
        END_IF
    61000: // Only ClampA place box Start
		bTimeOutIN :=TRUE;
		M_UpdateConveyorSensor(Info.ClampA_Setting.PlaceArea);
        IF NOT Robot._DI1.Done THEN
			CASE uiPlaceSingleStep OF	
				0: // setup
				IF NOT DiffSizeCV.InBackWard AND NOT SameSizeCV.InBackWard THEN
					CASE Info.ClampA_Setting.PlaceArea OF
						E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:					
							WorkingConveyor REF= DiffSizeCV;
						E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
							WorkingConveyor REF= SameSizeCV;
					END_CASE						
				END_IF
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceSingleStep:=100;
				END_IF
				
				100://Move conveyor forward to free conveyor
					bWorkingConveyorMoveForward:=  TRUE;
					IF WorkingConveyor.InForWard THEN
						uiPlaceSingleStep:=200;
					END_IF
	
				200:// delay for a while
					
					tonPlaceSensorDelay.IN := NOT SelectedSensor;
					IF tonPlaceSensorDelay.Q THEN
						tonPlaceSensorDelay.IN:=FALSE;
						uiPlaceSingleStep:=300;
					END_IF
					
				300:// stop motor
					WorkingConveyor.M_MotorStop(); 
					bWorkingConveyorMoveForward:= FALSE;
					bWorkingConveyorMoveBackward :=FALSE; 
					IF	WorkingConveyor.InStopped THEN
						uiPlaceSingleStep:=400;
					END_IF
				400:
					WorkingConveyor.M_MotorStop(); 
					IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN
						DiffSizeSlide_Clear := FALSE;
					ELSE
						DiffSizeSlide_Clear := TRUE;
					END_IF
	
					IF Input.bSameSizeCV_BoxNearStorageSensor THEN
						SameSizeSlide_clear := FALSE;
					ELSE
						SameSizeSlide_clear := TRUE;
					END_IF
					IF Robot._DI1.Error THEN
						uiResumeStep := 61000;
						uiResumePlaceSingleStep := 0;
						SameSizeSlide_clear		:= FALSE;
						DiffSizeSlide_Clear		:= FALSE;
						_Abort	  := TRUE;
						strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 61000:',Robot.ErrMsg);
					END_IF
				
			
			END_CASE
			
            Robot.M_StartMoveBoxToFeedInConveyor_ClampA(ConveyorSlideSelect := Info.ClampA_Setting.PlaceArea,
                                                        DiffSizeSlideClear  := DiffSizeSlide_Clear,
                                                        SameSizeSlideClear  := SameSizeSlide_clear);
        ELSIF THIS^.M_ClampAReleasedBox() THEN
			bTimeOutIN:=FALSE;
			uiPlaceSingleStep:=0;
            uiExecutingStep := 61100; // place done, reset robot command
        ELSE
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;
			uiResumeStep:=61000;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
				InnerMessage := GVL_ErrorCode.GC_MSG_0121);
        END_IF
				
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;		
			uiResumeStep:=61000;	
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
				InnerMessage := GVL_ErrorCode.GC_MSG_0097);
			Status := strStatus;
			Error := TRUE;
		END_IF
		IF Robot._DI1.Error THEN
			bTimeOutIN  := FALSE;
			_Abort		:= TRUE;
			uiResumeStep:= 61000;
			strStatus	:= CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 61000: ',robot.ErrMsg);
		END_IF
    61100: // ClampA place done, reset robot command
        bTimeOutIN := TRUE;
        IF Robot.M_ResetAllCommand() THEN
            bTimeOutIN := FALSE;
            uiExecutingStep := 99000;
        END_IF
        IF tonTimeOut.Q THEN
            bTimeOutIN := FALSE;
            _Abort := TRUE;
            uiResumeStep := 61100;
            strStatus := M_FormatManagedStatus(
                AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
                InnerMessage := GVL_ErrorCode.GC_MSG_0097);
            Status := strStatus;
            Error := TRUE;
        END_IF
        IF Robot._DI1.Error THEN
            bTimeOutIN := FALSE;
            _Abort := TRUE;
            uiResumeStep := 61100;
            strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 61100: ', robot.ErrMsg);
        END_IF
    70000: // Only ClampB place box
        // Clear command
        WareHouse.M_ResetReloadBox();
        Robot.M_ResetAllCommand();

        IF NOT THIS^.M_HasClampBBox() THEN
			_Abort 		:= TRUE;
			uiResumeStep:= 70000;
			strStatus 	:= M_FormatManagedStatus(AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
												 InnerMessage := GVL_ErrorCode.GC_MSG_0123);
        // Check robot RSR1 not working
        ELSIF NOT Robot._DI1.Done AND NOT (Robot._DI1.AbsMoveA OR Robot._DI1.AbsMoveB OR Robot._DI1.WarehouseA OR Robot._DI1.WarehouseB) THEN
			uiPlaceSingleStep :=0;
            uiExecutingStep := 71000;
        END_IF
	71000:
	
		bTimeOutIN :=TRUE;
		M_UpdateConveyorSensor(Info.ClampB_Setting.PlaceArea);
        IF NOT Robot._DI1.Done THEN
			CASE uiPlaceSingleStep OF	
				0: // setup
				IF NOT DiffSizeCV.InBackWard AND NOT SameSizeCV.InBackWard THEN
					CASE Info.ClampB_Setting.PlaceArea OF
						E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:					
							WorkingConveyor REF= DiffSizeCV;
						E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
							WorkingConveyor REF= SameSizeCV;
					END_CASE						
				END_IF
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceSingleStep:=100;
				END_IF
				
				100://Move conveyor forward to free conveyor
					bWorkingConveyorMoveForward:=  TRUE;
					IF WorkingConveyor.InForWard THEN
						uiPlaceSingleStep:=200;
					END_IF
	
				200:// delay for a while
					
					tonPlaceSensorDelay.IN := NOT SelectedSensor;
					IF tonPlaceSensorDelay.Q THEN
						tonPlaceSensorDelay.IN:=FALSE;
						uiPlaceSingleStep:=300;
					END_IF
					
				300:// stop motor
					WorkingConveyor.M_MotorStop(); 
					bWorkingConveyorMoveForward:= FALSE;
					bWorkingConveyorMoveBackward :=FALSE; 
					tonPlaceSensorDelay.IN:=FALSE;
					IF	WorkingConveyor.InStopped THEN
						uiPlaceSingleStep:=400;
					END_IF
				400:
					WorkingConveyor.M_MotorStop(); 
					IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN
						DiffSizeSlide_Clear := FALSE;
					ELSE
						DiffSizeSlide_Clear := TRUE;
					END_IF
	
					IF Input.bSameSizeCV_BoxNearStorageSensor THEN
						SameSizeSlide_clear := FALSE;
					ELSE
						SameSizeSlide_clear := TRUE;
					END_IF
					IF Robot._DI1.Error THEN
						uiResumeStep := 71000;
						uiResumePlaceSingleStep := 0;
						DiffSizeSlide_Clear		:= FALSE;
						SameSizeSlide_clear		:= FALSE;
						_Abort	  := TRUE;
						strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 71000:',Robot.ErrMsg);
					END_IF
				
			
			END_CASE
			
            Robot.M_StartMoveBoxToFeedInConveyor_ClampB(ConveyorSlideSelect := Info.ClampB_Setting.PlaceArea,
                                                        DiffSizeSlideClear  := DiffSizeSlide_Clear,
                                                        SameSizeSlideClear  := SameSizeSlide_clear);
        ELSIF THIS^.M_ClampBReleasedBox() THEN
			bTimeOutIN:=FALSE;
			uiPlaceSingleStep:=0;
            uiExecutingStep := 71100; // place done, reset robot command
        ELSE
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;
			uiResumeStep:=71000;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
				InnerMessage := GVL_ErrorCode.GC_MSG_0123);
        END_IF	       
       	
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;		
			uiResumeStep:=71000;	
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
				InnerMessage := GVL_ErrorCode.GC_MSG_0097);
			Status := strStatus;
			Error := TRUE;
		END_IF
		IF Robot._DI1.Error THEN
			bTimeOutIN	:= FALSE;
			_Abort		:= TRUE;
			uiResumeStep:= 71000;
			strStatus	:= CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 71000:',robot.ErrMsg);
			Status		:= strStatus;
		END_IF
    71100: // ClampB place done, reset robot command
        bTimeOutIN := TRUE;
        IF Robot.M_ResetAllCommand() THEN
            bTimeOutIN := FALSE;
            uiExecutingStep := 99000;
        END_IF
        IF tonTimeOut.Q THEN
            bTimeOutIN := FALSE;
            _Abort := TRUE;
            uiResumeStep := 71100;
            strStatus := M_FormatManagedStatus(
                AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
                InnerMessage := GVL_ErrorCode.GC_MSG_0097);
            Status := strStatus;
            Error := TRUE;
        END_IF
        IF Robot._DI1.Error THEN
            bTimeOutIN := FALSE;
            _Abort := TRUE;
            uiResumeStep := 71100;
            strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 71100: ', robot.ErrMsg);
            Status := strStatus;
        END_IF
		
	80000:
			IF THIS^.M_HasBothClampBox() THEN
				uiExecutingStep := 80100;
			ELSE
				_Abort 	  := TRUE;
				uiResumeStep := 80000;
				strStatus := 'FB_FeedInEmptyBoxWithRobot_V4 Step 80000: Robot use both clamp place, but clamp sensor/open status not valid';
			END_IF	 
		
    80100: // Both Clamp place box
        WareHouse.M_ResetReloadBox(); // Clear Warehouse reload command
        Robot.M_ResetAllCommand(); // Clear Fanuc Robot command
		bTimeOutIN := FALSE;
        IF NOT Robot._DI1.Done THEN
            uiExecutingStep := 81000;
        END_IF;
    81000:
        CASE uiPlaceBothStep OF
			
            0:  //setup              
                SlideClear_1st  := FALSE;
                SlideClear_2nd  := FALSE;
			IF NOT DiffSizeCV.InBackWard AND NOT SameSizeCV.InBackWard THEN
				CASE Info.ClampA_Setting.PlaceArea OF
					E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:
						WorkingConveyor REF=DiffSizeCV;
					E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
						WorkingConveyor REF= SameSizeCV;						
				END_CASE
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceBothStep := 5;
				END_IF
			END_IF
				
			5://Move motor forward
				bWorkingConveyorMoveForward:=  TRUE;
				IF WorkingConveyor.InForWard THEN
					uiPlaceBothStep := 10;
				END_IF
				
				
            10://Delay for a while
				M_UpdateConveyorSensor(Info.ClampA_Setting.PlaceArea);
				tonPlaceSensorDelay.IN := NOT SelectedSensor AND WorkingConveyor.InForWard ;
				IF tonPlaceSensorDelay.Q THEN
					tonPlaceSensorDelay.IN:=FALSE;
					uiPlaceBothStep := 20;
				END_IF
				
				
             20://Stop movor
					WorkingConveyor.M_MotorStop(); 
					bWorkingConveyorMoveForward:= FALSE;
					bWorkingConveyorMoveBackward :=FALSE; 
//					IF WorkingConveyor.InStopped THEN
//						uiPlaceBothStep := 30;
//					END_IF 
					uiPlaceBothStep := 30;

			30:	// ClampA place box
				
				WorkingConveyor.M_MotorStop(); 	
				bWorkingConveyorMoveForward:= FALSE;
				bWorkingConveyorMoveBackward :=FALSE; 
//				IF	WorkingConveyor.InStopped THEN
                	IF info.ClampA_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor THEN
                    	IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN
                        	SlideClear_1st := FALSE;
                    	ELSE
                        	SlideClear_1st := TRUE;
                    	END_IF

                	ELSIF info.ClampA_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.SameSizeConveyor THEN
                    	IF Input.bSameSizeCV_BoxNearStorageSensor THEN
                        	SlideClear_1st := FALSE;
                    	ELSE
                        	SlideClear_1st := TRUE;
                    	END_IF
                	END_IF
					IF SlideClear_1st  THEN
                		uiPlaceBothStep := 40;
					END_IF
//				ELSE
//					SlideClear_1st := FALSE;
//				END_IF
				IF Robot._DI1.Error THEN
					uiResumeStep := 81000;
					uiResumePlaceBothStep := 0;
					SlideClear_1st		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 81000:',Robot.ErrMsg);
				END_IF
            40: //setup for clampB				
			
				CASE Info.ClampB_Setting.PlaceArea OF
					E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:
						WorkingConveyor REF= DiffSizeCV;
					E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
						WorkingConveyor REF= SameSizeCV;
				END_CASE
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceBothStep := 50;
				END_IF
				IF Robot._DI1.Error THEN
					uiResumeStep := 81000;
					uiResumePlaceBothStep := 0;
					SlideClear_1st		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 81000:',Robot.ErrMsg);
				END_IF

			50://Wait Robot finish clampA
				IF Robot._DI1.Notification THEN
					uiPlaceBothStep:=60;
				END_IF
				IF Robot._DI1.Error THEN
					uiResumeStep := 81000;
					uiResumePlaceBothStep := 0;
					SlideClear_1st		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 81000:',Robot.ErrMsg);
				END_IF

			60://Move conveyor forward
				bWorkingConveyorMoveForward:=  TRUE;
				IF WorkingConveyor.InForWard THEN
					uiPlaceBothStep:=70;
				END_IF
				
			70://Update sensor
				M_UpdateConveyorSensor(Info.ClampB_Setting.PlaceArea);
				tonPlaceSensorDelay.IN := NOT SelectedSensor AND WorkingConveyor.InForWard ;
				IF 	tonPlaceSensorDelay.Q THEN
					tonPlaceSensorDelay.IN:=FALSE;
					uiPlaceBothStep:=80;
				END_IF
				
			80://Stop conveyor
				WorkingConveyor.M_MotorStop(); 
				bWorkingConveyorMoveForward:= FALSE;
				bWorkingConveyorMoveBackward :=FALSE; 
//				IF WorkingConveyor.InStopped THEN
//					uiPlaceBothStep:=90;
//				END_IF
				uiPlaceBothStep:=90;
			90:		
				WorkingConveyor.M_MotorStop(); 
				bWorkingConveyorMoveForward:= FALSE;
				bWorkingConveyorMoveBackward :=FALSE; 
//				IF	WorkingConveyor.InStopped THEN
               		 IF info.ClampB_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor THEN
                 	   IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN						
                    	    SlideClear_2nd := FALSE;
                   		 ELSE                        
							SlideClear_2nd := TRUE;							
                   		 END_IF
					
               		 ELSIF info.ClampB_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.SameSizeConveyor THEN
                 	   IF Input.bSameSizeCV_BoxNearStorageSensor THEN
                 	       SlideClear_2nd := FALSE;
                 		ELSE
							SlideClear_2nd := TRUE;
							
                  		END_IF
               			 END_IF
				//END_IF
				
				IF SlideClear_2nd THEN
                	uiPlaceBothStep := 99;
					tonPlaceSensorDelay.IN :=FALSE;
				END_IF
				IF Robot._DI1.Error THEN
					uiResumeStep := 81000;
					uiResumePlaceBothStep := 60;
					SlideClear_2nd		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 81000:',Robot.ErrMsg);
				END_IF

            99:
				IF Robot._DI1.Error THEN
					uiResumeStep := 81000;
					uiResumePlaceBothStep := 60;
					SlideClear_2nd		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 81000:',Robot.ErrMsg);
				END_IF
        // wait reset
        END_CASE
		bTimeOutIN :=TRUE;	
        IF NOT Robot._DI1.Done THEN
            Robot.M_StartMoveBoxToFeedInConveyor_ClampBoth(ClampA_Address := info.ClampA_Setting.PlaceArea,
                                                           ClampB_Address := info.ClampB_Setting.PlaceArea,
                                                           SlideClear_1st := SlideClear_1st,
                                                           SlideClear_2nd := SlideClear_2nd);
        ELSIF THIS^.M_BothClampReleasedBox() THEN
			bTimeOutIN:=FALSE;
            uiExecutingStep := 81100; // place done, reset robot command
        ELSE
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;
			uiResumeStep:=81000;
			strStatus := 'FB_FeedInEmptyBoxWithRobot_V4 Step 81000: both clamp release validation failed after done';
        END_IF
			
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;	
			uiResumeStep:=81000;		
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
				InnerMessage := GVL_ErrorCode.GC_MSG_0097);
			Status := strStatus;
			Error := TRUE;
		END_IF
		IF Robot._DI1.Error THEN
			bTimeOutIN  := FALSE;
			_Abort 		:= TRUE;
			uiResumeStep:= 81000;
			strStatus	:= concat('FB_FeedInEmptyBoxWithRobot_V4 Step 81000:',Robot.ErrMsg);
			//strStatus	:= 'Test ErrMsg';
		END_IF
    81100: // Both clamp place done, reset robot command
        bTimeOutIN := TRUE;
        IF Robot.M_ResetAllCommand() THEN
            bTimeOutIN := FALSE;
            uiExecutingStep := 90000;
        END_IF
        IF tonTimeOut.Q THEN
            bTimeOutIN := FALSE;
            _Abort := TRUE;
            uiResumeStep := 81100;
            strStatus := M_FormatManagedStatus(
                AlarmId := GVL_ErrorCode.GC_ALARM_STO_FEEDIN_EMPTY,
                InnerMessage := GVL_ErrorCode.GC_MSG_0097);
            Status := strStatus;
            Error := TRUE;
        END_IF
        IF Robot._DI1.Error THEN
            bTimeOutIN := FALSE;
            _Abort := TRUE;
            uiResumeStep := 81100;
            strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V4 Step 81100: ', Robot.ErrMsg);
        END_IF
	
	90000: // Move conveyor forward a bit
		bWorkingConveyorMoveForward:=TRUE;
		IF WorkingConveyor.InForWard THEN
			uiExecutingStep := 91000;
		END_IF
	
	91000:// DELAY
		tonPlaceSensorDelay.PT:=T#0.8S;
		tonPlaceSensorDelay.IN :=TRUE;
		IF tonPlaceSensorDelay.Q THEN
			uiExecutingStep := 92000;
		END_IF
	
	92000:// STOP MOTOR
		tonPlaceSensorDelay.IN :=FALSE;
		bWorkingConveyorMoveForward:=FALSE;
		WorkingConveyor.M_MotorStop();
		IF WorkingConveyor.InStopped THEN
			uiExecutingStep := 99000;
		END_IF
			
				
    99000: // process done
        // Stop FeedIn conveyor
		tonFeedInConveyorDelay.IN :=TRUE;		//Delay FeedInConveyor stop 500MS Edit by Min
		IF tonFeedInConveyorDelay.Q THEN
			DAS_CoreSys.MachineControl.fballocatearea.M_ReleasePulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);
			DiffSizeCV.M_MotorStop();
			SameSizeCV.M_MotorStop();
			bWorkingConveyorMoveForward:=FALSE;
			tonFeedInConveyorDelay.IN :=FALSE;
			
				IF DiffSizeCV.InStopped AND SameSizeCV.InStopped THEN
				 uiExecutingStep:= 	99100 ;
				END_IF
		END_IF
	99100:
		TON_WaitRobotClear.IN := TRUE;
		IF NOT Robot._DI1.Done THEN
			_Executed := TRUE;
			Status    := 'Process completed';
		END_IF
		IF TON_WaitRobotClear.Q THEN
			_Abort 	  	 := TRUE;
			uiResumeStep := 99100;
			strStatus 	 := 'FB_FeedInEmptyBoxWithRobot_V4 Step 99100: Clear Robot Done Timeout';
		END_IF
		
		
END_CASE

IF _Executed AND NOT Robot.Halt THEN
    eState := STATE_DONE;
ELSIF NOT Execute THEN
    eState := STATE_RESETTING;
ELSIF Pause THEN
	bPauseLatched := TRUE;
	uiPauseFromStep := uiExecutingStep;
	_HoldingCompleted := FALSE;
	_HeldCompleted := FALSE;
	_UnholdCompleted := FALSE;
	uiHoldingStep := 0;
	uiHeldStep := 0;
	uiUnholdStep := 0;
	eState := STATE_Holding;
ELSIF Abort OR _Abort THEN
	eState := STATE_ABORTING;
ELSIF _Error THEN
	eState := STATE_ERROR;	
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_HELD" Id="{01b9198b-e312-46e9-97c1-7428c00b4df2}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_HELD
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := FALSE;
Paused := TRUE;
Status := 'Paused';

IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF Abort OR _Abort THEN
	eState := STATE_ABORTING;
ELSIF _Error THEN
	eState := STATE_ERROR;
ELSIF NOT Pause THEN
	_UnholdCompleted := FALSE;
	uiUnholdStep := 0;
	eState := STATE_UnHold;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_HOLDING" Id="{f0a7575f-a002-47ba-8fe1-7c0b6e1bf4d4}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_HOLDING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := TRUE;
Paused := FALSE;
Status := 'Pause holding';

bTimeOutIN := FALSE;
tonPlaceSensorDelay.IN := FALSE;
tonFeedInConveyorDelay.IN := FALSE;
bWorkingConveyorMoveForward := FALSE;
bWorkingConveyorMoveBackward := FALSE;

CASE uiHoldingStep OF
	0:
		CASE uiExecutingStep OF
			0,10,20,1000,1100:
				uiHoldingStep := 9999;

			61000,71000,81000,90000,91000,92000:
				IF __ISVALIDREF(WorkingConveyor) THEN
					WorkingConveyor.M_MotorStop();
					IF WorkingConveyor.InStopped THEN
						uiHoldingStep := 9999;
					END_IF
				ELSE
					DiffSizeCV.M_MotorStop();
					SameSizeCV.M_MotorStop();
					IF DiffSizeCV.InStopped AND SameSizeCV.InStopped THEN
						uiHoldingStep := 9999;
					END_IF
				END_IF

			99000:
				DAS_CoreSys.MachineControl.fballocatearea.M_ReleasePulloutAccess(
					ControlAccess := E_RoundBeltControlAccess.FanucRobot);
				DiffSizeCV.M_MotorStop();
				SameSizeCV.M_MotorStop();
				IF DiffSizeCV.InStopped AND SameSizeCV.InStopped THEN
					_Executed := TRUE;
					uiHoldingStep := 9999;
				END_IF

		ELSE
			DAS_CoreSys.MachineControl.fballocatearea.M_StopStoragePulloutAction();
			IF Robot.Halt OR Robot._DI1.Done OR NOT Robot._DI12.BzoneInWork THEN
				uiHoldingStep := 9999;
			END_IF
		END_CASE

	9999:
		_HoldingCompleted := TRUE;
END_CASE

IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF Abort OR _Abort THEN
	eState := STATE_ABORTING;
ELSIF _Error THEN
	eState := STATE_ERROR;
ELSIF _Executed THEN
	eState := STATE_DONE;
ELSIF _HoldingCompleted THEN
	eState := STATE_Held;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_RESETTING" Id="{c2a06403-fb9d-4902-acd2-20867d25d244}" FolderPath="State\">
      <Declaration><![CDATA[METHOD  M_STATE_RESETTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _Executed THEN Done :=TRUE ; END_IF
CASE uiResettingStep OF
	0:
		//DAS.fbStorageArea.M_InactivePulloutConveyorInternCtrl();
		Robot.M_ResetAllCommand();
		Robot.Bzone_AllowWork:=FALSE;
		DiffSizeCV.M_MotorStop();
		SameSizeCV.M_MotorStop();
		DAS_CoreSys.MachineControl.fballocatearea.M_ReleasePulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);
		DAS_CoreSys.MachineControl.fballocatearea.M_StopStoragePulloutAction();
		WareHouse.M_ResetFeedInBox();
		WareHouse.M_ResetReloadBox();
		bWorkingConveyorMoveForward  :=FALSE;
		bWorkingConveyorMoveBackward :=FALSE;
		bTimeOutIN:=FALSE;
		Paused := FALSE;
		bPauseLatched := FALSE;
		uiPauseFromStep := 0;
		AClampMoveDone	:= FALSE;
		BClampMoveDone	:= FALSE;
		_AClampDoingWork	:= FALSE;
		_BClampDoingWork	:= FALSE;
		uiResettingStep := 100;
	100:
		_ResetCompleted := TRUE;
END_CASE
IF _ResetCompleted THEN
    eState := STATE_DORMANT;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_UNHOLD" Id="{4b925979-5453-418e-8095-51162e002708}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_UNHOLD
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Paused := FALSE;
Status := '';
tonPlaceSensorDelay.IN := FALSE;
tonFeedInConveyorDelay.IN := FALSE;
_UnholdCompleted := TRUE;

IF _UnholdCompleted THEN
	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_UpdateConveyorSensor" Id="{cdd24eb9-eb6f-486d-989a-95833a23ec74}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_UpdateConveyorSensor : BOOL
VAR_INPUT
	Area : E_FeedInEmptyBox_PlaceArea;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE Area OF
	
	E_FeedInEmptyBox_PlaceArea.SameSizeConveyor :
		SelectedSensor := Input.bSameSizeCV_BoxNearStorageSensor ;
	
	E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:
		SelectedSensor := Input.bDifferentSizeCV_BoxDetect7_Sensor;
END_CASE]]></ST>
      </Implementation>
    </Method>
