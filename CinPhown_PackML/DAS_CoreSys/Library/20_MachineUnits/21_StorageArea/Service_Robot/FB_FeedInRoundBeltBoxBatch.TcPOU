<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_FeedInRoundBeltBoxBatch" Id="{b1c2d3e4-aaaa-4444-bbbb-cccccccccccc}" SpecialFunc="None">
    <Declaration><![CDATA[// ═══════════════════════════════════════════════════════════════════════════
// FB_FeedInRoundBeltBoxBatch
// 圓帶回倉 — 批次服務 FB
// ═══════════════════════════════════════════════════════════════════════════
//
// 【用途】
// 管理最多 40 筆「從圓帶取盒回倉儲 / 或放到 PullOut」流程,每筆由
// FB_FeedInRoundBeltBoxToWareHouse (HandshakeMode=TRUE) 逐筆執行。
// 每筆 flow 可獨立決定目的地: WareHouseA / WareHouseB / PullOutInner / PullOutOuter
//
// 【設計模式】
// 仿 FB_WareHouseInnerPickToRoundBeltBatch:
//   1. 收到 Execute → 迭代 FlowInfo[0..NrOfFlow-1]
//   2. 跳過無效項 (ID = -1 或 A/B 爪皆 NoWork)
//   3. 對每筆有效流程配置並啟動 fbSingleFlow,等其完成/失敗
//   4. 每筆完成後 PLC 透過 FeedBack/ReadComplete 等 C# 讀完 ActionRecords 才進下一筆
//   5. 跨迭代強制清 handshake 防 C# 遺漏
//
// 【FeedBack / ReadComplete 握手協定】
// 同 FB_WareHouseInnerPickToRoundBeltBatch:
//   PLC: 單筆完成 → FeedBack:=TRUE → 等 ReadComplete=TRUE → 清 FeedBack → 進下一筆
//   C#:  看到 FeedBack=TRUE → 讀 ActionRecords → 寫 ReadComplete=TRUE → 等 FeedBack=FALSE → 清 ReadComplete
//
// 【Resume / Pause】
// Resume: 錯誤後 C# 按 Reset → 從 uiResumeStep 繼續 (固定回 100 重新配置 fbSingleFlow)
// Pause:  僅在迭代邊界 (step 0 / 310) 生效, 不中斷單筆流程
//
// Create Date : 2026/04/14
// ═══════════════════════════════════════════════════════════════════════════

FUNCTION_BLOCK FB_FeedInRoundBeltBoxBatch EXTENDS FB_ObjectBase_V2 IMPLEMENTS IBasicElement

VAR_INPUT
	// ----- 外部資源參照 -----
	Robot			: REFERENCE TO FB_FanucRobot_Basic_V2;	// 倉儲區 Fanuc 手臂
	RoundBelt		: REFERENCE TO FB_RoundBeltService;		// 圓帶服務
	WareHouse		: REFERENCE TO FB_WareHouse;				// 倉儲 FB
	Input			: ST_InputTable;						// IO 輸入表

	// ----- 批次資料 (C# HMI ↔ PLC 介面) -----
	BatchInfo		: REFERENCE TO ST_FeedInRBBatch;

	Stop			: BOOL;									// 外部停止信號
END_VAR

VAR_OUTPUT
END_VAR

VAR
	// ----- 狀態與錯誤追蹤 -----
	strStatus			: STRING;
	tonTimeOut			: TON;				// Per-iteration 逾時 (PT=600s, step 310 推進時重置)
	_UniqueErrorCode	: STRING;
	uiResumeStep		: UDINT := 0;
	_bRetry				: BOOL;

	// ----- 批次迭代控制 -----
	iProcessingIndex	: INT := 0;
	CurrentFlow			: ST_FeedInRBFlowInfo;

	// ----- 內嵌單筆 FB -----
	fbSingleFlow		: FB_FeedInRoundBeltBoxToWareHouse;
	_bSingleFlowStarted	: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ============================================================
// 執行順序: input piping → A00 → A10 → output piping
// ============================================================

// 1. Input piping: C# → fbSingleFlow
IF __ISVALIDREF(BatchInfo) THEN
	fbSingleFlow.ReadComplete := BatchInfo.ReadComplete;
	Execute := BatchInfo.HandShake.Execute;
	Reset	:= BatchInfo.HandShake.Reset;
END_IF

// 2. Timer PT setup
A00_BasicUnits();

// 3. State machine
SUPER^.A10_StateControl();

// 4. Output piping: fbSingleFlow → C#
IF __ISVALIDREF(BatchInfo) THEN
	BatchInfo.ActionRecords := fbSingleFlow.ActionRecords;
	BatchInfo.ActionIndex := fbSingleFlow.ActionIndex;
	BatchInfo.FeedBack := fbSingleFlow.FeedBack;
	BatchInfo.HandShake.Done := Done;
	BatchInfo.HandShake.Busy := Busy;
	BatchInfo.HandShake.Error := Error;
END_IF
]]></ST>
    </Implementation>
    <Folder Name="Method" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000001}" />
    <Folder Name="State" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000002}" />
    <Action Name="A00_BasicUnits" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000003}">
      <Implementation>
        <ST><![CDATA[// Per-iteration timeout, step 310 推進時重置
tonTimeOut(PT := T#600S);

fbSingleFlow(Input := Input);]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_FindNextValidFlow" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000010}" FolderPath="Method\">
      <Declaration><![CDATA[// 尋找下一筆有效流程
// 從 iProcessingIndex 開始往後掃描 BatchInfo.FlowInfo[]
// 有效條件: ID <> -1 且至少一爪為 Work
// 無效流程自動跳過並記錄 WorkedID
// 回傳 TRUE = 找到有效流程 (iProcessingIndex 已更新), FALSE = 全部完成
METHOD M_FindNextValidFlow : BOOL
VAR_INPUT
END_VAR
VAR
	i		: INT;
	bValid	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT __ISVALIDREF(BatchInfo) THEN
	M_FindNextValidFlow := FALSE;
	RETURN;
END_IF

IF BatchInfo.NrOfFlow = 0 THEN
	M_FindNextValidFlow := FALSE;
	RETURN;
END_IF

FOR i := iProcessingIndex TO UINT_TO_INT(BatchInfo.NrOfFlow) - 1 BY 1 DO
	bValid := FALSE;

	IF BatchInfo.FlowInfo[i].ID <> -1 THEN
		IF BatchInfo.FlowInfo[i].ClampA_Setting.Behavior = E_ClampWork.Work
		OR BatchInfo.FlowInfo[i].ClampB_Setting.Behavior = E_ClampWork.Work THEN
			bValid := TRUE;
		END_IF
	END_IF

	IF bValid THEN
		iProcessingIndex := i;
		CurrentFlow := BatchInfo.FlowInfo[i];
		M_FindNextValidFlow := TRUE;
		RETURN;
	ELSE
		BatchInfo.WorkedID[i] := BatchInfo.FlowInfo[i].ID;
	END_IF
END_FOR

M_FindNextValidFlow := FALSE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTED" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000070}" FolderPath="State\">
      <Declaration><![CDATA[// 已中止狀態 — 等待 Reset 信號
METHOD M_STATE_ABORTED
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT _bRetry THEN
	Busy 	:= FALSE;
	Aborted := TRUE;
	Error 	:= TRUE;
	Status 	:= strStatus;
	uiAbortingStep := 0;
	_AbortCompleted := FALSE;
END_IF
// 判斷內部Serivce 已經在aborted 狀態等著才能讓 FB reset
IF fbSingleFlow.eState = STATE_Aborted THEN
	IF reset THEN
		fbSingleFlow();
		fbSingleFlow.Reset := TRUE;

		_bRetry := TRUE;
		Aborted	:= FALSE;
		Error	:= FALSE;
	END_IF
END_IF

// 狀態機切換
IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF Execute AND _bRetry THEN
	IF fbSingleFlow.eState = STATE_EXECUTING OR fbSingleFlow.eState = STATE_DONE THEN
		fbSingleFlow.Reset := FALSE;
		IF uiResumeStep > 0 THEN
			status			:= '';
			uiExecutingStep := uiResumeStep;
			eState 			:= STATE_EXECUTING;
		END_IF
	END_IF
END_IF


//IF __ISVALIDREF(BatchInfo) THEN
//	IF BatchInfo.HandShake.Reset THEN
//		IF uiResumeStep > 0 THEN
//			uiExecutingStep := uiResumeStep;
//			_bRetry := TRUE;
//		END_IF
//		eState := STATE_RESETTING;
//	END_IF
//ELSIF Reset THEN
//	IF uiResumeStep > 0 THEN
//		uiExecutingStep := uiResumeStep;
//		_bRetry := TRUE;
//	END_IF
//	eState := STATE_RESETTING;
//END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTING" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000060}" FolderPath="State\">
      <Declaration><![CDATA[// 中止狀態 — 先停止單筆 FB
METHOD M_STATE_ABORTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE uiAbortingStep OF
	0:
		_Abort := FALSE;
		_bRetry := FALSE;
		tonTimeOut.IN := FALSE;
		IF _bSingleFlowStarted THEN
			fbSingleFlow.Abort := TRUE;
			fbSingleFlow();
		END_IF
		uiAbortingStep := 100;
	
	100:
		fbSingleFlow();
		IF fbSingleFlow.Aborted OR NOT fbSingleFlow.Busy THEN
			fbSingleFlow.Abort := FALSE;
			uiAbortingStep := 9999;
		END_IF
	
	9999:
		_AbortCompleted := TRUE;
END_CASE

IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF Execute AND _AbortCompleted THEN
	eState := STATE_Aborted;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DONE" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000040}" FolderPath="State\">
      <Declaration><![CDATA[// 完成狀態 — 等待外部取消 Execute
METHOD M_STATE_DONE
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := FALSE;
Done := TRUE;

IF __ISVALIDREF(BatchInfo) THEN
	IF NOT BatchInfo.HandShake.Execute THEN
		eState := STATE_RESETTING;
	END_IF
ELSIF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DORMANT" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000020}" FolderPath="State\">
      <Declaration><![CDATA[// 休眠狀態 — 清除旗標,監聽 BatchInfo.HandShake.Execute 觸發
METHOD M_STATE_DORMANT
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy				:= FALSE;
Done				:= FALSE;
Aborted				:= FALSE;
Error				:= FALSE;
ErrorID				:= 0;
Status				:= '';
_ResetCompleted		:= FALSE;
_Error				:= FALSE;
_Executed			:= FALSE;
_Abort				:= FALSE;
uiExecutingStep		:= 0;
uiResettingStep		:= 0;
uiResumeStep		:= 0;
uiAbortingStep		:= 0;

tonTimeOut.IN		:= FALSE;
_UniqueErrorCode	:= '0';

iProcessingIndex	:= 0;
_bSingleFlowStarted	:= FALSE;

IF __ISVALIDREF(BatchInfo) THEN
	MEMSET(ADR(BatchInfo.WorkedID), 0, SIZEOF(BatchInfo.WorkedID));
END_IF

_AbortCompleted		:= FALSE;
_bRetry				:= FALSE;

IF Execute THEN
	eState := STATE_EXECUTING;
END_IF

//IF __ISVALIDREF(BatchInfo) THEN
//	IF BatchInfo.HandShake.Execute AND NOT Stop THEN
//		Execute := TRUE;
//		eState := STATE_EXECUTING;
//	END_IF
//	IF BatchInfo.HandShake.Reset THEN
//		Reset := TRUE;
//	END_IF
//END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ERROR" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000050}" FolderPath="State\">
      <Declaration><![CDATA[// 錯誤狀態 — 顯示錯誤訊息
METHOD M_STATE_ERROR
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := FALSE;
Error := TRUE;
Status := strStatus;

IF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF

//IF __ISVALIDREF(BatchInfo) THEN
//	IF NOT BatchInfo.HandShake.Execute THEN
//		eState := STATE_RESETTING;
//	END_IF
//ELSIF NOT Execute THEN
//	eState := STATE_RESETTING;
//END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_EXECUTING" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000030}" FolderPath="State\">
      <Declaration><![CDATA[// 執行主狀態 — 迭代批次中每筆有效流程
// 步序:
//   0:      M_FindNextValidFlow → 找到跳 100 / 沒找到跳 99000
//   100:    強制清 handshake + 配置 fbSingleFlow + 啟動 (HandshakeMode := TRUE)
//   200:    每 cycle 呼叫 fbSingleFlow, 等 Done 跳 300, 等 Error/Aborted abort
//   300:    寫 WorkedID + 強制清 ReadComplete + 釋放 fbSingleFlow
//   310:    等 fbSingleFlow 回 DORMANT, iProcessingIndex+1, 重置 timer 回 0
//   99000:  全部完成
METHOD M_STATE_EXECUTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := TRUE;
tonTimeOut.IN := TRUE;

// 非自動模式直接中止
IF GVL_Machine.PackTags[UnitNo.Storage].Status.UnitModeCurrent <> E_UnitMode.Auto THEN
	strStatus := 'Not in Auto mode';
	_UniqueErrorCode := 'E_NOT_AUTO_MODE';
	_Abort := TRUE;
END_IF

// Pause: 僅在迭代邊界 (step 0/310) 生效
IF __ISVALIDREF(BatchInfo) AND BatchInfo.Pause THEN
	IF uiExecutingStep = 0 OR uiExecutingStep = 310 THEN
		strStatus := 'Paused (at iteration boundary)';
	END_IF
END_IF

// Per-iteration timeout (600s, step 310 推進時重置)
IF tonTimeOut.Q THEN
	strStatus := 'Batch per-iteration timeout';
	_UniqueErrorCode := 'E_BATCH_TIMEOUT';
	uiResumeStep := 100;
	_Abort := TRUE;
END_IF

CASE uiExecutingStep OF

// ===== Step 0: 尋找下一筆有效流程 =====
0:
	IF NOT M_FindNextValidFlow() THEN
		uiExecutingStep := 99000;
	ELSE
		strStatus := CONCAT('Processing flow #', INT_TO_STRING(iProcessingIndex));
		uiExecutingStep := 100;
	END_IF

// ===== Step 100: 配置並啟動單筆 FB =====
100:
	// Safety: 強制清 handshake 確保 C# 看到本迭代 FeedBack 上升緣
	IF __ISVALIDREF(BatchInfo) THEN
		BatchInfo.FeedBack := FALSE;
		BatchInfo.ReadComplete := FALSE;
	END_IF
	fbSingleFlow.ReadComplete := FALSE;

	// 配置參照與 input
	fbSingleFlow.Robot REF= Robot;
	fbSingleFlow.RoundBelt REF= RoundBelt;
	fbSingleFlow.WareHouse REF= WareHouse;
	fbSingleFlow.Input := Input;
	fbSingleFlow.Info.ClampA_Setting := CurrentFlow.ClampA_Setting;
	fbSingleFlow.Info.ClampB_Setting := CurrentFlow.ClampB_Setting;
	fbSingleFlow.Stop := Stop;
	fbSingleFlow.HandshakeMode := TRUE;	// 啟用 ActionRecord + FeedBack/ReadComplete
	fbSingleFlow.Execute := TRUE;
	_bSingleFlowStarted := TRUE;
	uiExecutingStep := 200;

// ===== Step 200: 等待單筆 FB 完成 =====
200:
	fbSingleFlow();
	IF fbSingleFlow.Done THEN
		uiExecutingStep := 300;
	ELSIF fbSingleFlow.Error OR fbSingleFlow.Aborted THEN
		strStatus := CONCAT('Flow #', CONCAT(INT_TO_STRING(iProcessingIndex), ' failed'));
		_UniqueErrorCode := 'E_FLOW_FAILED';
		uiResumeStep := 100;	// retry 從重配置開始
		_Abort := TRUE;
	END_IF

// ===== Step 300: 記錄完成 + 釋放單筆 FB =====
300:
	IF __ISVALIDREF(BatchInfo) THEN
		BatchInfo.WorkedID[iProcessingIndex] := CurrentFlow.ID;
		BatchInfo.ReadComplete := FALSE;	// Safety: 防 C# 殘留
	END_IF
	fbSingleFlow.Execute := FALSE;
	fbSingleFlow();
	_bSingleFlowStarted := FALSE;
	uiExecutingStep := 310;

// ===== Step 310: 等 fbSingleFlow 回 DORMANT 後再推進 =====
310:
	fbSingleFlow();
	IF NOT fbSingleFlow.Busy AND NOT fbSingleFlow.Done AND NOT fbSingleFlow.Error THEN
		iProcessingIndex := iProcessingIndex + 1;
		tonTimeOut.IN := FALSE;	// per-iteration timer 重置
		uiExecutingStep := 0;
	END_IF

// ===== Step 99000: 全部完成 =====
99000:
	_Executed := TRUE;

END_CASE

// ===== 狀態切換 =====
IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF _Error THEN
	eState := STATE_ERROR;
ELSIF _Abort THEN
	eState := STATE_ABORTING;
ELSIF _Executed THEN
	eState := STATE_DONE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_RESETTING" Id="{b1c2d3e4-aaaa-4444-bbbb-000000000080}" FolderPath="State\">
      <Declaration><![CDATA[// 重置狀態 — 等待 fbSingleFlow 回 DORMANT 後決定走 retry 或正常路徑
METHOD M_STATE_RESETTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE uiResettingStep OF
	0:
		//Done := FALSE;	//done 留到dormant 關閉。
		Error := FALSE;
		Aborted := FALSE;
		tonTimeOut.IN := FALSE;
	
		fbSingleFlow();
		fbSingleFlow.Execute := FALSE;
		uiResettingStep := 50;
	
	50:
		// 等 fbSingleFlow 真的回 DORMANT, 避免 race
//		fbSingleFlow.Reset := FALSE;
//		fbSingleFlow();
//		IF NOT fbSingleFlow.Busy AND NOT fbSingleFlow.Done AND NOT fbSingleFlow.Error AND NOT fbSingleFlow.Aborted THEN
//			IF _bRetry THEN
//				_bRetry := FALSE;
//				eState := STATE_EXECUTING;
//				RETURN;
//			END_IF
//			uiResettingStep := 100;
//		END_IF
		IF fbSingleFlow.eState = STATE_DORMANT THEN
			uiResettingStep := 100;
		END_IF
	
	100:
		_ResetCompleted := TRUE;
	
END_CASE

IF _ResetCompleted THEN
	eState := STATE_DORMANT;
END_IF
]]></ST>
      </Implementation>
    </Method>
