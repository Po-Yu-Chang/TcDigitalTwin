        END_IF;
					
		IF tonTimeOut.Q THEN
			bTimeOutIN	:=FALSE;
			uiResumeStep:=35100;
			_Abort 		:=TRUE;
			strStatus 	:='FB_FeedInEmptyBoxWithRobot_V3 Step 35100: Pick Box timeout';
		END_IF
		
    36000: // ClampA pickup from PulloutConveyor, ClampB pickup from WarehouseA
		bTimeOutIN :=TRUE;
        IF NOT Robot._di1.Done THEN
        DAS_CoreSys.MachineControl.fballocatearea.M_GetPulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);

            IF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I3_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideB_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
            ELSIF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I4_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideA_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
            ELSE
                Status := 'FB_FeedInEmptyBoxWithRobot_V3 Step 36000: Not define PulloutConveyor Slide';
                _Error := TRUE;
            END_IF

            Robot.M_StartPullOutConveyorPickUpBox_ClampA(ClampA_Address := Info.ClampA_Setting.PullOutConveyorSetting,
                                                         BoxReady       := DAS_CoreSys.MachineControl.fballocatearea.fbPulloutCV.Done);
        ELSE
			bTimeOutIN:=FALSE;
			uiExecutingStep := 36080;
		END_IF
						
		IF tonTimeOut.Q THEN
			bTimeOutIN	:=FALSE;
			uiResumeStep:=36000;
			_Abort 		:=TRUE;
			strStatus 	:='FB_FeedInEmptyBoxWithRobot_V3 Step 36000: Pick Box timeout';
		END_IF
		
	36080:
		Robot.M_ResetAllCommand();
        DAS_CoreSys.MachineControl.fballocatearea.M_StopStoragePulloutAction();
		IF NOT Robot._di1.Done THEN
			uiExecutingStep := 36100; // only place clampA
		END_IF
    36100:
		bTimeOutIN :=TRUE;
        IF NOT Robot._di1.Done THEN
            ClampB_WareHouseCoordinates := info.ClampB_Setting.WareHouseSetting;
            WareHouse.M_StartReloadBox(WareHouseSelect := E_WareHouse.WareHouseA, WarehouseCoordinates := ClampB_WareHouseCoordinates);

            IF WareHouse.bReloadBox_Completed THEN
                BoxReady_2nd 	 := TRUE;
				_BClampDoingWork := TRUE;
            END_IF

            Robot.M_StartWareHousePickUpBox_ClampB(WareHouseSelect := E_WareHouse.WareHouseA,
                                                   Info            := ClampB_WareHouseCoordinates,
                                                   BoxReady_2nd    := BoxReady_2nd);
			// robot doing Clamp done
			IF _BClampDoingWork AND NOT Robot._DI1.ClampB_Open THEN
				BClampMoveDone := TRUE;
			END_IF									   
												   
        ELSE
			bTimeOutIN:=FALSE;
			uiExecutingStep := 36200;
		END_IF
						
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			uiResumeStep:=36100;
			_Abort :=TRUE;
			strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 36100: Pick Box timeout';
		END_IF
		
	36200:
		Robot.M_ResetAllCommand(); // Clear command and go to place box
		IF NOT Robot._DI1.Done THEN
			uiExecutingStep := 80000; //  place clampA and clampB
		END_IF 
    37000: // ClampA pickup from PulloutConveyor, ClampB pickup from WarehouseB
		bTimeOutIN :=TRUE;	
        IF NOT Robot._di1.Done THEN
        DAS_CoreSys.MachineControl.fballocatearea.M_GetPulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);

            IF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I3_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideB_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
            ELSIF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I4_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideA_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
            ELSE
                Status := 'FB_FeedInEmptyBoxWithRobot_V3 Step 37000: Not define PulloutConveyor Slide';
                _Error := TRUE;
            END_IF

            Robot.M_StartPullOutConveyorPickUpBox_ClampA(ClampA_Address := Info.ClampA_Setting.PullOutConveyorSetting,
                                                         BoxReady       := DAS_CoreSys.MachineControl.fballocatearea.fbPulloutCV.Done);
        ELSE
			bTimeOutIN:=FALSE;
			uiExecutingStep := 37080;
		END_IF
						
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			uiResumeStep:=37000;
			_Abort :=TRUE;
			strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 37000: Pick Box timeout';
		END_IF
		
		
	37080:
		Robot.M_ResetAllCommand();
		IF NOT Robot._di1.Done THEN
			// Clear Pullout conveyor reload command
            DAS_CoreSys.MachineControl.fballocatearea.M_StopStoragePulloutAction();
			uiExecutingStep := 37100;
		END_IF
    
	37100:
		bTimeOutIN :=TRUE;
        IF NOT Robot._di1.Done THEN
            ClampB_WareHouseCoordinates := info.ClampB_Setting.WareHouseSetting;
            WareHouse.M_StartReloadBox(WareHouseSelect := E_WareHouse.WareHouseB, WarehouseCoordinates := ClampB_WareHouseCoordinates);

            IF WareHouse.bReloadBox_Completed THEN
                BoxReady_2nd 	 := TRUE;
				_BClampDoingWork := TRUE;
            END_IF

            Robot.M_StartWareHousePickUpBox_ClampB(WareHouseSelect := E_WareHouse.WareHouseB,
                                                   Info            := ClampB_WareHouseCoordinates,
                                                   BoxReady_2nd    := BoxReady_2nd);
			// robot doing Clamp done
			IF _BClampDoingWork AND NOT Robot._DI1.ClampB_Open THEN
				BClampMoveDone := TRUE;
			END_IF											   
        ELSE
			bTimeOutIN:=FALSE;
			uiExecutingStep := 37180;
		END_IF
				
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			uiResumeStep:=37100;
			_Abort :=TRUE;
			strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 37100: Pick Box timeout';
		END_IF
	37180:
		Robot.M_ResetAllCommand(); // Clear command and go to place box
		IF NOT Robot._di1.Done THEN
			uiExecutingStep := 80000; // only place clampA
		END_IF
    38000: // ClampBoth pickup from PulloutConveyor
        DAS_CoreSys.MachineControl.fballocatearea.M_GetPulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);

        CASE uiPickUpBothStep OF
            0: // ClampA target slide move the box to front side
                IF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I3_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideB_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSIF Info.ClampA_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I4_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideA_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSE
                    Status := 'FB_FeedInEmptyBoxWithRobot_V3 Step 38000: Not define PulloutConveyor Slide';
                    _Error := TRUE;
                END_IF

                IF DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Done THEN
                    BoxReady_1st     := TRUE;
                    uiPickUpBothStep := 10;
                END_IF

            10: // wait Robot Allow continue
                IF Robot._DI1.Notification THEN
            		DAS_CoreSys.MachineControl.fballocatearea.M_StopStoragePulloutAction();

                    IF NOT DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Done THEN
                        uiPickUpBothStep := 20;
                    END_IF

                END_IF
            20: // ClampB target slide move the box to front slide
                IF Info.ClampB_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I3_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideB_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSIF Info.ClampB_Setting.PullOutConveyorSetting = E_PullOutConveyorAddress.I4_Slide THEN
                        DAS_CoreSys.MachineControl.fballocatearea
                            .M_StartStoragePulloutAction(CommandType := E_PullOutConveyorCommandType.SlideA_FeedIn_Ext,
                                                         CV_BackwardTIme := T#0S,
                                                         CV_ForwardTime := T#0S);
                ELSE
                    Status := 'FB_FeedInEmptyBoxWithRobot_V3 Step 38000: Not define PulloutConveyor Slide';
                    _Error := TRUE;
                END_IF

                IF DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Done THEN
                    BoxReady_2nd     := TRUE;
                    uiPickUpBothStep := 99;
                END_IF
            99:
        // wait reset
        END_CASE
		bTimeOutIN :=TRUE;	
        Robot.M_StartPullOutConveyorPickUpBox_ClampBoth(ClampA_Address := Info.ClampA_Setting.PullOutConveyorSetting,
                                                        ClampB_Address := Info.ClampB_Setting.PullOutConveyorSetting,
                                                        BoxReady_1     := BoxReady_1st,
                                                        BoxReady_2     := BoxReady_2nd);

        IF Robot._DI1.Done THEN
			bTimeOutIN:=FALSE;
            uiExecutingStep := 80000; // go to place step
        END_IF
		
			
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;	
			uiResumeStep:=38000;		
			strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 38000: Pick Box timeout';
		END_IF
		IF DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Error THEN
				uiResumeStep 	:= 38000;
				uiResumePickUpBothStep := uiPickUpBothStep;
				strStatus 		:= DAS_CoreSys.MachineControl.fballocatearea.fbpulloutcv.Status;
				_Abort 			:= TRUE;
			END_IF
    60000: // Only ClampA place box
        // Clear command
        WareHouse.M_ResetReloadBox();
        Robot.M_ResetAllCommand();

        // Check robot RSR1 not working
        IF NOT Robot._DI1.Done AND NOT (Robot._DI1.AbsMoveA OR Robot._DI1.AbsMoveB OR Robot._DI1.WarehouseA OR Robot._DI1.WarehouseB) THEN
            uiExecutingStep := 61000;
        END_IF
    61000: // Only ClampA place box Start
		bTimeOutIN :=TRUE;
		M_UpdateConveyorSensor(Info.ClampA_Setting.PlaceArea);
        IF NOT Robot._DI1.Done THEN
			CASE uiPlaceSingleStep OF	
				0: // setup
				IF NOT DiffSizeCV.InBackWard AND NOT SameSizeCV.InBackWard THEN
					CASE Info.ClampA_Setting.PlaceArea OF
						E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:					
							WorkingConveyor REF= DiffSizeCV;
						E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
							WorkingConveyor REF= SameSizeCV;
					END_CASE						
				END_IF
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceSingleStep:=100;
				END_IF
				
				100://Move conveyor forward to free conveyor
					bWorkingConveyorMoveForward:=  TRUE;
					IF WorkingConveyor.InForWard THEN
						uiPlaceSingleStep:=200;
					END_IF
	
				200:// delay for a while
					
					tonPlaceSensorDelay.IN := NOT SelectedSensor;
					IF tonPlaceSensorDelay.Q THEN
						tonPlaceSensorDelay.IN:=FALSE;
						uiPlaceSingleStep:=300;
					END_IF
					
				300:// stop motor
					WorkingConveyor.M_MotorStop(); 
					bWorkingConveyorMoveForward:= FALSE;
					bWorkingConveyorMoveBackward :=FALSE; 
					IF	WorkingConveyor.InStopped THEN
						uiPlaceSingleStep:=400;
					END_IF
				400:
					WorkingConveyor.M_MotorStop(); 
					IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN
						DiffSizeSlide_Clear := FALSE;
					ELSE
						DiffSizeSlide_Clear := TRUE;
					END_IF
	
					IF Input.bSameSizeCV_BoxNearStorageSensor THEN
						SameSizeSlide_clear := FALSE;
					ELSE
						SameSizeSlide_clear := TRUE;
					END_IF
					IF Robot._DI1.Error THEN
						uiResumePlaceSingleStep := 0;
						SameSizeSlide_clear		:= FALSE;
						DiffSizeSlide_Clear		:= FALSE;
						_Abort	  := TRUE;
						strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 61000:',Robot.ErrMsg);
					END_IF
				
			
			END_CASE
			
            Robot.M_StartMoveBoxToFeedInConveyor_ClampA(ConveyorSlideSelect := Info.ClampA_Setting.PlaceArea,
                                                        DiffSizeSlideClear  := DiffSizeSlide_Clear,
                                                        SameSizeSlideClear  := SameSizeSlide_clear);
        ELSE
			bTimeOutIN:=FALSE;
			uiPlaceSingleStep:=0;
            uiExecutingStep := 99000; // Go to process end
        END_IF
				
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;		
			uiResumeStep:=61000;	
			strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 61000: Place Box timeout';
			IF Robot._DI1.Error THEN
			bTimeOutIN  := FALSE;
			_Abort		:= TRUE;
			uiResumeStep:= 61000;
			strStatus	:= CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 61000: ',robot.ErrMsg);
		END_IF
		END_IF
    70000: // Only ClampB place box
        // Clear command
        WareHouse.M_ResetReloadBox();
        Robot.M_ResetAllCommand();

        // Check robot RSR1 not working
        IF NOT Robot._DI1.Done AND NOT (Robot._DI1.AbsMoveA OR Robot._DI1.AbsMoveB OR Robot._DI1.WarehouseA OR Robot._DI1.WarehouseB) THEN
			uiPlaceSingleStep :=0;
            uiExecutingStep := 71000;
        END_IF
    71000:
	
		bTimeOutIN :=TRUE;
		M_UpdateConveyorSensor(Info.ClampB_Setting.PlaceArea);
        IF NOT Robot._DI1.Done THEN
			CASE uiPlaceSingleStep OF	
				0: // setup
				IF NOT DiffSizeCV.InBackWard AND NOT SameSizeCV.InBackWard THEN
					CASE Info.ClampB_Setting.PlaceArea OF
						E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:					
							WorkingConveyor REF= DiffSizeCV;
						E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
							WorkingConveyor REF= SameSizeCV;
					END_CASE						
				END_IF
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceSingleStep:=100;
				END_IF
				
				100://Move conveyor forward to free conveyor
					bWorkingConveyorMoveForward:=  TRUE;
					IF WorkingConveyor.InForWard THEN
						uiPlaceSingleStep:=200;
					END_IF
	
				200:// delay for a while
					
					tonPlaceSensorDelay.IN := NOT SelectedSensor;
					IF tonPlaceSensorDelay.Q THEN
						tonPlaceSensorDelay.IN:=FALSE;
						uiPlaceSingleStep:=300;
					END_IF
					
				300:// stop motor
					WorkingConveyor.M_MotorStop(); 
					bWorkingConveyorMoveForward:= FALSE;
					bWorkingConveyorMoveBackward :=FALSE; 
					tonPlaceSensorDelay.IN:=FALSE;
					IF	WorkingConveyor.InStopped THEN
						uiPlaceSingleStep:=400;
					END_IF
				400:
					WorkingConveyor.M_MotorStop(); 
					IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN
						DiffSizeSlide_Clear := FALSE;
					ELSE
						DiffSizeSlide_Clear := TRUE;
					END_IF
	
					IF Input.bSameSizeCV_BoxNearStorageSensor THEN
						SameSizeSlide_clear := FALSE;
					ELSE
						SameSizeSlide_clear := TRUE;
					END_IF
					IF Robot._DI1.Error THEN
						uiResumePlaceSingleStep := 0;
						DiffSizeSlide_Clear		:= FALSE;
						SameSizeSlide_clear		:= FALSE;						
						_Abort	  := TRUE;
						strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 71000:',Robot.ErrMsg);
					END_IF
			
			END_CASE
			
            Robot.M_StartMoveBoxToFeedInConveyor_ClampB(ConveyorSlideSelect := Info.ClampB_Setting.PlaceArea,
                                                        DiffSizeSlideClear  := DiffSizeSlide_Clear,
                                                        SameSizeSlideClear  := SameSizeSlide_clear);
        ELSE
			bTimeOutIN:=FALSE;
			uiPlaceSingleStep:=0;
            uiExecutingStep := 99000; // Go to process end
        END_IF	       
       	
		IF tonTimeOut.Q THEN
			bTimeOutIN	:= FALSE;
			_Abort 		:= TRUE;
			uiResumeStep:= 71000;
			strStatus 	:='FB_FeedInEmptyBoxWithRobot_V3 Step 71000: Place Box timeout';
		END_IF
		IF Robot._DI1.Error THEN
			bTimeOutIN	:= FALSE;
			_Abort		:= TRUE;	// typo fix: 原本寫成 FALSE,會把同 scan 內 sub-step 已設的 _Abort:=TRUE 蓋掉,造成 Fanuc 報錯時 FB 卡在 71000 不轉 ABORTING (對齊 61000 / 81000 行為)
			uiResumeStep:= 71000;
			strStatus	:= CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 71000:',robot.ErrMsg);
		END_IF
		
    80000:
			IF NOT Robot._DI1.ClampA_Open AND NOT Robot._DI1.ClampB_Open THEN
				uiExecutingStep := 80100;
			ELSE
				_Abort 	  := TRUE;
				strStatus := 'FB_FeedInEmptyBoxWithRobot_V3 Step 80000: Robot Use Both Clamp Place ,but Clamp open';
			END_IF	 
		
    80100: // Both Clamp place box
        WareHouse.M_ResetReloadBox(); // Clear Warehouse reload command
        Robot.M_ResetAllCommand(); // Clear Fanuc Robot command
		bTimeOutIN := FALSE;
        IF NOT Robot._DI1.Done THEN
            uiExecutingStep := 81000;
        END_IF;
    81000:
			
        CASE uiPlaceBothStep OF
			
            0:  //setup              
                SlideClear_1st  := FALSE;
                SlideClear_2nd  := FALSE;
			IF NOT DiffSizeCV.InBackWard AND NOT SameSizeCV.InBackWard THEN
				CASE Info.ClampA_Setting.PlaceArea OF
					E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:
						WorkingConveyor REF=DiffSizeCV;
					E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
						WorkingConveyor REF= SameSizeCV;						
				END_CASE
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceBothStep := 5;
				END_IF
			END_IF
				
			5://Move motor forward
				bWorkingConveyorMoveForward:=  TRUE;
				IF WorkingConveyor.InForWard THEN
					uiPlaceBothStep := 10;
				END_IF
				
				
            10://Delay for a while
				M_UpdateConveyorSensor(Info.ClampA_Setting.PlaceArea);
				tonPlaceSensorDelay.IN := NOT SelectedSensor AND WorkingConveyor.InForWard ;
				IF tonPlaceSensorDelay.Q THEN
					tonPlaceSensorDelay.IN:=FALSE;
					uiPlaceBothStep := 20;
				END_IF
				
				
             20://Stop movor
					WorkingConveyor.M_MotorStop(); 					
					bWorkingConveyorMoveForward:= FALSE;
					bWorkingConveyorMoveBackward :=FALSE; 
//					IF WorkingConveyor.InStopped THEN		// 放盒不需要確認軌道停，會跟出貨手臂互卡  edited Gamin 2026/04/28
//						uiPlaceBothStep := 30;
//					END_IF 
					uiPlaceBothStep := 30;

			30:	// ClampA place box
				
				WorkingConveyor.M_MotorStop(); 	
				bWorkingConveyorMoveForward:= FALSE;
				bWorkingConveyorMoveBackward :=FALSE; 
//				IF	WorkingConveyor.InStopped THEN
                	IF info.ClampA_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor THEN
                    	IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN
                        	SlideClear_1st := FALSE;
                    	ELSE
                        	SlideClear_1st := TRUE;
                    	END_IF

                	ELSIF info.ClampA_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.SameSizeConveyor THEN
                    	IF Input.bSameSizeCV_BoxNearStorageSensor THEN
                        	SlideClear_1st := FALSE;
                    	ELSE
                        	SlideClear_1st := TRUE;
                    	END_IF
                	END_IF
					IF SlideClear_1st  THEN
                		uiPlaceBothStep := 40;
					END_IF
//				ELSE
//					SlideClear_1st := FALSE;
//				END_IF
				IF Robot._DI1.Error THEN
					uiResumePlaceBothStep := 0;
					SlideClear_1st		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 81000:',Robot.ErrMsg);
				END_IF
            40: //setup for clampB				
			
				CASE Info.ClampB_Setting.PlaceArea OF
					E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:
						WorkingConveyor REF= DiffSizeCV;
					E_FeedInEmptyBox_PlaceArea.SameSizeConveyor:
						WorkingConveyor REF= SameSizeCV;
				END_CASE
				IF __ISVALIDREF(WorkingConveyor) THEN
					uiPlaceBothStep := 50;
				END_IF
				IF Robot._DI1.Error THEN
					uiResumePlaceBothStep := 0;
					SlideClear_1st		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 81000:',Robot.ErrMsg);
				END_IF
				
			50://Wait Robot finish clampA
				IF Robot._DI1.Notification THEN
					uiPlaceBothStep:=60;
				END_IF
				IF Robot._DI1.Error THEN
					uiResumePlaceBothStep := 0;
					SlideClear_1st		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 81000:',Robot.ErrMsg);
				END_IF
				
			60://Move conveyor forward
				bWorkingConveyorMoveForward:=  TRUE;
				IF WorkingConveyor.InForWard THEN
					uiPlaceBothStep:=70;
				END_IF
				
			70://Update sensor
				M_UpdateConveyorSensor(Info.ClampB_Setting.PlaceArea);
				tonPlaceSensorDelay.IN := NOT SelectedSensor AND WorkingConveyor.InForWard ;
				IF 	tonPlaceSensorDelay.Q THEN
					tonPlaceSensorDelay.IN:=FALSE;
					uiPlaceBothStep:=80;
				END_IF
				
			80://Stop conveyor
				WorkingConveyor.M_MotorStop(); 
				bWorkingConveyorMoveForward:= FALSE;
				bWorkingConveyorMoveBackward :=FALSE; 
//				IF WorkingConveyor.InStopped THEN
//					uiPlaceBothStep:=90;
//				END_IF
				uiPlaceBothStep:=90;
			90:		
				WorkingConveyor.M_MotorStop(); 
				bWorkingConveyorMoveForward:= FALSE;
				bWorkingConveyorMoveBackward :=FALSE; 
//				IF	WorkingConveyor.InStopped THEN
               		 IF info.ClampB_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor THEN
                 	   IF Input.bDifferentSizeCV_BoxDetect7_Sensor THEN						
                    	    SlideClear_2nd := FALSE;
                   		 ELSE                        
							SlideClear_2nd := TRUE;							
                   		 END_IF
					
               		 ELSIF info.ClampB_Setting.PlaceArea = E_FeedInEmptyBox_PlaceArea.SameSizeConveyor THEN
                 	   IF Input.bSameSizeCV_BoxNearStorageSensor THEN
                 	       SlideClear_2nd := FALSE;
                 		ELSE
							SlideClear_2nd := TRUE;
							
                  		END_IF
               			 END_IF
//				END_IF
				
				IF SlideClear_2nd THEN
                	uiPlaceBothStep := 99;
					tonPlaceSensorDelay.IN :=FALSE;
				END_IF
				IF Robot._DI1.Error THEN
						uiResumePlaceBothStep := 60;
						SlideClear_2nd		  := FALSE;
						_Abort	  := TRUE;
						strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 81000:',Robot.ErrMsg);
					END_IF
				
			99:
				IF Robot._DI1.Error THEN
					uiResumePlaceBothStep := 60;
					SlideClear_2nd		  := FALSE;
					_Abort	  := TRUE;
					strStatus := CONCAT('FB_FeedInEmptyBoxWithRobot_V3 Step 81000:',Robot.ErrMsg);
				END_IF
        // wait reset
        END_CASE
		bTimeOutIN :=TRUE;	
        IF NOT Robot._DI1.Done THEN
            Robot.M_StartMoveBoxToFeedInConveyor_ClampBoth(ClampA_Address := info.ClampA_Setting.PlaceArea,
                                                           ClampB_Address := info.ClampB_Setting.PlaceArea,
                                                           SlideClear_1st := SlideClear_1st,
                                                           SlideClear_2nd := SlideClear_2nd);
        ELSE
			bTimeOutIN:=FALSE;
            uiExecutingStep := 90000;
        END_IF
			
		IF tonTimeOut.Q THEN
			bTimeOutIN:=FALSE;
			_Abort :=TRUE;	
			uiResumeStep:=81000;		
			strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 81000: Place Box timeout';
		END_IF
		IF Robot._DI1.Error THEN
			bTimeOutIN  := FALSE;
			_Abort 		:= TRUE;
			uiResumeStep:= 81000;
			strStatus	:= concat('FB_FeedInEmptyBoxWithRobot_V3 Step 81000:',Robot.ErrMsg);
			//strStatus	:= 'Test ErrMsg';
		END_IF
	
	90000: // Move conveyor forward a bit
		bWorkingConveyorMoveForward:=TRUE;
		IF WorkingConveyor.InForWard THEN
			uiExecutingStep := 91000;
		END_IF
	
	91000:// DELAY
		tonPlaceSensorDelay.PT:=T#0.8S;
		tonPlaceSensorDelay.IN :=TRUE;
		IF tonPlaceSensorDelay.Q THEN
			uiExecutingStep := 92000;
		END_IF
	
	92000:// STOP MOTOR
		tonPlaceSensorDelay.IN :=FALSE;
		bWorkingConveyorMoveForward:=FALSE;
		WorkingConveyor.M_MotorStop();
		IF WorkingConveyor.InStopped THEN
			uiExecutingStep := 99000;
		END_IF
			
				
    99000: // process done
        // Stop FeedIn conveyor
		tonFeedInConveyorDelay.IN :=TRUE;		//Delay FeedInConveyor stop 500MS Edit by Min
		IF tonFeedInConveyorDelay.Q THEN
			DAS_CoreSys.MachineControl.fballocatearea.M_ReleasePulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);
			DiffSizeCV.M_MotorStop();
			SameSizeCV.M_MotorStop();
			bWorkingConveyorMoveForward:=FALSE;
			tonFeedInConveyorDelay.IN :=FALSE;
			Status    := 'FB_FeedInEmptyBoxWithRobot_V3 Step 99000: Process completed';
				IF DiffSizeCV.InStopped AND SameSizeCV.InStopped THEN
				 _Executed := TRUE;
				END_IF
		END_IF
END_CASE

IF _Executed THEN
    eState := STATE_DONE;
ELSIF NOT Execute THEN
    eState := STATE_RESETTING;
ELSIF Abort OR _Abort THEN
	//FUN_UniqueErrorCodeGenerator(iErrorID := ErrorID,UinqueErrorCode=>_UniqueErrorCode);
	eState := STATE_ABORTING;
ELSIF _Error THEN
	//FUN_UniqueErrorCodeGenerator(iErrorID := ErrorID,UinqueErrorCode=>_UniqueErrorCode);
	eState := STATE_ERROR;
	
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_RESETTING" Id="{14acce75-cc5f-4708-92ae-82c265c6f85c}" FolderPath="State\">
      <Declaration><![CDATA[METHOD  M_STATE_RESETTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _Executed THEN Done :=TRUE ; END_IF
CASE uiResettingStep OF
	0:
		//DAS.fbStorageArea.M_InactivePulloutConveyorInternCtrl();
		Robot.M_ResetAllCommand();
		Robot.Bzone_AllowWork:=FALSE;
		DiffSizeCV.M_MotorStop();
		SameSizeCV.M_MotorStop();
		 DAS_CoreSys.MachineControl.fballocatearea.M_ReleasePulloutAccess(ControlAccess := E_RoundBeltControlAccess.FanucRobot);
		 DAS_CoreSys.MachineControl.fballocatearea.M_StopStoragePulloutAction();
		WareHouse.M_ResetFeedInBox();
		WareHouse.M_ResetReloadBox();
		bWorkingConveyorMoveForward  :=FALSE;
		bWorkingConveyorMoveBackward :=FALSE;
		bTimeOutIN:=FALSE;
		AClampMoveDone	:= FALSE;
		BClampMoveDone	:= FALSE;
		_AClampDoingWork	:= FALSE;
		_BClampDoingWork	:= FALSE;
		uiResettingStep := 100;
	100:
		_ResetCompleted := TRUE;
END_CASE
IF _ResetCompleted THEN
    eState := STATE_DORMANT;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_UpdateConveyorSensor" Id="{b87c24a4-4e8a-4577-897a-2d65d4b11c19}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_UpdateConveyorSensor : BOOL
VAR_INPUT
	Area : E_FeedInEmptyBox_PlaceArea;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE Area OF
	
	E_FeedInEmptyBox_PlaceArea.SameSizeConveyor :
		SelectedSensor := Input.bSameSizeCV_BoxNearStorageSensor ;
	
	E_FeedInEmptyBox_PlaceArea.DiffSizeConveyor:
		SelectedSensor := Input.bDifferentSizeCV_BoxDetect7_Sensor;
END_CASE]]></ST>
      </Implementation>
    </Method>
