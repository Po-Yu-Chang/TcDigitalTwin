			// robot doing Clamp done
				IF _AClampDoingWork AND NOT Robot._DI1.ClampA_Open THEN
					AClampMoveDone := TRUE;
				END_IF									   
        ELSE
		  tonTimeOut.IN:=FALSE;
		  uiExecutingStep := 35100; // ClampA pickup finished, ClampB start 
		END_IF
		  tonTimeOut.IN :=TRUE;   
		IF tonTimeOut.Q THEN
		  tonTimeOut.IN:=FALSE;
		  uiResumeStep:=35000;
		  _Abort :=TRUE;
		  strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 35000: Pick Box timeout';
