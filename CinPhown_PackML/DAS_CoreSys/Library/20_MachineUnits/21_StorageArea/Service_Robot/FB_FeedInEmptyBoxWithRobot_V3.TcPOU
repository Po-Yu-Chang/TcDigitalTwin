				bTimeOutIN:=FALSE;
				uiResumeStep:= 30000;
				_Abort 		:= TRUE;
				strStatus :='FB_FeedInEmptyBoxWithRobot_V3 Step 30000: Pick Box timeout';
			END_IF
		
