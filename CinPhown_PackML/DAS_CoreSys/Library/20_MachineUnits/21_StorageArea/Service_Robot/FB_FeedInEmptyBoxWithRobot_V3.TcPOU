				BClampMoveDone := TRUE;
			END_IF
        ELSE
            IF Robot.M_ResetWareHousePickUpBox_ClampB() THEN
                // Clear command and go to place box
				bTimeOutIN:=FALSE;
                uiExecutingStep := 70000; // only place clampA
            END_IF
        END_IF
					
