			uiResumeStep:= 20000;			
			strStatus 	:= 'FB_FeedInEmptyBoxWithRobot_V3 Step 20000: Pick Box timeout';
		END_IF
    21000: // Only ClampB pickup box from WareHouseB
		bTimeOutIN :=TRUE;	
