      <Implementation>
        <ST><![CDATA[FOR i := 0 TO 9 DO
	position :=FUN_GetPositionTableData(PositionName:='W',Index:=i,Clip:=0);
RackMotorStationTable[i].Position:= position.X_Pos;
END_FOR
	M_RefreshStationPos :=TRUE;

// todo : update position of each stations
