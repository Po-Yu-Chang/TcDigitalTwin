<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_AddBoxes_v2" Id="{11e6da6f-01a9-4b4c-b8de-011d03c04171}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_AddBoxes_v2 EXTENDS FB_ObjectBase_V2
VAR_INPUT
//	UpperBoxRefillDetection		:REFERENCE TO FB_Sensor;
//	RackPusherCylinder			:REFERENCE TO FB_Cylinder;
//	RackMotor					:REFERENCE TO FB_RackMotor_V2;
//	bUpperLayerFeedInConveyor	:REFERENCE TO FB_Motor;
	Cylinder 	: REFERENCE TO UNI_CylinderList;
	Motor	 	: REFERENCE TO UNI_MotorList;
	Input 	 	: REFERENCE TO ST_InputTable;
	OutPut	 	: REFERENCE TO ST_OutputTable;
	CurrentData      : ST_SetupPara;

	ERackState	:E_RackState;
	bClearInterventionRequest : BOOL;
	_bForceUpperCV_Use		:BOOL;
END_VAR
VAR_OUTPUT
	InterventionRequest	 : BOOL;
	FeedingBoxes		:BOOL;
END_VAR
VAR
	RackMotorStationTable   : ARRAY[0..9] OF st_StationPositions;
	uiMaxRackStation :INT :=10;
//	eState :E_MethodStatus_Basic;
//	uiExecutingStep : UDINT; // This var is used to been controll STATE_EXECUTING process.
//	uiResettingStep : UDINT;
//	uiAbortingStep : UDINT;
//	_Executed :BOOL; // Executing process completed.
//	_Error : BOOL; // FB has an error.
//	_ResetCompleted : BOOL; // FB resetting completed.
//	_AbortCompleted : BOOL; // FB aborting completed.	

	tonAddBoxTimeOut	:TON;
	tonDetectSensor		:TON;
	tonConveyorTimeOut	:TON;
	tonFeedInUseAddBoxesDelay :TON;
	strStatus	:STRING;
//	_Abort		:BOOL;
	CurrStation : UINT;
	bInterventionRequest	 : BOOL;
	trigClearInterventionRequest : R_TRIG;
	_bClearInterventionRequestLast :BOOL;
	ftrigRackStateLeaveFeedBox		:F_Trig;
	_UniqueErrorCode : STRING;
	_RetryCompleted	 : BOOL; // FB Aboted STATE use

	// ===== Pause / Resume framework =====
	_bPaused					: BOOL;
	_bPauseEdge					: BOOL;

	// 計時器活動狀態保存
	bWasActive_tonAddBoxTimeOut			: BOOL;
	bWasActive_tonDetectSensor			: BOOL;
	bWasActive_tonConveyorTimeOut		: BOOL;
	bWasActive_tonFeedInUseAddBoxesDelay : BOOL;

	// 計時器剩餘時間保存
	tRemaining_tonAddBoxTimeOut			: TIME;
	tRemaining_tonDetectSensor			: TIME;
	tRemaining_tonConveyorTimeOut		: TIME;
	tRemaining_tonFeedInUseAddBoxesDelay : TIME;

	// 恢復後使用調整 PT 旗標 (Q 觸發或被外部關掉就清除)
	bUseAdjustedPT_tonAddBoxTimeOut		: BOOL;
	bUseAdjustedPT_tonDetectSensor		: BOOL;
	bUseAdjustedPT_tonConveyorTimeOut	: BOOL;
	bUseAdjustedPT_tonFeedInUseAddBoxesDelay : BOOL;

	// 馬達/輸出狀態保存
	bSaved_MoveConveyor			: BOOL;

	// 從 EXECUTING.VAR_INST 提到 FB-level (A01_PauseControl 需 access)
	bMoveConveyor				: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[A00_BasicUnits();
A01_PauseControl();

// 暫停時不執行狀態機
IF NOT _bPaused THEN
	SUPER^.A10_StateControl();
END_IF]]></ST>
    </Implementation>
    <Folder Name="Private" Id="{2ce1c8cb-b732-4dc9-877e-291d3e9b7568}" />
    <Folder Name="STATE" Id="{8f45b950-0851-424e-829e-bd5e5f7ff7e1}" />
    <Action Name="A00_BasicUnits" Id="{1ddad176-be7b-474e-9872-dfb34dcf8407}">
      <Implementation>
        <ST><![CDATA[// 計時器 PT 設定 - 恢復後使用剩餘時間,完成後切回原 PT
IF bUseAdjustedPT_tonAddBoxTimeOut THEN
	tonAddBoxTimeOut(PT := tRemaining_tonAddBoxTimeOut);
	IF tonAddBoxTimeOut.Q OR NOT tonAddBoxTimeOut.IN THEN
		bUseAdjustedPT_tonAddBoxTimeOut := FALSE;
	END_IF
ELSE
	tonAddBoxTimeOut(PT:=T#120S);
END_IF

IF bUseAdjustedPT_tonDetectSensor THEN
	tonDetectSensor(PT := tRemaining_tonDetectSensor);
	IF tonDetectSensor.Q OR NOT tonDetectSensor.IN THEN
		bUseAdjustedPT_tonDetectSensor := FALSE;
	END_IF
ELSE
	tonDetectSensor(PT:=T#1S);
END_IF

IF bUseAdjustedPT_tonConveyorTimeOut THEN
	tonConveyorTimeOut(PT := tRemaining_tonConveyorTimeOut);
	IF tonConveyorTimeOut.Q OR NOT tonConveyorTimeOut.IN THEN
		bUseAdjustedPT_tonConveyorTimeOut := FALSE;
	END_IF
ELSE
	tonConveyorTimeOut(PT:=T#5S);
END_IF

IF bUseAdjustedPT_tonFeedInUseAddBoxesDelay THEN
	tonFeedInUseAddBoxesDelay(PT := tRemaining_tonFeedInUseAddBoxesDelay);
	IF tonFeedInUseAddBoxesDelay.Q OR NOT tonFeedInUseAddBoxesDelay.IN THEN
		bUseAdjustedPT_tonFeedInUseAddBoxesDelay := FALSE;
	END_IF
ELSE
	tonFeedInUseAddBoxesDelay(PT:=T#1S);
END_IF

ErrorID := 2700;

InterventionRequest:=bInterventionRequest;
ftrigRackStateLeaveFeedBox(CLK := (eRackState = E_RackState.FeedBox));
IF ftrigRackStateLeaveFeedBox.Q THEN
	bInterventionRequest:=FALSE;
END_IF

FeedingBoxes := eRackState=E_RackState.FeedBox;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="A01_PauseControl" Id="{a01a0001-add9-0001-0001-000000000001}">
      <Implementation>
        <ST><![CDATA[// A01_PauseControl - 暫停控制邏輯
// 依 PauseResume_Implementation_Guide.md 標準框架實作
// 控制對象: tonAddBoxTimeOut/tonDetectSensor/tonConveyorTimeOut/tonFeedInUseAddBoxesDelay 4 個計時器
//          Motor.List.UpCV (DC 馬達, 透過 bMoveConveyor 控制)
//          arAxisCtrl_gb[AxisNo.RackMotor] (伺服軸)

Paused := _bPaused;

// 只在執行狀態處理暫停
IF eState <> STATE_EXECUTING THEN
	_bPaused := FALSE;
	_bPauseEdge := FALSE;
	RETURN;
END_IF

// ===== 進入暫停 (上升邊緣) =====
IF Pause AND NOT _bPauseEdge THEN
	_bPauseEdge := TRUE;

	IF NOT _bPaused THEN
		_bPaused := TRUE;

		// 保存計時器活動狀態和剩餘時間
		bWasActive_tonAddBoxTimeOut := tonAddBoxTimeOut.IN;
		tRemaining_tonAddBoxTimeOut := T#120S - tonAddBoxTimeOut.ET;

		bWasActive_tonDetectSensor := tonDetectSensor.IN;
		tRemaining_tonDetectSensor := T#1S - tonDetectSensor.ET;

		bWasActive_tonConveyorTimeOut := tonConveyorTimeOut.IN;
		tRemaining_tonConveyorTimeOut := T#5S - tonConveyorTimeOut.ET;

		bWasActive_tonFeedInUseAddBoxesDelay := tonFeedInUseAddBoxesDelay.IN;
		tRemaining_tonFeedInUseAddBoxesDelay := T#1S - tonFeedInUseAddBoxesDelay.ET;

		// 停止所有計時器 (避免暫停期間 Timeout)
		tonAddBoxTimeOut.IN := FALSE;
		tonDetectSensor.IN := FALSE;
		tonConveyorTimeOut.IN := FALSE;
		tonFeedInUseAddBoxesDelay.IN := FALSE;

		// 保存上層輸送帶狀態
		bSaved_MoveConveyor := bMoveConveyor;

		// 停止上層輸送帶 (DC 馬達)
		Motor.List.UpCV.M_MotorStop();

		// 注意:RackMotor 不主動 halt
		// (1) 本 codebase 軸 API 沒有 Admin.Stop,要 halt 必須切 _OpMode.en := ModeAH 但 resume 後要重 issue 太複雜
		// (2) 暫停期間 SUPER^.A10_StateControl 不執行,軸完成 in-flight 移動後 state machine 不會推進
		// (3) Resume 時 step 210/610 直接看到 CmdDone 立即過 step,行為等價
	END_IF
END_IF

// ===== 離開暫停 (下降邊緣) - 必須等 Start 按鈕觸發 =====
IF NOT Pause AND _bPauseEdge AND GVL_ADS.OpPannel_Status.StartBtnStatus THEN
	_bPauseEdge := FALSE;

	IF _bPaused THEN
		_bPaused := FALSE;

		// 恢復上層輸送帶: 透過 bMoveConveyor 在 EXECUTING preamble 自動 M_MoveForward
		bMoveConveyor := bSaved_MoveConveyor;

		// 軸:暫停時沒主動 halt,resume 不需要 restore (對應上方 pause 注意事項)

		// 恢復計時器 (使用剩餘時間,A00 完成後切回原 PT)
		IF bWasActive_tonAddBoxTimeOut THEN
			bUseAdjustedPT_tonAddBoxTimeOut := TRUE;
			tonAddBoxTimeOut.IN := TRUE;
		END_IF

		IF bWasActive_tonDetectSensor THEN
			bUseAdjustedPT_tonDetectSensor := TRUE;
			tonDetectSensor.IN := TRUE;
		END_IF

		IF bWasActive_tonConveyorTimeOut THEN
			bUseAdjustedPT_tonConveyorTimeOut := TRUE;
			tonConveyorTimeOut.IN := TRUE;
		END_IF

		IF bWasActive_tonFeedInUseAddBoxesDelay THEN
			bUseAdjustedPT_tonFeedInUseAddBoxesDelay := TRUE;
			tonFeedInUseAddBoxesDelay.IN := TRUE;
		END_IF
	END_IF
END_IF

// 邊緣重置
IF NOT Pause THEN
	_bPauseEdge := FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_CheckCommand" Id="{794a08ec-bc7b-4c3e-86ee-7581fc56f7b9}">
      <Declaration><![CDATA[METHOD PRIVATE M_CheckCommand : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_CheckCommand	:= true;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetCurrentStation" Id="{1d173ada-9992-4afb-ba27-8c0f7ef419b8}" FolderPath="Private\">
      <Declaration><![CDATA[METHOD PRIVATE M_GetCurrentStation : BOOL
VAR
	i : UINT;
	SetPos	 :LREAL;
END_VAR

VAR_OUTPUT
	uiCurrentStation	:UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//SetPos := THIS^.fbMotor.NcToPlc.SetPos;
SetPos := arAxisCtrl_gb[AxisNo.RackMotor].Admin.Axis.NcToPlc.SetPos;
M_RefreshStationPos();
//IF  THIS^.fbMotor.Status.Homed THEN
IF arAxisCtrl_gb[AxisNo.RackMotor].Admin.Axis.Status.Homed THEN
	FOR i:=0 TO 9 BY 1 DO 
		IF SetPos> RackMotorStationTable[i].Position-5 AND SetPos< RackMotorStationTable[i].Position+5 THEN // Range should be confirm
			uiCurrentStation :=i;
			M_GetCurrentStation :=TRUE;
			RETURN;
		END_IF
	END_FOR
	
	uiCurrentStation:=99;
	M_GetCurrentStation :=FALSE;
ELSE
	M_GetCurrentStation :=FALSE;
	uiCurrentStation:=99;
END_IF


]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_MoveToStation" Id="{1db7facf-a8d7-49ae-8466-74cc522693dc}" FolderPath="Private\">
      <Declaration><![CDATA[METHOD PRIVATE M_MoveToStation : BOOL
VAR_INPUT
	uiStation : UINT;
END_VAR
VAR
	bDone	:BOOL;
	uiTargetPosition	:LREAL ;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_RefreshStationPos();
IF uiStation>=0 AND uiStation <10 THEN
	uiTargetPosition :=RackMotorStationTable[uiStation].Position;
	
	arAxisCtrl_gb[AxisNo.RackMotor].PosMode.Acc := CurrentData.Axes.RackMotor.HalfAuto.Acceleration;
	arAxisCtrl_gb[AxisNo.RackMotor].PosMode.Dec := CurrentData.Axes.RackMotor.HalfAuto.Deceleration;
	arAxisCtrl_gb[AxisNo.RackMotor].PosMode.Jerk := CurrentData.Axes.RackMotor.HalfAuto.Jerk;
	arAxisCtrl_gb[AxisNo.RackMotor].PosMode.Velocity := CurrentData.Axes.RackMotor.HalfAuto.Velocity;
	arAxisCtrl_gb[AxisNo.RackMotor].PosMode.Position := uiTargetPosition;
	
//	THIS^.fbMotor.MoveAbs(lrPosition	:=uiTargetPosition,
//						lrVelocity 		:=GVL.MotorCore[AxisNo.RackMotor].VCC,
//						lrAcceleration	:=GVL.MotorCore[AxisNo.RackMotor].ACC,
//						lrDeceleration	:=GVL.MotorCore[AxisNo.RackMotor].DCC,
//						lrJerk			:=GVL.MotorCore[AxisNo.RackMotor].Jerk,
//						BufferMode		:=MC_BufferMode.MC_Aborting);
	//THIS^.fbMotor.GetCmdDoneStatus(bMotionCmdDone=>bDone);
ELSE
	M_MoveToStation :=FALSE;
	RETURN;
END_IF]]></ST>
      </Implementation>
    </Method>
