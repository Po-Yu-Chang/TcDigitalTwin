<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_SameSizeCV_ReverseBoxToWareHouse" Id="{e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b}" SpecialFunc="None">
    <Declaration><![CDATA[// FB_SameSizeCV_ReverseBoxToWareHouse
// 同尺寸軌道逆向送盒入倉/NG 服務
// 流程: Block3擋盒 → Press3壓住 → 軌道送到 NearStorage → 大手臂取盒 → 入倉 or NG區
// 支援: 單爪A / 單爪B / 雙爪 (2盒連續)
//
// 狀態機架構: FB_ObjectBase_V2 + IBasicElement
//   DORMANT → EXECUTING → DONE / ABORTING → ABORTED → RESETTING → DORMANT

FUNCTION_BLOCK FB_SameSizeCV_ReverseBoxToWareHouse EXTENDS FB_ObjectBase_V2 IMPLEMENTS IBasicElement

VAR_INPUT
	// ===== 盒子資訊 (由上層 FB 設定) =====
	bBoxA_Enable	: BOOL;				// A爪有盒子要處理
	bBoxA_IsOK		: BOOL;				// A爪: TRUE=OK入倉, FALSE=NG
	iBoxA_Warehouse	: INT;				// A爪: 倉 (E_WareHouse: 1=A, 2=B)
	iBoxA_Level		: INT;				// A爪: 層 (1~10)
	iBoxA_Track		: INT;				// A爪: 軌 (1~20)

	bBoxB_Enable	: BOOL;				// B爪有盒子要處理 (FALSE=單爪)
	bBoxB_IsOK		: BOOL;
	iBoxB_Warehouse	: INT;
	iBoxB_Level		: INT;
	iBoxB_Track		: INT;

	NGAreaPosition	: INT := 3;			// NG 區 InOutConveyor Position
	PickupPosition	: INT := 2;			// 同尺寸輸送帶 為2

	// ===== 硬體 REFERENCE =====
	Cylinder		: REFERENCE TO UNI_CylinderList;
	Motor			: REFERENCE TO UNI_MotorList;
	Input			: ST_InputTable;
	OutPut			: ST_OutputTable;
	StorageRobot	: REFERENCE TO FB_FanucRobot_Basic_V2;
	WareHouse		: REFERENCE TO FB_WareHouse;
	
	Stop			: BOOL;
END_VAR

VAR_OUTPUT
	bBoxA_Done			: BOOL;				// A爪盒子搬運完成 (入倉或NG放置皆算完成)
	bBoxB_Done			: BOOL;				// B爪盒子搬運完成 (入倉或NG放置皆算完成)
END_VAR

VAR
	strStatus			: STRING;
	_UniqueErrorCode	: STRING;
	_bRetry				: BOOL;

	bDualGrip			: BOOL;
	bFirstClampIsA		: BOOL;
	bBoxReady			: BOOL;
	stWareHouseCoord	: ST_WareHouseCoordinates;

	// Timers
	TON_TimeOut				: TON;
	TON_ConveyorTimeOut		: TON;
	TON_RobotResetTimeOut 	: TON;
	TON_ArrivedDelay		: TON;

	tonDelay_SameSizeGetBox 	: TON;
	tonDelay_SameSizeDelayBox 	: TON;
	TON_CVmovedelay				: TON;
	
	// Resume
	uiResumeStep		: UDINT := 0;
	
	NGRegionMove	: FB_RobotRegionMove_FeedInConveyor_V2;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SUPER^.A10_StateControl();
A00_BasicUnits();

(*============================================================
Create Date : 2026/04/13
Last Update	: 2026/04/13
Change Log  : 2026/04/13，移植泰興鏡射機版本，修正輸送帶盒子定位邏輯，每一台輸送帶的機構不同需要客製化針盒定位邏輯。 	edited by Gamin
============================================================*)]]></ST>
    </Implementation>
    <Folder Name="State" Id="{f2a3b4c5-d6e7-4f8a-9b0c-1d2e3f4a5b6c}" />
    <Action Name="A00_BasicUnits" Id="{a3b4c5d6-e7f8-4a9b-0c1d-2e3f4a5b6c7d}">
      <Implementation>
        <ST><![CDATA[TON_TimeOut(PT := T#60S);
TON_ConveyorTimeOut(PT := T#60S);
TON_RobotResetTimeOut(PT := T#30S);
TON_ArrivedDelay(PT:= T#300MS);
tonDelay_SameSizeDelayBox(PT:=T#800MS);
tonDelay_SameSizeGetBox(PT:=T#50MS);
TON_CVmovedelay(PT:= T#500mS);

NGRegionMove(
	Execute:= , 
	Abort:= , 
	Reset:= , 
	ObjectName:= , 
	Busy=> , 
	Done=> , 
	Aborted=> , 
	Error=> , 
	ErrorID=> , 
	Status=> , 
	UniqueErrorCode=> , 
	Robot:= StorageRobot, 
	LowerConveyor:= Motor.List.LowCV, 
	Input:= input, 
	Info:= , 
	Stop:= );]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_STATE_ABORTED" Id="{00000001-e3f4-4a5b-6c7d-8e9f0a1b2c3d}" FolderPath="State\">
      <Declaration><![CDATA[// 已中止 — 等待 Reset，支援 Resume
METHOD M_STATE_ABORTED
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT _bRetry THEN
	Busy 	:= FALSE;
	Aborted := TRUE;
	Error 	:= TRUE;
	Status 	:= strStatus;
	_AbortCompleted := FALSE;
	uiAbortingStep  := 0;
END_IF
// 等待上層 FB 設定 Reset
IF reset THEN
	_bRetry := TRUE;
	Busy 	:= FALSE;
	Aborted := FALSE;
	Error 	:= FALSE;
END_IF

IF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF

IF Execute AND _bRetry AND NOT StorageRobot._DI1.Error AND NOT StorageRobot.Halt THEN
	status := '';
	uiExecutingStep := uiResumeStep;
	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTING" Id="{f8000000-d2e3-4f4a-5b6c-7d8e9f0a1b2c}" FolderPath="State\">
      <Declaration><![CDATA[// 中止 — 停止手臂/馬達/氣缸，保存 Resume 步驟
METHOD M_STATE_ABORTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE uiAbortingStep OF
0:
	// 保存 Resume
	IF uiResumeStep = 0 THEN
		uiResumeStep := uiExecutingStep;
	END_IF
	_Abort	:= FALSE;
	_bRetry := FALSE;

	// 清除 Timer
	TON_TimeOut.IN := FALSE;
	TON_ConveyorTimeOut.IN := FALSE;
	TON_RobotResetTimeOut.IN := FALSE;

	// 停止手臂 + 倉儲 + NG
	//StorageRobot.M_ResetAllCommand();		續做盡量不要清除掉手臂的command 保持原狀，如要清除把Continue 拔掉即可。
	WareHouse.M_ResetFeedInBox();
	NGRegionMove.Execute := FALSE;

	// 停止馬達
	Motor.List.TransmitSameSideCV.M_MotorStop();

	uiAbortingStep := 100;

100:
	// 機構復位
//	Cylinder.List.fbSameSizeCV_Block3.M_Retract();
//	Cylinder.List.fbSameSizeCV_Press3.M_Retract();
//	IF Cylinder.List.fbSameSizeCV_Block3.InRearPosition AND
//	   Cylinder.List.fbSameSizeCV_Press3.InRearPosition AND
//	   Motor.List.TransmitSameSideCV.InStopped THEN
//		uiAbortingStep := 9999;
//	END_IF
	uiAbortingStep := 9999;
9999:
	_AbortCompleted := TRUE;
END_CASE

IF NOT Execute THEN
	estate := STATE_RESETTING;
ELSIF _AbortCompleted THEN
	eState := STATE_Aborted;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DONE" Id="{d6e7f800-b0c1-4d2e-3f4a-5b6c7d8e9f0a}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_DONE
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := FALSE;
Done := TRUE;

// 等待上層 FB 取消 Execute
IF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DORMANT" Id="{c5d6e700-f8a9-4b0c-1d2e-3f4a5b6c7d8e}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_DORMANT
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy				:= FALSE;
Done				:= FALSE;
Aborted				:= FALSE;
Error				:= FALSE;
ErrorID				:= 0;
Status				:= '';
_ResetCompleted		:= FALSE;
_Error				:= FALSE;
_Executed			:= FALSE;
_Abort				:= FALSE;
uiExecutingStep		:= 0;
uiResettingStep		:= 0;
uiAbortingStep		:= 0;

_UniqueErrorCode	:= '';
_bRetry				:= FALSE;
uiResumeStep		:= 0;

bBoxA_Done			:= FALSE;
bBoxB_Done			:= FALSE;
bBoxReady			:= FALSE;
bDualGrip			:= FALSE;
bFirstClampIsA		:= TRUE;

TON_TimeOut.IN			:= FALSE;
TON_ConveyorTimeOut.IN	:= FALSE;
TON_RobotResetTimeOut.IN := FALSE;
TON_ArrivedDelay.IN		:= FALSE;

TON_CVmovedelay.IN 			 := FALSE;
tonDelay_SameSizeDelayBox.IN := FALSE;
tonDelay_SameSizeGetBox.IN 	 := FALSE;

_AbortCompleted		:= FALSE;

// 由上層 FB 設定 Execute := TRUE 觸發
IF Execute AND NOT Stop THEN
	// 啟動前檢查
	IF NOT bBoxA_Enable AND NOT bBoxB_Enable THEN
		strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse: No box enabled';
		_UniqueErrorCode := 'E_NO_BOX';
		_Abort := TRUE;
		RETURN;
	END_IF

	// 判斷爪模式
	bDualGrip := bBoxA_Enable AND bBoxB_Enable;
	IF bBoxA_Enable THEN
		bFirstClampIsA := TRUE;
	ELSIF bBoxB_Enable THEN
		bFirstClampIsA := FALSE;
	END_IF

	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ERROR" Id="{e7f80000-c1d2-4e3f-4a5b-6c7d8e9f0a1b}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_ERROR
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := FALSE;
Error := TRUE;
Status := strStatus;

IF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_EXECUTING" Id="{c5d6e7f8-a9b0-4c1d-2e3f-4a5b6c7d8e9f}" FolderPath="State\">
      <Declaration><![CDATA[// 執行主狀態 — 軌道送盒 + 大手臂取盒 + 入倉/NG
// ═══════════════════════════════════════════════════
// Phase 1 (1000-1500): 第一盒送到 NearStorage
// Phase 2 (2000-2100): 大手臂取第一盒
// Phase 3 (3000-3400): 第二盒送到 NearStorage (雙爪)
// Phase 4 (4000-4100): 大手臂取第二盒
// Phase 5 (5000-5600): 放 ClampA (入倉 or NG)
// Phase 6 (6000-6500): 放 ClampB (入倉 or NG)
// Phase 9 (9000-9100): 復位機構
// ═══════════════════════════════════════════════════
METHOD M_STATE_EXECUTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := TRUE;

// Stop 時暫停 Timeout
IF Stop THEN
	TON_TimeOut.IN := FALSE;
	TON_ConveyorTimeOut.IN := FALSE;
END_IF

CASE uiExecutingStep OF
			
		0:	// 初始化
				bBoxReady := FALSE;
				bBoxA_Done := FALSE;
				bBoxB_Done := FALSE;
				uiExecutingStep := 1000;
		
		{region '=== Phase 1: 第一盒送到 NearStorage ==='}
		// 流程: 馬達先動 → 等盒到 Detect6 → Block3 擋 → Press3 壓 → Block3 放 → 送到 NearStorage
					
		1000:	// 啟動軌道馬達
				Motor.List.TransmitSameSideCV.M_MoveBackward();
				cylinder.List.fbSameSizeCV_Press3.M_Retract();
				cylinder.List.fbSameSizeCV_Press4.M_Retract();
				TON_ConveyorTimeOut.IN := TRUE;
				uiExecutingStep := 1100;
		
		1100:	// 等待盒子到達 BoxDetect6，延遲50ms 擋住第二盒，泰興機沒有檔盒
				tonDelay_SameSizeGetBox.IN := Input.bSameSizeCV_BoxDetect6_Sensor;
				IF tonDelay_SameSizeGetBox.Q THEN
					cylinder.List.fbSameSizeCV_Press3.M_Extend();
					uiExecutingStep :=1200;
				END_IF
		
		1200:	// 盒子觸底後，延遲800ms
				tonDelay_SameSizeGetBox.IN:=FALSE;
				tonDelay_SameSizeDelayBox.IN :=Input.bSameSizeCV_BoxNearStorageSensor;
				IF 	tonDelay_SameSizeDelayBox.Q THEN
					uiExecutingStep :=1300;
				END_IF
		
		1300:	// 壓盒壓上，檢測第二盒是否在後面，
				cylinder.List.fbSameSizeCV_Press4.M_Extend();
				IF NOT Input.bSameSizeCV_BoxDetect6_Sensor THEN
					uiExecutingStep := 1400;
				ELSE 
					// 如果有盒，壓盒收回，馬達停止
					cylinder.List.fbSameSizeCV_Press3.M_Retract();
					Motor.List.TransmitSameSideCV.M_MotorStop();
					uiExecutingStep := 1325;
				END_IF
					 
		1325:	// 正轉輸送帶將第二盒退後。
				Motor.List.TransmitSameSideCV.M_MoveForward();
				IF Motor.List.TransmitSameSideCV.InForWard THEN
					uiExecutingStep := 1350;
				END_IF
		
		1350:	//  檢測是否離開第二盒Sensor 位置，偵測到延遲 1秒確保離開
			 	TON_CVmovedelay.IN := NOT Input.bSameSizeCV_BoxDetect6_Sensor;
				IF TON_CVmovedelay.Q THEN
					cylinder.List.fbSameSizeCV_Press3.M_Extend();
					Motor.List.TransmitSameSideCV.M_MotorStop();
					uiExecutingStep := 1375;
				END_IF
				  
		1375:	
				TON_CVmovedelay.IN := FALSE;
				Motor.List.TransmitSameSideCV.M_MoveBackward();
				IF Motor.List.TransmitSameSideCV.InBackWard THEN
					uiExecutingStep := 1400;
				END_IF
		1400:
			 	TON_CVmovedelay.IN := TRUE;
				Motor.List.TransmitSameSideCV.M_MotorStop();
				IF TON_CVmovedelay.Q THEN
					cylinder.List.fbSameSizeCV_Press4.M_Retract();
					uiExecutingStep := 1500;
				END_IF
			
		1500:
			 	TON_CVmovedelay.IN 			 := FALSE;
				tonDelay_SameSizeDelayBox.IN := FALSE;
				tonDelay_SameSizeGetBox.IN 	 := FALSE;
				uiExecutingStep	   			 := 2000;

				 
		{endregion}
		
		{region '=== Phase 2: 大手臂取第一盒 ==='}
		
		2000:	// Robot AbsMove 取盒
			TON_TimeOut.IN := TRUE;
			IF NOT StorageRobot._DI1.Done THEN
				StorageRobot.M_StartRobotAbsMove(
					GetBox			:= TRUE,
					UseClampA		:= bFirstClampIsA,
					UseClampB		:= FALSE,
					Area			:= E_RobotArea.TransmitCV,
					ClampA_Address	:= PickupPosition,
					ClampB_Address	:= 99,
					BoxReady_1		:= bFirstClampIsA,
					BoxReady_2		:= FALSE);
			ELSE
				TON_TimeOut.IN := FALSE;
				uiExecutingStep := 2100;
			END_IF
			IF TON_TimeOut.Q OR StorageRobot.Error THEN
				uiResumeStep := uiExecutingStep;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 2000: Robot pick first box timeout';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		2100:	// Reset Robot
			StorageRobot.M_ResetAllCommand();
			IF NOT StorageRobot._DI1.Done THEN
				IF bDualGrip THEN
					uiExecutingStep := 3000;
				ELSE
					uiExecutingStep := 5000;
				END_IF
			END_IF
		
		{endregion}
		
		{region '=== Phase 3: 第二盒送到 NearStorage (雙爪) ==='}
		// 流程: 馬達先動 → 等盒到 Detect6 → Block3 擋 → Press3 壓 → Block3 放 → 送到 NearStorage
		
		3000:	// 啟動軌道馬達
				Cylinder.List.fbSameSizeCV_Press3.M_Retract();
				Motor.List.TransmitSameSideCV.M_MoveBackward();
  				TON_CVmovedelay.IN 			 := FALSE;
				tonDelay_SameSizeDelayBox.IN := FALSE;
				tonDelay_SameSizeGetBox.IN 	 := FALSE;
				uiExecutingStep := 3100;
		
		3100:	// Block3 extend (擋住第二盒)
				tonDelay_SameSizeGetBox.IN := Input.bSameSizeCV_BoxDetect6_Sensor;
				IF tonDelay_SameSizeGetBox.Q THEN
					cylinder.List.fbSameSizeCV_Press3.M_Extend();
					uiExecutingStep :=3200;
				END_IF
		
		3200:	// 等待第二盒到達 BoxDetect6
			 	tonDelay_SameSizeGetBox.IN:=FALSE;
				tonDelay_SameSizeDelayBox.IN :=Input.bSameSizeCV_BoxNearStorageSensor;
				IF 	tonDelay_SameSizeDelayBox.Q THEN
					uiExecutingStep :=3300;
				END_IF 
				  
		3300:	// Press3 壓住第二盒
				cylinder.List.fbSameSizeCV_Press4.M_Extend();
				IF NOT Input.bSameSizeCV_BoxDetect6_Sensor THEN
					uiExecutingStep := 3400;
				ELSE
					cylinder.List.fbSameSizeCV_Press3.M_Retract();
					Motor.List.TransmitSameSideCV.M_MotorStop();
					uiExecutingStep := 3325;
				END_IF
		
		3325:	// Block3 retract (放開)
				Motor.List.TransmitSameSideCV.M_MoveForward();
				IF Motor.List.TransmitSameSideCV.InForWard THEN
					uiExecutingStep := 3350;
				END_IF
		
		3350:	// 軌道往前送到 NearStorage + Press3 縮回
				TON_CVmovedelay.IN := NOT Input.bSameSizeCV_BoxDetect6_Sensor;
				IF TON_CVmovedelay.Q THEN
					cylinder.List.fbSameSizeCV_Press3.M_Extend();
					Motor.List.TransmitSameSideCV.M_MotorStop();
					uiExecutingStep := 3375;
				END_IF
		
		3375:	// 等待馬達停止
			 	TON_CVmovedelay.IN := FALSE;
				Motor.List.TransmitSameSideCV.M_MoveBackward();
				IF Motor.List.TransmitSameSideCV.InBackWard THEN
					uiExecutingStep := 3400;
				END_IF
				
		3400:
			 	TON_CVmovedelay.IN := TRUE;
				Motor.List.TransmitSameSideCV.M_MotorStop();
				IF TON_CVmovedelay.Q THEN
					cylinder.List.fbSameSizeCV_Press4.M_Retract();
					uiExecutingStep := 3500;
				END_IF
					 
		3500:
			 	TON_CVmovedelay.IN 			 := FALSE;
				tonDelay_SameSizeDelayBox.IN := FALSE;
				tonDelay_SameSizeGetBox.IN 	 := FALSE;
				uiExecutingStep	   			 := 4000;
					
		
		{endregion}
		
		{region '=== Phase 4: 大手臂取第二盒 ==='}
		
		4000:	// Robot AbsMove 第二爪
			TON_TimeOut.IN := TRUE;
			IF NOT StorageRobot._DI1.Done THEN
				StorageRobot.M_StartRobotAbsMove(
					GetBox			:= TRUE,
					UseClampA		:= FALSE,
					UseClampB		:= bFirstClampIsA,
					Area			:= E_RobotArea.TransmitCV,
					ClampA_Address	:= 99,
					ClampB_Address	:= PickupPosition,
					BoxReady_1		:= FALSE,
					BoxReady_2		:= bFirstClampIsA);
			ELSE
				TON_TimeOut.IN := FALSE;
				uiExecutingStep := 4100;
			END_IF
			IF TON_TimeOut.Q OR StorageRobot.Error THEN
				uiResumeStep := uiExecutingStep;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 4000: Robot pick second box timeout';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		4100:	// Reset Robot
			StorageRobot.M_ResetAllCommand();
			IF NOT StorageRobot._DI1.Done THEN
				uiExecutingStep := 5000;
			END_IF
		
		{endregion}
		
		{region '=== Phase 5: 放 ClampA ==='}
		
		5000:	// 清除 Robot 命令
			TON_RobotResetTimeOut.IN := TRUE;
			StorageRobot.M_ResetAllCommand();
			IF NOT StorageRobot._DI1.Done AND
				NOT (StorageRobot._DI1.AbsMoveA OR StorageRobot._DI1.AbsMoveB OR
					 StorageRobot._DI1.WarehouseA OR StorageRobot._DI1.WarehouseB) THEN
				TON_RobotResetTimeOut.IN := FALSE;
				bBoxReady := FALSE;
				IF bBoxA_Enable THEN
					uiExecutingStep := 5100;
				ELSE
					uiExecutingStep := 6000;
				END_IF
			END_IF
			IF TON_RobotResetTimeOut.Q THEN
				uiResumeStep := 5000;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 5000: Robot reset timeout (phase 5)';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		5100:	// ClampA: OK → 入倉, NG → NG區
			IF bBoxA_IsOK THEN
				uiExecutingStep := 5200;
			ELSE
				uiExecutingStep := 5300;
			END_IF
		
		5200:	// ClampA OK → 入倉
			TON_TimeOut.IN := TRUE;
			stWareHouseCoord.Layer := iBoxA_Level;
			stWareHouseCoord.Slide := iBoxA_Track;
			IF iBoxA_Warehouse = 1 THEN
				WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseA, WarehouseCoordinates := stWareHouseCoord);
				IF WareHouse.bFeedInBox_Completed THEN
					bBoxReady := TRUE;
				END_IF
				StorageRobot.M_StartWareHousePlaceBox_ClampA(
					WareHouseSelect := E_WareHouse.WareHouseA,
					Info := stWareHouseCoord,
					BoxReady_1st := bBoxReady);
			ELSIF iBoxA_Warehouse = 2 THEN
				WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseB, WarehouseCoordinates := stWareHouseCoord);
				IF WareHouse.bFeedInBox_Completed THEN
					bBoxReady := TRUE;
				END_IF
				StorageRobot.M_StartWareHousePlaceBox_ClampA(
					WareHouseSelect := E_WareHouse.WareHouseB,
					Info := stWareHouseCoord,
					BoxReady_1st := bBoxReady);
			ELSE
				uiResumeStep := 5200;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 5200: Invalid BoxA warehouse value';
				_UniqueErrorCode := 'E_INVALID_WAREHOUSE';
				_Abort := TRUE;
				RETURN;
			END_IF
			IF StorageRobot._DI1.Done THEN
				TON_TimeOut.IN := FALSE;
				bBoxA_Done := TRUE;
				uiExecutingStep := 5500;
			END_IF
			IF TON_TimeOut.Q OR StorageRobot.Error THEN
				uiResumeStep := 5200;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 5200: ClampA place to warehouse timeout';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		5300:	// ClampA NG → NG區
			NGRegionMove.Info.Get := FALSE;
			NGRegionMove.Info.UseA := TRUE;
			NGRegionMove.Info.UseB := FALSE;
			NGRegionMove.Info.A_Position := NGAreaPosition;
			NGRegionMove.Info.B_Position := 0;
			NGRegionMove.Execute := TRUE;
			uiExecutingStep := 5310;
		
		5310:	// 等待 NG RegionMove 完成
			IF NGRegionMove.Done THEN
				NGRegionMove.Execute := FALSE;
				bBoxA_Done := TRUE;
				uiExecutingStep := 5320;
			END_IF
			IF NGRegionMove.Error OR NGRegionMove.Aborted THEN
				NGRegionMove.Execute := FALSE;
				uiResumeStep := 5300;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 5300: ClampA NG region move failed';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		5320:	// 等待 DORMANT
			IF NOT NGRegionMove.Busy AND NOT NGRegionMove.Done THEN
				uiExecutingStep := 5600;
			END_IF
		
		5500:	// ClampA OK 完成 → Reset
			StorageRobot.M_ResetAllCommand();
			WareHouse.M_ResetFeedInBox();
			IF NOT StorageRobot._DI1.Done THEN
				uiExecutingStep := 5600;
			END_IF
		
		5600:	// 繼續 ClampB?
			IF bDualGrip THEN
				bBoxReady := FALSE;
				uiExecutingStep := 6000;
			ELSE
				uiExecutingStep := 9000;
			END_IF
		
		{endregion}
		
		{region '=== Phase 6: 放 ClampB ==='}
		
		6000:	// 準備放 ClampB
			TON_RobotResetTimeOut.IN := TRUE;
			StorageRobot.M_ResetAllCommand();
			IF NOT StorageRobot._DI1.Done AND
				NOT (StorageRobot._DI1.AbsMoveA OR StorageRobot._DI1.AbsMoveB OR
					 StorageRobot._DI1.WarehouseA OR StorageRobot._DI1.WarehouseB) THEN
				TON_RobotResetTimeOut.IN := FALSE;
				uiExecutingStep := 6100;
			END_IF
			IF TON_RobotResetTimeOut.Q THEN
				uiResumeStep := 6000;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 6000: Robot reset timeout (phase 6)';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		6100:	// ClampB: OK → 入倉, NG → NG區
			IF bBoxB_IsOK THEN
				uiExecutingStep := 6200;
			ELSE
				uiExecutingStep := 6300;
			END_IF
		
		6200:	// ClampB OK → 入倉
			TON_TimeOut.IN := TRUE;
			stWareHouseCoord.Layer := iBoxB_Level;
			stWareHouseCoord.Slide := iBoxB_Track;
			IF iBoxB_Warehouse = 1 THEN
				WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseA, WarehouseCoordinates := stWareHouseCoord);
				IF WareHouse.bFeedInBox_Completed THEN
					bBoxReady := TRUE;
				END_IF
				StorageRobot.M_StartWareHousePlaceBox_ClampB(
					WareHouseSelect := E_WareHouse.WareHouseA,
					Info := stWareHouseCoord,
					BoxReady_2nd := bBoxReady);
			ELSIF iBoxB_Warehouse = 2 THEN
				WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseB, WarehouseCoordinates := stWareHouseCoord);
				IF WareHouse.bFeedInBox_Completed THEN
					bBoxReady := TRUE;
				END_IF
				StorageRobot.M_StartWareHousePlaceBox_ClampB(
					WareHouseSelect := E_WareHouse.WareHouseB,
					Info := stWareHouseCoord,
					BoxReady_2nd := bBoxReady);
			ELSE
				uiResumeStep := 6200;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 6200: Invalid BoxB warehouse value';
				_UniqueErrorCode := 'E_INVALID_WAREHOUSE';
				_Abort := TRUE;
				RETURN;
			END_IF
			IF StorageRobot._DI1.Done THEN
				TON_TimeOut.IN := FALSE;
				bBoxB_Done := TRUE;
				uiExecutingStep := 6500;
			END_IF
			IF TON_TimeOut.Q OR StorageRobot.Error THEN
				uiResumeStep := 6200;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 6200: ClampB place to warehouse timeout';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		6300:	// ClampB NG → NG區
			NGRegionMove.Info.Get := FALSE;
			NGRegionMove.Info.UseA := FALSE;
			NGRegionMove.Info.UseB := TRUE;
			NGRegionMove.Info.A_Position := 0;
			NGRegionMove.Info.B_Position := NGAreaPosition;
			NGRegionMove.Execute := TRUE;
			uiExecutingStep := 6310;
		
		6310:	// 等待 NG 完成
			IF NGRegionMove.Done THEN
				NGRegionMove.Execute := FALSE;
				bBoxB_Done := TRUE;
				uiExecutingStep := 6320;
			END_IF
			IF NGRegionMove.Error OR NGRegionMove.Aborted THEN
				NGRegionMove.Execute := FALSE;
				uiResumeStep := 6300;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 6300: ClampB NG region move failed';
				_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		6320:	// 等待 DORMANT
			IF NOT NGRegionMove.Busy AND NOT NGRegionMove.Done THEN
				uiExecutingStep := 9000;
			END_IF
		
		6500:	// ClampB OK 完成 → Reset
			StorageRobot.M_ResetAllCommand();
			WareHouse.M_ResetFeedInBox();
			IF NOT StorageRobot._DI1.Done THEN
				uiExecutingStep := 9000;
			END_IF
		
		{endregion}
		
		{region '=== Phase 9: 復位 ==='}
		
		9000:	// 復位機構
			Motor.List.TransmitSameSideCV.M_MotorStop();
			uiExecutingStep := 9100;
		
		9100:	// 等待復位完成
			TON_TimeOut.IN := TRUE;
			IF  Motor.List.TransmitSameSideCV.InStopped THEN
				TON_TimeOut.IN := FALSE;
				_Executed := TRUE;
			END_IF
			IF TON_TimeOut.Q THEN
				uiResumeStep := uiExecutingStep;
				strStatus := 'FB_SameSizeCV_ReverseBoxToWareHouse Step 9100: Mechanism reset timeout';
				_UniqueErrorCode := 'E_CYL_TIMEOUT';
				_Abort := TRUE;
			END_IF
		
		{endregion}

END_CASE

// 狀態切換
IF _Error THEN
	eState := STATE_ERROR;
ELSIF _Abort THEN
	eState := STATE_ABORTING;
ELSIF _Executed THEN
	eState := STATE_DONE;
ELSIF NOT Execute THEN
	eState := STATE_RESETTING; 
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_RESETTING" Id="{00000002-f4a5-4b6c-7d8e-9f0a1b2c3d4e}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_RESETTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := TRUE;
Error := FALSE;
Aborted := FALSE;

CASE uiResettingStep OF
0:
	TON_TimeOut.IN := FALSE;
	TON_ConveyorTimeOut.IN := FALSE;
	TON_RobotResetTimeOut.IN := FALSE;

	TON_CVmovedelay.IN 			 := FALSE;
	tonDelay_SameSizeDelayBox.IN := FALSE;
	tonDelay_SameSizeGetBox.IN 	 := FALSE;

	StorageRobot.M_ResetAllCommand();
	WareHouse.M_ResetFeedInBox();
	NGRegionMove.Execute := FALSE;
	Motor.List.TransmitSameSideCV.M_MotorStop();

	uiResettingStep := 100;

100:
	Done := FALSE;
	Busy := FALSE;
	_ResetCompleted := TRUE;
END_CASE

IF _ResetCompleted THEN
	eState := STATE_DORMANT;
END_IF
]]></ST>
      </Implementation>
    </Method>
