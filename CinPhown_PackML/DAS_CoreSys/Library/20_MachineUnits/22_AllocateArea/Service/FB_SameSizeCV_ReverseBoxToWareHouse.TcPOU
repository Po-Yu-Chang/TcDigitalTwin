<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_SameSizeCV_ReverseBoxToWareHouse" Id="{e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b}" SpecialFunc="None">
    <Declaration><![CDATA[// FB_SameSizeCV_ReverseBoxToWareHouse
// 同尺寸軌道逆向送盒入倉/NG 服務
// 流程: 擋盒 SM (Press3 後壓 + Press4 擋第二盒, ref AllocatedConveyor) → 軌道送到 NearStorage → 大手臂取盒 → 入倉 or NG區
// 支援: 單爪A / 單爪B / 雙爪 (2盒連續)
//
// 狀態機架構: FB_ObjectBase_V2 + IBasicElement
//   DORMANT → EXECUTING → DONE / ABORTING → ABORTED → RESETTING → DORMANT

FUNCTION_BLOCK FB_SameSizeCV_ReverseBoxToWareHouse EXTENDS FB_ObjectBase_V2 IMPLEMENTS IBasicElement

VAR_INPUT
	// ===== 盒子資訊 (由上層 FB 設定) =====
	bBoxA_Enable		: BOOL;						// A爪有盒子要處理
	eBoxA_Destination	: E_ReverseBoxDestination;	// A爪目的地: WareHouse / PullOut / NGConveyor
	iBoxA_Warehouse		: INT;						// (僅 Destination=WareHouse) 倉 (E_WareHouse: 1=A, 2=B)
	iBoxA_Level			: INT;						// (僅 Destination=WareHouse) 層 (1~10)
	iBoxA_Track			: INT;						// (僅 Destination=WareHouse) 軌 (1~20)
	iBoxA_PullOutSide	: INT;						// (僅 Destination=PullOut) 1=I3_Slide 左 / 2=I4_Slide 右

	bBoxB_Enable		: BOOL;						// B爪有盒子要處理 (FALSE=單爪)
	eBoxB_Destination	: E_ReverseBoxDestination;
	iBoxB_Warehouse		: INT;
	iBoxB_Level			: INT;
	iBoxB_Track			: INT;
	iBoxB_PullOutSide	: INT;						// 1=I3_Slide 左 / 2=I4_Slide 右

	NGAreaPosition		: INT := 3;					// NG 區 InOutConveyor Position
	PickupPosition		: INT := 2;					// 同尺寸輸送帶 為 2

	// ===== 硬體 REFERENCE =====
	Cylinder			: REFERENCE TO UNI_CylinderList;
	Motor				: REFERENCE TO UNI_MotorList;
	SameSizeCVRequest	: REFERENCE TO ST_SameSizeCVRequest;	// Phase 2 仲裁:本 FB 寫 bWareHouse_NeedBackward / bWareHouse_HoldStill
	Input				: ST_InputTable;
	OutPut				: ST_OutputTable;
	StorageRobot		: REFERENCE TO FB_FanucRobot_Basic_V2;
	WareHouse			: REFERENCE TO FB_WareHouse;
	PullOutConveyor		: REFERENCE TO FB_PullOutConveyorAction;	// PullOut 目的地需要

	Stop				: BOOL;
END_VAR

VAR_OUTPUT
	bBoxA_Done			: BOOL;				// A爪搬運完成 (入倉/PullOut/NG 三路皆算完成)
	bBoxB_Done			: BOOL;				// B爪搬運完成
END_VAR

VAR
	strStatus			: STRING;
	_UniqueErrorCode	: STRING;
	_bRetry				: BOOL;

	bDualGrip			: BOOL;
	bFirstClampIsA		: BOOL;
	bBoxReady			: BOOL;
	stWareHouseCoord	: ST_WareHouseCoordinates;

	// Timers
	TON_TimeOut			: TON;
	TON_ConveyorTimeOut	: TON;
	TON_RobotResetTimeOut : TON;
	TON_ArrivedDelay	: TON;
	tonDelay_SameSizeGetBox		: TON;	// 擋盒 SM:Detect6 50ms debounce (ref FB_RobotRegionMove_AllocatedConveyor)
	tonDelay_SameSizeDelayBox	: TON;	// 擋盒 SM:NearStorageSensor 1.5s 穩定確認

	// 擋盒 sub state (Phase 1/3 step 1100/3100 共用) — ref AllocatedConveyor uiSameGetBoxStep 0/100/200/300/400 pattern
	uiSameGetBoxStep	: UINT;

	// Resume
	uiResumeStep		: UDINT := 0;

	// Region move helpers
	NGRegionMove		: FB_RobotRegionMove_FeedInConveyor_V2;		// NG 目的地用 (InOutConveyor Pos 3)
	PullOutRegionMove	: FB_RobotRegionMove_PullOutConveyor;		// PullOut 目的地用 (新加)

	// STATE_ERROR retry framework (對齊 FB_ShippingRobotTransfer)
	trigErrorReset		: R_TRIG;
	tonErrorResetDelay	: TON;
	bErrorBlinking		: BOOL;

	// Phase 2:本 FB 有兩個 instance (Direct 在 FB_AllocateAreaWithRoundbelt + Orchestrator 在 FB_SameSizeCV_ReverseBatchPickAndPhoto)
	// shared SameSizeCVRequest flag 不能被 idle instance stomp。Step 寫 local intent,A00 + Busy gate 才 propagate。
	bIntent_NeedBackward	: BOOL;
	bIntent_HoldStill		: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SUPER^.A10_StateControl();
A00_BasicUnits();
]]></ST>
    </Implementation>
    <Folder Name="State" Id="{f2a3b4c5-d6e7-4f8a-9b0c-1d2e3f4a5b6c}" />
    <Action Name="A00_BasicUnits" Id="{a3b4c5d6-e7f8-4a9b-0c1d-2e3f4a5b6c7d}">
      <Implementation>
        <ST><![CDATA[TON_TimeOut(PT := T#60S);
TON_ConveyorTimeOut(PT := T#60S);
TON_RobotResetTimeOut(PT := T#30S);
TON_ArrivedDelay(PT:= T#300MS);
tonDelay_SameSizeGetBox(PT := T#50MS);
tonDelay_SameSizeDelayBox(PT := T#1500MS);

// Phase 2:Busy 期間才 propagate local intent 到 shared request flag,避免 idle instance stomp 別人的請求
IF Busy AND __ISVALIDREF(SameSizeCVRequest) THEN
	SameSizeCVRequest.bWareHouse_NeedBackward := bIntent_NeedBackward;
	SameSizeCVRequest.bWareHouse_HoldStill    := bIntent_HoldStill;
END_IF

NGRegionMove(
	Execute:= ,
	Abort:= ,
	Reset:= ,
	ObjectName:= ,
	Busy=> ,
	Done=> ,
	Aborted=> ,
	Error=> ,
	ErrorID=> ,
	Status=> ,
	UniqueErrorCode=> ,
	Robot:= StorageRobot,
	LowerConveyor:= Motor.List.LowCV,
	Input:= input,
	Info:= ,
	Stop:= );

PullOutRegionMove(
	Robot:= StorageRobot,
	PullOutConveyor:= PullOutConveyor,
	Stop:= Stop);]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_STATE_ABORTED" Id="{00000001-e3f4-4a5b-6c7d-8e9f0a1b2c3d}" FolderPath="State\">
      <Declaration><![CDATA[// 已中止 — 等待 Reset，支援 Resume
METHOD M_STATE_ABORTED
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT _bRetry THEN
	Busy 	:= FALSE;
	Aborted := TRUE;
	Error 	:= TRUE;
	Status 	:= strStatus;
	_AbortCompleted := FALSE;
	uiAbortingStep  := 0;
END_IF
// 等待上層 FB 設定 Reset
IF reset THEN
	_bRetry := TRUE;
	Busy 	:= FALSE;
	Aborted := FALSE;
	Error 	:= FALSE;
END_IF

IF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF

IF Execute AND _bRetry AND NOT StorageRobot._DI1.Error AND NOT StorageRobot.Halt THEN
	status := '';
	uiExecutingStep := uiResumeStep;
	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTING" Id="{f8000000-d2e3-4f4a-5b6c-7d8e9f0a1b2c}" FolderPath="State\">
      <Declaration><![CDATA[// 中止 — 停止手臂/馬達/氣缸，保存 Resume 步驟
METHOD M_STATE_ABORTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE uiAbortingStep OF
0:
	// 保存 Resume
	IF uiResumeStep = 0 THEN
		uiResumeStep := uiExecutingStep;
	END_IF
	_Abort	:= FALSE;
	_bRetry := FALSE;

	// 清除 Timer
	TON_TimeOut.IN := FALSE;
	TON_ConveyorTimeOut.IN := FALSE;
	TON_RobotResetTimeOut.IN := FALSE;
	tonDelay_SameSizeGetBox.IN := FALSE;
	tonDelay_SameSizeDelayBox.IN := FALSE;
	uiSameGetBoxStep := 0;

	// 停止手臂 + 倉儲 + NG + PullOut
	//StorageRobot.M_ResetAllCommand();		續做盡量不要清除掉手臂的command 保持原狀，如要清除把Continue 拔掉即可。
	WareHouse.M_ResetFeedInBox();
	NGRegionMove.Execute := FALSE;
	PullOutRegionMove.Execute := FALSE;

	// Phase 2:清 local intent (A00 在 Busy 時 propagate FALSE,本 instance 收手不影響別人)
	bIntent_NeedBackward := FALSE;
	bIntent_HoldStill    := FALSE;

	uiAbortingStep := 100;

100:
	// 機構復位
	uiAbortingStep := 9999;
9999:
	_AbortCompleted := TRUE;
END_CASE

IF NOT Execute THEN
	estate := STATE_RESETTING;
ELSIF _AbortCompleted THEN
	eState := STATE_Aborted;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DONE" Id="{d6e7f800-b0c1-4d2e-3f4a-5b6c7d8e9f0a}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_DONE
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := FALSE;
Done := TRUE;

// 等待上層 FB 取消 Execute
IF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DORMANT" Id="{c5d6e700-f8a9-4b0c-1d2e-3f4a5b6c7d8e}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_DORMANT
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy				:= FALSE;
Done				:= FALSE;
Aborted				:= FALSE;
Error				:= FALSE;
ErrorID				:= 0;
Status				:= '';
_ResetCompleted		:= FALSE;
_Error				:= FALSE;
_Executed			:= FALSE;
_Abort				:= FALSE;
uiExecutingStep		:= 0;
uiResettingStep		:= 0;
uiAbortingStep		:= 0;

_UniqueErrorCode	:= '';
_bRetry				:= FALSE;
uiResumeStep		:= 0;

bBoxA_Done			:= FALSE;
bBoxB_Done			:= FALSE;
bBoxReady			:= FALSE;
bDualGrip			:= FALSE;
bFirstClampIsA		:= TRUE;

TON_TimeOut.IN			:= FALSE;
TON_ConveyorTimeOut.IN	:= FALSE;
TON_RobotResetTimeOut.IN := FALSE;
TON_ArrivedDelay.IN		:= FALSE;
tonDelay_SameSizeGetBox.IN	:= FALSE;
tonDelay_SameSizeDelayBox.IN := FALSE;
uiSameGetBoxStep		:= 0;
tonErrorResetDelay.IN	:= FALSE;
bErrorBlinking			:= FALSE;

PullOutRegionMove.Execute := FALSE;
NGRegionMove.Execute      := FALSE;

// Phase 2:DORMANT 只清 local intent,不動 shared SameSizeCVRequest flag (本 FB 有兩個 instance,idle 不能 stomp 其他 instance 的 request)
bIntent_NeedBackward := FALSE;
bIntent_HoldStill    := FALSE;

_AbortCompleted		:= FALSE;

// 由上層 FB 設定 Execute := TRUE 觸發
IF Execute AND NOT Stop THEN
	// 啟動前檢查
	IF NOT bBoxA_Enable AND NOT bBoxB_Enable THEN
		strStatus := 'No box enabled';
		_UniqueErrorCode := 'E_NO_BOX';
		_Abort := TRUE;
		RETURN;
	END_IF

	// 判斷爪模式
	bDualGrip := bBoxA_Enable AND bBoxB_Enable;
	IF bBoxA_Enable THEN
		bFirstClampIsA := TRUE;
	ELSIF bBoxB_Enable THEN
		bFirstClampIsA := FALSE;
	END_IF

	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ERROR" Id="{e7f80000-c1d2-4e3f-4a5b-6c7d8e9f0a1b}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_ERROR
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := FALSE;
Error := TRUE;
Status := strStatus;

// Reset 上升緣 → 1 秒閃爍 (對齊 FB_ShippingRobotTransfer)
trigErrorReset(CLK := Reset);
IF trigErrorReset.Q THEN
	bErrorBlinking := TRUE;
END_IF
tonErrorResetDelay(IN := bErrorBlinking, PT := T#1S);
IF tonErrorResetDelay.Q THEN
	bErrorBlinking := FALSE;
END_IF
IF bErrorBlinking THEN
	Error := FALSE;
END_IF

IF NOT Execute THEN
	Error := FALSE;
	bErrorBlinking := FALSE;
	tonErrorResetDelay.IN := FALSE;
	eState := STATE_RESETTING;
ELSIF trigErrorReset.Q AND Execute AND NOT StorageRobot._DI1.Error THEN
	// Retry 對稱:Reset 上升緣 (edge) 才觸發,從 uiResumeStep 續做
	uiExecutingStep := uiResumeStep;
	Status := '';
	Error := FALSE;
	bErrorBlinking := FALSE;
	tonErrorResetDelay.IN := FALSE;
	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_EXECUTING" Id="{c5d6e7f8-a9b0-4c1d-2e3f-4a5b6c7d8e9f}" FolderPath="State\">
      <Declaration><![CDATA[// 執行主狀態 — 軌道送盒 + 大手臂取盒 + 入倉/NG
// ═══════════════════════════════════════════════════
// Phase 1 (1000-1500): 第一盒送到 NearStorage
// Phase 2 (2000-2100): 大手臂取第一盒
// Phase 3 (3000-3400): 第二盒送到 NearStorage (雙爪)
// Phase 4 (4000-4100): 大手臂取第二盒
// Phase 5 (5000-5600): 放 ClampA (入倉 or NG)
// Phase 6 (6000-6500): 放 ClampB (入倉 or NG)
// Phase 9 (9000-9100): 復位機構
// ═══════════════════════════════════════════════════
METHOD M_STATE_EXECUTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := TRUE;

// Stop 時暫停 Timeout
IF Stop THEN
	TON_TimeOut.IN := FALSE;
	TON_ConveyorTimeOut.IN := FALSE;
END_IF

CASE uiExecutingStep OF

0:	// 初始化
	bBoxReady := FALSE;
	bBoxA_Done := FALSE;
	bBoxB_Done := FALSE;
	uiExecutingStep := 1000;

{region '=== Phase 1: 第一盒送到 NearStorage ==='}
// 流程: 馬達 backward + 擋盒 state machine (Press3 後壓 + Press4 擋第二盒) → 送到 NearStorage → motor 停
// 擋盒邏輯 ref FB_RobotRegionMove_AllocatedConveyor uiSameGetBoxStep 0/100/200/300/400 (省略 325/350/375 卡盒重推,Reverse 流程 motor 不能 forward)

1000:	// 請求軌道 backward + 初始化擋盒 state machine
	bIntent_NeedBackward := TRUE;
	bIntent_HoldStill    := FALSE;
	Cylinder.List.fbSameSizeCV_Press3.M_Retract();
	Cylinder.List.fbSameSizeCV_Press4.M_Retract();
	uiSameGetBoxStep := 0;
	TON_ConveyorTimeOut.IN := TRUE;
	uiExecutingStep := 1100;

1100:	// 擋盒 state machine
	CASE uiSameGetBoxStep OF
		0:	// 初始位置:兩支 retract
			Cylinder.List.fbSameSizeCV_Press3.M_Retract();
			Cylinder.List.fbSameSizeCV_Press4.M_Retract();
			uiSameGetBoxStep := 100;

		100:	// 等盒到 Detect6 (50ms debounce) → Press3 extend 後壓
			tonDelay_SameSizeGetBox.IN := Input.bSameSizeCV_BoxDetect6_Sensor;
			IF tonDelay_SameSizeGetBox.Q THEN
				Cylinder.List.fbSameSizeCV_Press3.M_Extend();
				uiSameGetBoxStep := 200;
			END_IF

		200:	// 等 NearStorageSensor 穩定 1.5s 確認盒到位
			tonDelay_SameSizeGetBox.IN := FALSE;
			tonDelay_SameSizeDelayBox.IN := Input.bSameSizeCV_BoxNearStorageSensor;
			IF tonDelay_SameSizeDelayBox.Q THEN
				uiSameGetBoxStep := 300;
			END_IF

		300:	// Press4 extend 擋第二盒避免擠進來
			Cylinder.List.fbSameSizeCV_Press4.M_Extend();
			IF Cylinder.List.fbSameSizeCV_Press4.InFrontPosition THEN
				uiSameGetBoxStep := 400;
			END_IF

		400:	// state machine 完成 → 進 1500 motor 停 + final settle
			tonDelay_SameSizeDelayBox.IN := FALSE;
			uiSameGetBoxStep := 0;
			TON_ConveyorTimeOut.IN := FALSE;
			uiExecutingStep := 1500;
	END_CASE
	// state machine 整段 60s timeout 保護
	IF TON_ConveyorTimeOut.Q THEN
		TON_ConveyorTimeOut.IN := FALSE;
		uiResumeStep := 1000;
		strStatus := 'Phase 1 擋盒 state machine timeout';
		_UniqueErrorCode := 'E_BLOCK_TIMEOUT';
		_Abort := TRUE;
	END_IF

1500:	// 軌道 backward 推到 NearStorage final settle (Press3 後壓中, Press4 擋第二盒中)
	TON_ConveyorTimeOut.IN := TRUE;
	TON_ArrivedDelay.IN := Input.bSameSizeCV_BoxNearStorageSensor;
	IF TON_ArrivedDelay.Q THEN
		TON_ConveyorTimeOut.IN := FALSE;
		bIntent_NeedBackward := FALSE;
		bIntent_HoldStill    := TRUE;	// 大手臂取盒前要靜止
		uiExecutingStep := 1600;
	END_IF
	IF TON_ConveyorTimeOut.Q THEN
		bIntent_NeedBackward := FALSE;
		uiResumeStep := 1000;	// retry 從馬達啟動重來
		strStatus := 'Box cross conveyor timeout';
		_UniqueErrorCode := 'E_BOX_CROSS_TIMEOUT';
		_Abort := TRUE;
	END_IF

1600:	// 等待馬達停止
	 TON_ArrivedDelay.IN := FALSE;
	IF Motor.List.TransmitSameSideCV.InStopped THEN
		//uiExecutingStep := 1650;
		uiExecutingStep := 2000;
	END_IF
1650:	// dead code (1600 直接跳 2000),保留以維持原邏輯 — Destination=WareHouse 視同舊 IsOK=TRUE
	 IF eBoxA_Destination = E_ReverseBoxDestination.WareHouse THEN
	  	uiExecutingStep := 2000;
	 ELSE
		uiExecutingStep := 1700;
  	 END_IF
	 
1700:
	TON_TimeOut.IN := TRUE;
	Cylinder.List.fbSameSizeCV_Press4.M_Extend();
	IF Cylinder.List.fbSameSizeCV_Press4.InFrontPosition THEN
		TON_TimeOut.IN := FALSE;
		uiExecutingStep := 1800;
	END_IF
	IF TON_TimeOut.Q THEN
		uiResumeStep := uiExecutingStep;
		strStatus := 'Press4 Extend timeout';
		_UniqueErrorCode := 'E_CYL_TIMEOUT';
		_Abort := TRUE;
	END_IF
1800:
	Cylinder.List.fbSameSizeCV_Press4.M_Retract();
	IF Cylinder.List.fbSameSizeCV_Press4.InRearPosition THEN				
		uiExecutingStep := 2000;
	END_IF
		 
{endregion}

{region '=== Phase 2: 大手臂取第一盒 ==='}

2000:	// Robot AbsMove 取盒
	TON_TimeOut.IN := TRUE;
	IF NOT StorageRobot._DI1.Done THEN
		StorageRobot.M_StartRobotAbsMove(
			GetBox			:= TRUE,
			UseClampA		:= bFirstClampIsA,
			UseClampB		:= FALSE,
			Area			:= E_RobotArea.TransmitCV,
			ClampA_Address	:= PickupPosition,
			ClampB_Address	:= 99,
			BoxReady_1		:= bFirstClampIsA,
			BoxReady_2		:= FALSE);
	ELSE
		TON_TimeOut.IN := FALSE;
		uiExecutingStep := 2100;
	END_IF
	IF TON_TimeOut.Q OR StorageRobot.Error THEN
		uiResumeStep := uiExecutingStep;
		strStatus := 'Robot pick first box timeout';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

2100:	// Reset Robot
	StorageRobot.M_ResetAllCommand();
	IF NOT StorageRobot._DI1.Done THEN
		IF bDualGrip THEN
			uiExecutingStep := 3000;
		ELSE
			uiExecutingStep := 5000;
		END_IF
	END_IF

{endregion}

{region '=== Phase 3: 第二盒送到 NearStorage (雙爪) ==='}
// 流程同 Phase 1:馬達 backward + 擋盒 state machine → 送到 NearStorage → motor 停

3000:	// 請求軌道 backward + 初始化擋盒 state machine (第二盒)
	bIntent_NeedBackward := TRUE;
	bIntent_HoldStill    := FALSE;
	Cylinder.List.fbSameSizeCV_Press3.M_Retract();
	Cylinder.List.fbSameSizeCV_Press4.M_Retract();
	uiSameGetBoxStep := 0;
	TON_ConveyorTimeOut.IN := TRUE;
	uiExecutingStep := 3100;

3100:	// 擋盒 state machine (第二盒) — ref AllocatedConveyor (與 Phase 1 step 1100 對稱)
	CASE uiSameGetBoxStep OF
		0:
			Cylinder.List.fbSameSizeCV_Press3.M_Retract();
			Cylinder.List.fbSameSizeCV_Press4.M_Retract();
			uiSameGetBoxStep := 100;

		100:	// 等盒到 Detect6 (50ms debounce) → Press3 extend
			tonDelay_SameSizeGetBox.IN := Input.bSameSizeCV_BoxDetect6_Sensor;
			IF tonDelay_SameSizeGetBox.Q THEN
				Cylinder.List.fbSameSizeCV_Press3.M_Extend();
				uiSameGetBoxStep := 200;
			END_IF

		200:	// 等 NearStorageSensor 穩定 1.5s
			tonDelay_SameSizeGetBox.IN := FALSE;
			tonDelay_SameSizeDelayBox.IN := Input.bSameSizeCV_BoxNearStorageSensor;
			IF tonDelay_SameSizeDelayBox.Q THEN
				uiSameGetBoxStep := 300;
			END_IF

		300:	// Press4 extend
			Cylinder.List.fbSameSizeCV_Press4.M_Extend();
			IF Cylinder.List.fbSameSizeCV_Press4.InFrontPosition THEN
				uiSameGetBoxStep := 400;
			END_IF

		400:	// 完成 → 進 3500
			tonDelay_SameSizeDelayBox.IN := FALSE;
			uiSameGetBoxStep := 0;
			TON_ConveyorTimeOut.IN := FALSE;
			uiExecutingStep := 3500;
	END_CASE
	IF TON_ConveyorTimeOut.Q THEN
		TON_ConveyorTimeOut.IN := FALSE;
		uiResumeStep := 3000;
		strStatus := 'Phase 3 擋盒 state machine timeout';
		_UniqueErrorCode := 'E_BLOCK_TIMEOUT';
		_Abort := TRUE;
	END_IF

3500:	// 軌道 backward 推到 NearStorage final settle (第二盒)
	TON_ConveyorTimeOut.IN := TRUE;
	TON_ArrivedDelay.IN := Input.bSameSizeCV_BoxNearStorageSensor;
	IF TON_ArrivedDelay.Q THEN
		TON_ConveyorTimeOut.IN := FALSE;
		bIntent_NeedBackward := FALSE;
		bIntent_HoldStill    := TRUE;	// 大手臂取盒前要靜止
		uiExecutingStep := 3600;
	END_IF
	IF TON_ConveyorTimeOut.Q THEN
		bIntent_NeedBackward := FALSE;
		uiResumeStep := 3000;	// retry 從馬達啟動重來
		strStatus := 'Box 2 cross conveyor timeout';
		_UniqueErrorCode := 'E_BOX_CROSS_TIMEOUT';
		_Abort := TRUE;
	END_IF

3600:	// 等待馬達停止
	 TON_ArrivedDelay.IN := FALSE;
	IF Motor.List.TransmitSameSideCV.InStopped THEN
		//uiExecutingStep := 3650;
		uiExecutingStep := 4000;
	END_IF
3650:	// dead code,保留 — Destination=WareHouse 視同舊 IsOK=TRUE
	 IF eBoxB_Destination = E_ReverseBoxDestination.WareHouse THEN
	  	uiExecutingStep := 4000;
	 ELSE
		uiExecutingStep := 3700;
  	 END_IF
	 
3700:
	TON_TimeOut.IN := TRUE;
	Cylinder.List.fbSameSizeCV_Press4.M_Extend();
	IF Cylinder.List.fbSameSizeCV_Press4.InFrontPosition THEN
		TON_TimeOut.IN := FALSE;
		uiExecutingStep := 3800;
	END_IF
	IF TON_TimeOut.Q THEN
		uiResumeStep := uiExecutingStep;
		strStatus := 'Press4 Extend timeout';
		_UniqueErrorCode := 'E_CYL_TIMEOUT';
		_Abort := TRUE;
	END_IF
3800:
	Cylinder.List.fbSameSizeCV_Press4.M_Retract();
	IF Cylinder.List.fbSameSizeCV_Press4.InRearPosition THEN				
		uiExecutingStep := 4000;
	END_IF

{endregion}

{region '=== Phase 4: 大手臂取第二盒 ==='}

4000:	// Robot AbsMove 第二爪
	TON_TimeOut.IN := TRUE;
	IF NOT StorageRobot._DI1.Done THEN
		StorageRobot.M_StartRobotAbsMove(
			GetBox			:= TRUE,
			UseClampA		:= FALSE,
			UseClampB		:= bFirstClampIsA,
			Area			:= E_RobotArea.TransmitCV,
			ClampA_Address	:= 99,
			ClampB_Address	:= PickupPosition,
			BoxReady_1		:= FALSE,
			BoxReady_2		:= bFirstClampIsA);
	ELSE
		TON_TimeOut.IN := FALSE;
		uiExecutingStep := 4100;
	END_IF
	IF TON_TimeOut.Q OR StorageRobot.Error THEN
		uiResumeStep := uiExecutingStep;
		strStatus := 'Robot pick second box timeout';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

4100:	// Reset Robot
	StorageRobot.M_ResetAllCommand();
	IF NOT StorageRobot._DI1.Done THEN
		uiExecutingStep := 5000;
	END_IF

{endregion}

{region '=== Phase 5: 放 ClampA ==='}

5000:	// 清除 Robot 命令
	TON_RobotResetTimeOut.IN := TRUE;
	StorageRobot.M_ResetAllCommand();
	IF NOT StorageRobot._DI1.Done AND
		NOT (StorageRobot._DI1.AbsMoveA OR StorageRobot._DI1.AbsMoveB OR
			 StorageRobot._DI1.WarehouseA OR StorageRobot._DI1.WarehouseB) THEN
		TON_RobotResetTimeOut.IN := FALSE;
		bBoxReady := FALSE;
		IF bBoxA_Enable THEN
			uiExecutingStep := 5100;
		ELSE
			uiExecutingStep := 6000;
		END_IF
	END_IF
	IF TON_RobotResetTimeOut.Q THEN
		uiResumeStep := 5000;
		strStatus := 'Robot reset timeout (phase 5)';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

5100:	// ClampA Destination 三選一
	CASE eBoxA_Destination OF
		E_ReverseBoxDestination.WareHouse:
			uiExecutingStep := 5200;
		E_ReverseBoxDestination.PullOut:
			uiExecutingStep := 5400;
		E_ReverseBoxDestination.NGConveyor:
			uiExecutingStep := 5300;
	ELSE
		uiResumeStep := 5100;
		strStatus := 'Invalid BoxA destination enum';
		_UniqueErrorCode := 'E_INVALID_DEST';
		_Abort := TRUE;
	END_CASE

5200:	// ClampA OK → 入倉
	TON_TimeOut.IN := TRUE;
	stWareHouseCoord.Layer := iBoxA_Level;
	stWareHouseCoord.Slide := iBoxA_Track;
	IF iBoxA_Warehouse = 1 THEN
		WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseA, WarehouseCoordinates := stWareHouseCoord);
		IF WareHouse.bFeedInBox_Completed THEN
			bBoxReady := TRUE;
		END_IF
		StorageRobot.M_StartWareHousePlaceBox_ClampA(
			WareHouseSelect := E_WareHouse.WareHouseA,
			Info := stWareHouseCoord,
			BoxReady_1st := bBoxReady);
	ELSIF iBoxA_Warehouse = 2 THEN
		WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseB, WarehouseCoordinates := stWareHouseCoord);
		IF WareHouse.bFeedInBox_Completed THEN
			bBoxReady := TRUE;
		END_IF
		StorageRobot.M_StartWareHousePlaceBox_ClampA(
			WareHouseSelect := E_WareHouse.WareHouseB,
			Info := stWareHouseCoord,
			BoxReady_1st := bBoxReady);
	ELSE
		uiResumeStep := 5200;
		strStatus := 'Invalid BoxA warehouse value';
		_UniqueErrorCode := 'E_INVALID_WAREHOUSE';
		_Abort := TRUE;
		RETURN;
	END_IF
	IF StorageRobot._DI1.Done THEN
		TON_TimeOut.IN := FALSE;
		bBoxA_Done := TRUE;
		uiExecutingStep := 5500;
	END_IF
	IF TON_TimeOut.Q OR StorageRobot.Error THEN
		uiResumeStep := 5200;
		strStatus := 'ClampA place to warehouse timeout';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

5300:	// ClampA NG → NG區
	NGRegionMove.Info.Get := FALSE;
	NGRegionMove.Info.UseA := TRUE;
	NGRegionMove.Info.UseB := FALSE;
	NGRegionMove.Info.A_Position := NGAreaPosition;
	NGRegionMove.Info.B_Position := 0;
	NGRegionMove.Execute := TRUE;
	uiExecutingStep := 5310;

5310:	// 等待 NG RegionMove 完成
	IF NGRegionMove.Done THEN
		NGRegionMove.Execute := FALSE;
		bBoxA_Done := TRUE;
		uiExecutingStep := 5320;
	END_IF
	IF NGRegionMove.Error OR NGRegionMove.Aborted THEN
		NGRegionMove.Execute := FALSE;
		uiResumeStep := 5300;
		strStatus := 'ClampA NG region move failed';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

5320:	// 等待 DORMANT
	IF NOT NGRegionMove.Busy AND NOT NGRegionMove.Done THEN
		uiExecutingStep := 5600;
	END_IF

5400:	// ClampA PullOut → PullOutConveyor 區 (Side 1=I3_Slide 左, 2=I4_Slide 右)
	IF iBoxA_PullOutSide < 1 OR iBoxA_PullOutSide > 2 THEN
		uiResumeStep := 5400;
		strStatus := 'Invalid BoxA PullOut side (must be 1 or 2)';
		_UniqueErrorCode := 'E_INVALID_PULLOUT_SIDE';
		_Abort := TRUE;
	ELSE
		PullOutRegionMove.Info.Get := FALSE;
		PullOutRegionMove.Info.UseA := TRUE;
		PullOutRegionMove.Info.UseB := FALSE;
		PullOutRegionMove.Info.A_Position := iBoxA_PullOutSide;
		PullOutRegionMove.Info.B_Position := 0;
		PullOutRegionMove.Execute := TRUE;
		uiExecutingStep := 5410;
	END_IF

5410:	// 等待 PullOut RegionMove 完成
	IF PullOutRegionMove.Done THEN
		PullOutRegionMove.Execute := FALSE;
		bBoxA_Done := TRUE;
		uiExecutingStep := 5420;
	END_IF
	IF PullOutRegionMove.Error OR PullOutRegionMove.Aborted THEN
		PullOutRegionMove.Execute := FALSE;
		uiResumeStep := 5400;
		strStatus := 'ClampA PullOut region move failed';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

5420:	// 等待 DORMANT
	IF NOT PullOutRegionMove.Busy AND NOT PullOutRegionMove.Done THEN
		uiExecutingStep := 5600;
	END_IF

5500:	// ClampA OK 完成 → Reset
	StorageRobot.M_ResetAllCommand();
	WareHouse.M_ResetFeedInBox();
	IF NOT StorageRobot._DI1.Done THEN
		uiExecutingStep := 5600;
	END_IF

5600:	// 繼續 ClampB?
	IF bDualGrip THEN
		bBoxReady := FALSE;
		uiExecutingStep := 6000;
	ELSE
		uiExecutingStep := 9000;
	END_IF

{endregion}

{region '=== Phase 6: 放 ClampB ==='}

6000:	// 準備放 ClampB
	TON_RobotResetTimeOut.IN := TRUE;
	StorageRobot.M_ResetAllCommand();
	IF NOT StorageRobot._DI1.Done AND
		NOT (StorageRobot._DI1.AbsMoveA OR StorageRobot._DI1.AbsMoveB OR
			 StorageRobot._DI1.WarehouseA OR StorageRobot._DI1.WarehouseB) THEN
		TON_RobotResetTimeOut.IN := FALSE;
		uiExecutingStep := 6100;
	END_IF
	IF TON_RobotResetTimeOut.Q THEN
		uiResumeStep := 6000;
		strStatus := 'Robot reset timeout (phase 6)';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

6100:	// ClampB Destination 三選一
	CASE eBoxB_Destination OF
		E_ReverseBoxDestination.WareHouse:
			uiExecutingStep := 6200;
		E_ReverseBoxDestination.PullOut:
			uiExecutingStep := 6400;
		E_ReverseBoxDestination.NGConveyor:
			uiExecutingStep := 6300;
	ELSE
		uiResumeStep := 6100;
		strStatus := 'Invalid BoxB destination enum';
		_UniqueErrorCode := 'E_INVALID_DEST';
		_Abort := TRUE;
	END_CASE

6200:	// ClampB OK → 入倉
	TON_TimeOut.IN := TRUE;
	stWareHouseCoord.Layer := iBoxB_Level;
	stWareHouseCoord.Slide := iBoxB_Track;
	IF iBoxB_Warehouse = 1 THEN
		WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseA, WarehouseCoordinates := stWareHouseCoord);
		IF WareHouse.bFeedInBox_Completed THEN
			bBoxReady := TRUE;
		END_IF
		StorageRobot.M_StartWareHousePlaceBox_ClampB(
			WareHouseSelect := E_WareHouse.WareHouseA,
			Info := stWareHouseCoord,
			BoxReady_2nd := bBoxReady);
	ELSIF iBoxB_Warehouse = 2 THEN
		WareHouse.M_StartFeedInBox(WareHouseSelect := E_WareHouse.WareHouseB, WarehouseCoordinates := stWareHouseCoord);
		IF WareHouse.bFeedInBox_Completed THEN
			bBoxReady := TRUE;
		END_IF
		StorageRobot.M_StartWareHousePlaceBox_ClampB(
			WareHouseSelect := E_WareHouse.WareHouseB,
			Info := stWareHouseCoord,
			BoxReady_2nd := bBoxReady);
	ELSE
		uiResumeStep := 6200;
		strStatus := 'Invalid BoxB warehouse value';
		_UniqueErrorCode := 'E_INVALID_WAREHOUSE';
		_Abort := TRUE;
		RETURN;
	END_IF
	IF StorageRobot._DI1.Done THEN
		TON_TimeOut.IN := FALSE;
		bBoxB_Done := TRUE;
		uiExecutingStep := 6500;
	END_IF
	IF TON_TimeOut.Q OR StorageRobot.Error THEN
		uiResumeStep := 6200;
		strStatus := 'ClampB place to warehouse timeout';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

6300:	// ClampB NG → NG區
	NGRegionMove.Info.Get := FALSE;
	NGRegionMove.Info.UseA := FALSE;
	NGRegionMove.Info.UseB := TRUE;
	NGRegionMove.Info.A_Position := 0;
	NGRegionMove.Info.B_Position := NGAreaPosition;
	NGRegionMove.Execute := TRUE;
	uiExecutingStep := 6310;

6310:	// 等待 NG 完成
	IF NGRegionMove.Done THEN
		NGRegionMove.Execute := FALSE;
		bBoxB_Done := TRUE;
		uiExecutingStep := 6320;
	END_IF
	IF NGRegionMove.Error OR NGRegionMove.Aborted THEN
		NGRegionMove.Execute := FALSE;
		uiResumeStep := 6300;
		strStatus := 'ClampB NG region move failed';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

6320:	// 等待 DORMANT
	IF NOT NGRegionMove.Busy AND NOT NGRegionMove.Done THEN
		uiExecutingStep := 9000;
	END_IF

6400:	// ClampB PullOut → PullOutConveyor 區 (Side 1=I3_Slide 左, 2=I4_Slide 右)
	IF iBoxB_PullOutSide < 1 OR iBoxB_PullOutSide > 2 THEN
		uiResumeStep := 6400;
		strStatus := 'Invalid BoxB PullOut side (must be 1 or 2)';
		_UniqueErrorCode := 'E_INVALID_PULLOUT_SIDE';
		_Abort := TRUE;
	ELSE
		PullOutRegionMove.Info.Get := FALSE;
		PullOutRegionMove.Info.UseA := FALSE;
		PullOutRegionMove.Info.UseB := TRUE;
		PullOutRegionMove.Info.A_Position := 0;
		PullOutRegionMove.Info.B_Position := iBoxB_PullOutSide;
		PullOutRegionMove.Execute := TRUE;
		uiExecutingStep := 6410;
	END_IF

6410:	// 等待 PullOut 完成
	IF PullOutRegionMove.Done THEN
		PullOutRegionMove.Execute := FALSE;
		bBoxB_Done := TRUE;
		uiExecutingStep := 6420;
	END_IF
	IF PullOutRegionMove.Error OR PullOutRegionMove.Aborted THEN
		PullOutRegionMove.Execute := FALSE;
		uiResumeStep := 6400;
		strStatus := 'ClampB PullOut region move failed';
		_UniqueErrorCode := 'E_BIGARM_TIMEOUT';
		_Abort := TRUE;
	END_IF

6420:	// 等待 DORMANT
	IF NOT PullOutRegionMove.Busy AND NOT PullOutRegionMove.Done THEN
		uiExecutingStep := 9000;
	END_IF

6500:	// ClampB OK 完成 → Reset
	StorageRobot.M_ResetAllCommand();
	WareHouse.M_ResetFeedInBox();
	IF NOT StorageRobot._DI1.Done THEN
		uiExecutingStep := 9000;
	END_IF

{endregion}

{region '=== Phase 9: 復位 ==='}

9000:	// 復位機構 (Phase 2:清 local intent,Busy 仍 TRUE 時 A00 會 propagate FALSE)
	bIntent_NeedBackward := FALSE;
	bIntent_HoldStill    := FALSE;
	Cylinder.List.fbSameSizeCV_Press3.M_Retract();
	Cylinder.List.fbSameSizeCV_Press4.M_Retract();
	uiExecutingStep := 9100;

9100:	// 等待復位完成 (Press3 + Press4 縮回 + 馬達停)
	TON_TimeOut.IN := TRUE;
	IF Cylinder.List.fbSameSizeCV_Press3.InRearPosition AND
	   Cylinder.List.fbSameSizeCV_Press4.InRearPosition AND
	   Motor.List.TransmitSameSideCV.InStopped THEN
		TON_TimeOut.IN := FALSE;
		_Executed := TRUE;
	END_IF
	IF TON_TimeOut.Q THEN
		uiResumeStep := uiExecutingStep;
		strStatus := 'Mechanism reset timeout';
		_UniqueErrorCode := 'E_CYL_TIMEOUT';
		_Abort := TRUE;
	END_IF

{endregion}

END_CASE

// 狀態切換
IF _Error THEN
	eState := STATE_ERROR;
ELSIF _Abort THEN
	eState := STATE_ABORTING;
ELSIF _Executed THEN
	eState := STATE_DONE;
ELSIF NOT Execute THEN
	eState := STATE_RESETTING; 
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_RESETTING" Id="{00000002-f4a5-4b6c-7d8e-9f0a1b2c3d4e}" FolderPath="State\">
      <Declaration><![CDATA[METHOD M_STATE_RESETTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := TRUE;
Error := FALSE;
Aborted := FALSE;

CASE uiResettingStep OF
0:
	TON_TimeOut.IN := FALSE;
	TON_ConveyorTimeOut.IN := FALSE;
	TON_RobotResetTimeOut.IN := FALSE;
	tonDelay_SameSizeGetBox.IN := FALSE;
	tonDelay_SameSizeDelayBox.IN := FALSE;
	uiSameGetBoxStep := 0;

	StorageRobot.M_ResetAllCommand();
	WareHouse.M_ResetFeedInBox();
	NGRegionMove.Execute := FALSE;
	PullOutRegionMove.Execute := FALSE;
	// Phase 2:清 local intent (Busy=FALSE A00 不會寫,不影響別 instance shared flag)
	bIntent_NeedBackward := FALSE;
	bIntent_HoldStill    := FALSE;

	uiResettingStep := 100;

100:
	Done := FALSE;
	Busy := FALSE;
	_ResetCompleted := TRUE;
END_CASE

IF _ResetCompleted THEN
	eState := STATE_DORMANT;
END_IF
]]></ST>
      </Implementation>
    </Method>
