<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_OutRobot_BoxMoveReverse" Id="{f3e83fbe-be04-4e98-957f-fba21b58faf5}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_OutRobot_BoxMoveReverse EXTENDS FB_ObjectBase_V2
VAR_INPUT
//    Execute    :BOOL;   // True : This prog will start.
//    Abort      :BOOL;   // True : This prog will be abort.
//    Reset      :BOOL;   // True : This prog will be reset.
//    ObjectName :STRING; // Set this fb name(About it's action)
	INPUT            			   : REFERENCE TO ST_InputTable;
	Cylinder   					   : REFERENCE TO UNI_CylinderList;
	Motor      					   : REFERENCE TO UNI_MotorList;
	Cylinders					   : REFERENCE TO ARRAY[0..1] OF FB_Cylinder;
	Clips						   : REFERENCE TO ARRAY[0..1] OF FB_Cylinder;
	AutoMode_OutRobotMoveMove : st_AutoMode_ClampingBoxesJob;	
END_VAR

VAR_OUTPUT
//    Busy    :BOOL;        // True : This prog is running.
//    Done    :BOOL;        // True : Command has been executed.
//    Aborted :BOOL;        // True : This prog is aborted.
//    Error   :BOOL;        // True : This prog has an error.
//    ErrorID :UINT;       // Output ErrorID
//    Status  :T_MaxString; // Output this prog status by string(255bytes)
END_VAR

VAR
//    eState :E_MethodStatus_Basic;
//	uiExecutingStep : UDINT; // This var is used to been controll STATE_EXECUTING process.
//	uiResettingStep : UDINT;
//	uiAbortingStep : UDINT;
//	_Executed :BOOL; // Executing process completed.
//	_Error : BOOL; // FB has an error.
//	_ResetCompleted : BOOL; // FB resetting completed.
//	_AbortCompleted : BOOL; // FB aborting completed.
//	_Abort		: BOOL;
	strStatus	: STRING;
	uiResumeStep : UDINT;
	tonTimeOut   :TON;
	tonTimeDelay   :TON;
	iWorkingIndex : INT;
	_UniqueErrorCode :STRING;

	PickingPos	: ARRAY[0..1] OF ST_PositionTable;
	PlacingPos  : ARRAY[0..1] OF ST_PositionTable;
	bSyncPick	: BOOL;
	bSyncPlace	: BOOL;
	SensorOnConveyor			   : BIT;
	ConveyorMotor				   : REFERENCE TO FB_Motor;
	UseA	: BOOL;
	UseB	: BOOL;
	bMotorMoveForward : BOOL;
	lrEpsPos 	: LREAL := 0.001;	// 浮點座標比較容差 (sync 判斷)
	// Step 切換偵測 (timer 乾淨重置)
	uiExecutingStep_Last : UDINT;
	// Resume / Pause 機制
	bResumeEnabled : BOOL;
	bCanPause : BOOL;
	bPauseLast : BOOL;
	// 雙 clip pick / place 旗標 (取代 iWorkingIndex 共用)
	bPickedA : BOOL;
	bPickedB : BOOL;
	bPlacedA : BOOL;
	bPlacedB : BOOL;
	// Safety: 夾爪是否正夾著箱 (latched, 1300 閉夾→TRUE, 2300 開夾→FALSE)
	bClipHasBox : ARRAY[0..1] OF BOOL;
	
	_bRetry  : BOOL;
	
	// Error blinking 閃爍邏輯
	trigErrorReset		: R_TRIG;
	tonErrorResetDelay	: TON;
	bErrorBlinking		: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[A00_BasicUnits();
SUPER^.A10_StateControl();]]></ST>
    </Implementation>
    <Folder Name="Method" Id="{d6e260a5-a891-444e-890d-7227dd5220a5}" />
    <Folder Name="STATE" Id="{f9fc60e3-aa74-4364-b599-5cdb8c0b3912}" />
    <Action Name="A00_BasicUnits" Id="{14e52cea-4905-4712-ad7d-530b54102f3f}">
      <Implementation>
        <ST><![CDATA[// Timer 由各 step 自行呼叫並傳 IN/PT,此處不做 freerun call,
// 避免「IN 殘留 TRUE」造成 step 切換後 timer 不歸零。]]></ST>
      </Implementation>
    </Action>
    <Method Name="GetModelState" Id="{5eb72e06-7e2a-4bb9-a846-ce5593c00faf}">
      <Declaration><![CDATA[METHOD GetModelState
VAR_OUTPUT
    xDone    :BOOL;
    xBusy    :BOOL;
    xError   :BOOL;
    xAborted :BOOL;
    iErrorID :UDINT;
	UniqueErrorCode : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[xDone    := Done;
xBusy    := Busy;
xError   := Error;
xAborted := Aborted;
iErrorID := ErrorID;
UniqueErrorCode := THIS^.UniqueErrorCode;]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetName" Id="{2525672c-763f-45e0-914f-a08631d0e58d}">
      <Declaration><![CDATA[METHOD GetName : STRING
]]></Declaration>
      <Implementation>
        <ST><![CDATA[GetName := ObjectName;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckCommand" Id="{f140fd6d-cdcd-4593-a4b7-9ce270b0ce43}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_CheckCommand : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT AutoMode_OutRobotMoveMove.ClampingInfo.UseClibA AND NOT AutoMode_OutRobotMoveMove.ClampingInfo.UseClibB THEN
	M_CheckCommand := FALSE;
	strStatus 	   := 'FB_OutRobot_BoxMoveReverse , Wrong Command Neither Clamp was used';
	RETURN;
END_IF
IF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA <> AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipB THEN
	M_CheckCommand := FALSE;
	strStatus 	   := 'FB_OutRobot_BoxMoveReverse , Wrong Command ClampA,B need same TargetPos';
	RETURN;
END_IF

M_CheckCommand:=true;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetResumeEntryStep" Id="{c0000003-0000-0000-0000-000000000003}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_GetResumeEntryStep : UDINT
VAR_INPUT
	uiErrorStep : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Resume 入口對照表: 錯誤點 → 重新進入的安全 checkpoint
CASE uiErrorStep OF
	1000, 1100:
		M_GetResumeEntryStep := 1000;
	1200, 1300, 1400, 1500, 1600:
		M_GetResumeEntryStep := 1000;	// pick 階段錯誤 → 重發 XY 從頭 pick
	2000, 2100, 2150:
		M_GetResumeEntryStep := 2000;
	2200, 2300, 2400, 2500:
		M_GetResumeEntryStep := 2000;	// place 階段錯誤 → 重發 XY 從頭 place
	2600, 2700:
		M_GetResumeEntryStep := 2600;	// conveyor handoff 重做
ELSE
	M_GetResumeEntryStep := 0;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetWorkingConditions" Id="{98cc34e0-eda1-4aec-bc36-9e9af1097447}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_GetWorkingConditions : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//For Outbox move reverse, Boxes must place on same position , therefor only work with TargetPosition of ClipA



IF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 5 THEN
	ConveyorMotor REF= Motor.List.TransmitDifferentSideCV;
ELSIF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 6 THEN
	ConveyorMotor REF= Motor.List.TransmitSameSideCV;
ELSIF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 3 THEN
	ConveyorMotor REF= Motor.List.TransmitDifferentSideCV;
ELSIF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 4 THEN
	ConveyorMotor REF= Motor.List.TransmitSameSideCV;
END_IF

IF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA=5 THEN
		bMotorMoveForward := FALSE;
	ELSE
		bMotorMoveForward := TRUE;
END_IF
IF AutoMode_OutRobotMoveMove.ClampingInfo.UseClibA THEN
	PickingPos[0] :=FUN_GetPositionTableData('R',1,0);
	UseA := TRUE;
	CASE  AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA OF

	3,4:
		PlacingPos[0] :=FUN_GetPositionTableData('O',AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA,0);
	5,6:
		PlacingPos[0] :=FUN_GetPositionTableData('I',AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA,0);
	ELSE
		strStatus := M_FormatManagedStatus(
			AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
			InnerMessage := GVL_ErrorCode.GC_MSG_0157);
		Status := strStatus;
		Error := TRUE;
		M_GetWorkingConditions := FALSE;
		RETURN;
	END_CASE
END_IF

IF AutoMode_OutRobotMoveMove.ClampingInfo.UseClibB THEN
	PickingPos[1] :=FUN_GetPositionTableData('R',2,1);
	UseB :=TRUE;
		CASE AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipB OF

	3,4:
		PlacingPos[1] :=FUN_GetPositionTableData('O',AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipB,1);
	5,6 :
		PlacingPos[1] :=FUN_GetPositionTableData('I',AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipB,1);
	ELSE
		strStatus := M_FormatManagedStatus(
			AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
			InnerMessage := GVL_ErrorCode.GC_MSG_0158);
		Status := strStatus;
		Error := TRUE;
		M_GetWorkingConditions := FALSE;
		RETURN;
	END_CASE
END_IF

// Sync 判斷一律用浮點容差 (lrEpsPos), OutRobot 只有 X/Y 軸 (無 R 軸),
// 不比較 R_Pos 避免因不相關欄位微誤差導致 sync 永遠 FALSE
bSyncPlace := UseA AND UseB
	AND ABS(PlacingPos[0].X_Pos - PlacingPos[1].X_Pos) < lrEpsPos
	AND ABS(PlacingPos[0].Y_Pos - PlacingPos[1].Y_Pos) < lrEpsPos;

bSyncPick := UseA AND UseB
	AND ABS(PickingPos[0].X_Pos - PickingPos[1].X_Pos) < lrEpsPos
	AND ABS(PickingPos[0].Y_Pos - PickingPos[1].Y_Pos) < lrEpsPos;

M_GetWorkingConditions :=TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_IsOutRobotAtPos" Id="{c0000001-0000-0000-0000-000000000001}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_IsOutRobotAtPos : BOOL
VAR_INPUT
	TargetPos : ST_PositionTable;
END_VAR
VAR
	lTol : LREAL := 0.1;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//lTol := GVL_HMI.Setup.Mechanical.OutRobotPositionTolerance;

M_IsOutRobotAtPos :=
		NOT arAxisCtrl_gb[AxisNo.OutRobot_X].Admin.Axis.Status.Moving
	AND NOT arAxisCtrl_gb[AxisNo.OutRobot_Y].Admin.Axis.Status.Moving
	AND ABS(arAxisCtrl_gb[AxisNo.OutRobot_X].Admin.Axis.NcToPlc.ActPos - TargetPos.X_Pos) < lTol
	AND ABS(arAxisCtrl_gb[AxisNo.OutRobot_Y].Admin.Axis.NcToPlc.ActPos - TargetPos.Y_Pos) < lTol;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_IsTurnTableAtStation" Id="{c0000002-0000-0000-0000-000000000002}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_IsTurnTableAtStation : BOOL
VAR
	lActPos : LREAL;
	lTol    : LREAL := 0.1;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Pick 前 TurnTable 必須位於 0/90/180/270/360 (任一 station)
// 取絕對值處理負角度 (e.g., -90 → 90, -180 → 180)
lActPos := ABS(arAxisCtrl_gb[AxisNo.TurnTable].Admin.Axis.NcToPlc.ModuloActPos);

M_IsTurnTableAtStation :=
	   FUN_CheckInPos(ActPos:=lActPos, TargetPos:=0,   ToleranceRange:=lTol)
	OR FUN_CheckInPos(ActPos:=lActPos, TargetPos:=90,  ToleranceRange:=lTol)
	OR FUN_CheckInPos(ActPos:=lActPos, TargetPos:=180, ToleranceRange:=lTol)
	OR FUN_CheckInPos(ActPos:=lActPos, TargetPos:=270, ToleranceRange:=lTol)
	OR FUN_CheckInPos(ActPos:=lActPos, TargetPos:=360, ToleranceRange:=lTol);]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_RecoveryAllObjects" Id="{d165e555-6c86-4089-916b-9a58de282fb4}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_RecoveryAllObjects : BOOL
VAR_INPUT
END_VAR
VAR 
	i : INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[FOR i:=0 TO 1 DO
	// Clip: 有箱時絕對不張開 (safety),只清錯
	IF Clips[i].xError THEN
		Clips[i].M_Reset();
	ELSIF NOT bClipHasBox[i] THEN
		Clips[i].M_Retract();
	END_IF
	// Cylinder: 一律抬起 (空爪或有箱都安全)
	IF Cylinders[i].xError THEN
		Cylinders[i].M_Reset();
	ELSE
		Cylinders[i].M_Retract();
	END_IF
END_FOR


IF arAxisCtrl_gb[AxisNo.OutRobot_X].Admin.Axis.Status.Error THEN

	arAxisCtrl_gb[AxisNo.OutRobot_X].Admin.ClearError:= TRUE;
ELSE
	arAxisCtrl_gb[AxisNo.OutRobot_X].Admin.ClearError:= FALSE;
END_IF

IF arAxisCtrl_gb[AxisNo.OutRobot_Y].Admin.Axis.Status.Error THEN

	arAxisCtrl_gb[AxisNo.OutRobot_Y].Admin.ClearError:= TRUE;
ELSE
	arAxisCtrl_gb[AxisNo.OutRobot_Y].Admin.ClearError:= FALSE;
END_IF
	]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SensorUpdate" Id="{f1f87623-52f8-4554-9792-aeb5eb42c4d9}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_SensorUpdate : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 5 THEN
	SensorOnConveyor := INPUT.bDifferentSizeCV_BoxDetect5_Sensor;
ELSIF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 6 THEN
	SensorOnConveyor := INPUT.bSameSizeCV_BoxDetect5_Sensor;
ELSIF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 3 THEN
	SensorOnConveyor := INPUT.bDifferentSizeCV_BoxDetect4_Sensor;
ELSIF AutoMode_OutRobotMoveMove.ClampingInfo.TargetOfClipA = 4 THEN
	SensorOnConveyor := INPUT.bSameSizeCV_BoxDetect4_Sensor;	
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTED" Id="{d840a1d1-c783-4da9-80f0-46e244582d0e}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD  M_STATE_ABORTED
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT _bRetry THEN
	ERROR 			:= TRUE;
	Busy    		:= FALSE;
	Aborted 		:= TRUE;
	Status 			:= strStatus;
	uiAbortingStep  := 0;
	_AbortCompleted := TRUE;
END_IF

IF reset THEN
	ERROR 	:= FALSE;
	Aborted := FALSE;
	_bRetry	:= TRUE;
END_IF

IF NOT Execute THEN
	eSTATE:=STATE_RESETTING;
// 續做: Reset+Execute 時設旗標,EXECUTING step 0 會跳到 ResumeStep
ELSIF Execute AND _bRetry AND uiResumeStep > 0 THEN
	Status  := '';
	bResumeEnabled := TRUE;
	uiExecutingStep := 0;
	eSTATE:=STATE_EXECUTING;
// 判斷如果是不能續做的，重新跳回aborting 再次進入aborted 循環，上位下Reset 會看Error 如果Error沒有消失會卡住。
ELSIF Execute AND _bRetry AND uiResumeStep = 0 THEN	
	strStatus := 'FB_OutRobot_BoxMoveReverse, this Error can not retry';
	eState := STATE_ERROR;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTING" Id="{dc5c1a40-90b4-4678-8029-a3d1311ecd17}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD  M_STATE_ABORTING
VAR_INPUT
END_VAR

VAR
	i : int;
	bCylinderCheck: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Timer 歸零
tonTimeOut(IN:=FALSE);
tonTimeDelay(IN:=FALSE);

CASE uiAbortingStep OF
	0 :
		_Abort  := FALSE;
		_bRetry := FALSE;
		bCylinderCheck:=TRUE;
		IF __ISVALIDREF(ConveyorMotor) THEN
			ConveyorMotor.M_MotorStop();
		END_IF

		// Safety: 有箱的 clip 絕對不張開
		FOR i :=0 TO 1 DO
			IF Clips[i].xError THEN
				Clips[i].M_Reset();
			ELSIF NOT bClipHasBox[i] THEN
				Clips[i].M_Retract();
			END_IF
		END_FOR

		// Cylinder 一律抬起 (空爪或有箱都安全)
		FOR i :=0 TO 1 DO
			IF Cylinders[i].xError THEN
				Cylinders[i].M_Reset();
			END_IF
			Cylinders[i].M_Retract();
			bCylinderCheck:=bCylinderCheck AND Cylinders[i].InRearPosition;
		END_FOR

		IF bCylinderCheck THEN
			uiAbortingStep:=9999;
		END_IF

	9999:
		_Abort := FALSE;
		_AbortCompleted:=TRUE;
END_CASE

IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF Execute AND _AbortCompleted THEN
	eSTATE :=STATE_ABORTED;
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DONE" Id="{c9e9cf49-5e0e-45c3-9c1b-20074085120c}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD  M_STATE_DONE
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy 	:= FALSE;
Done	:=TRUE;

IF NOT Execute THEN
	eSTATE:=STATE_RESETTING;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DORMANT" Id="{143405c0-ae72-4a5a-8b8d-6a872a66ac79}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD  M_STATE_DORMANT
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy            := FALSE;
Done            := FALSE;
Aborted         := FALSE;
Error           := FALSE;
ErrorID         := 0;
Status          := '';
_ResetCompleted := FALSE;
_Error          := FALSE;
_Executed       := FALSE;
_Abort          := FALSE;
strStatus := M_FormatManagedStatus(
	AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
	InnerMessage := GVL_ErrorCode.GC_MSG_0089);
Status := '';
Error := FALSE;
uiExecutingStep :=uiResettingStep :=0;
// Timer 完整歸零 (用實際 FB call,不是只設屬性)
tonTimeOut(IN:=FALSE);
tonTimeDelay(IN:=FALSE);
uiExecutingStep_Last := 0;
_UniqueErrorCode:='0';
iWorkingIndex :=0;
bSyncPick := FALSE;
bSyncPlace := FALSE;
UseA := FALSE;
UseB := FALSE;
bMotorMoveForward := FALSE;
bPickedA := FALSE;
bPickedB := FALSE;
bPlacedA := FALSE;
bPlacedB := FALSE;
bPauseLast 	:= FALSE;
bCanPause 	:= FALSE;
_bRetry	 	:= FALSE;
_AbortCompleted := FALSE;
uiAbortingStep  := 0;
tonErrorResetDelay.IN := FALSE;
// 非續做模式才清 ResumeStep 與 ClipHasBox
IF NOT bResumeEnabled THEN
	uiResumeStep := 0;
	bClipHasBox[0] := FALSE;
	bClipHasBox[1] := FALSE;
END_IF
// 註: M_RecoveryAllObjects 不放 DORMANT 避免與其他 FB 搶 ClearError,
// 以及避免清掉 bClipHasBox 後誤張爪掉箱。僅 EXECUTING step 0 / RESETTING 呼叫。

IF Execute THEN
	eSTATE:=STATE_EXECUTING;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ERROR" Id="{b6e5580e-fd77-4ac8-b994-4f8bfb80565d}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD  M_STATE_ERROR
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[ERROR   :=TRUE;
Busy	:=FALSE;
_Error  := FALSE;
Status := strStatus;
IF __ISVALIDREF(ConveyorMotor) THEN
	ConveyorMotor.M_MotorStop();
END_IF

// --- Reset 閃爍邏輯：偵測上升緣觸發 1 秒閃爍 ---
trigErrorReset(CLK := reset);
IF trigErrorReset.Q THEN
	bErrorBlinking := TRUE;
END_IF

tonErrorResetDelay(IN := bErrorBlinking, PT := T#1S);
IF tonErrorResetDelay.Q THEN
	bErrorBlinking := FALSE;
END_IF

// 閃爍期間 (1秒) 暫時將 Error 訊號設為 FALSE
IF bErrorBlinking THEN
	Error := FALSE;
END_IF


IF NOT Execute THEN
	bErrorBlinking := FALSE;
	tonErrorResetDelay.IN := FALSE;
	eSTATE:=STATE_RESETTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_EXECUTING" Id="{1e1413df-6920-4d38-abcc-c5a793041751}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD  M_STATE_EXECUTING
VAR_INPUT
END_VAR
VAR_INST
	bMoveConveyorForward : BOOL;
	bMoveConveyorBackrward : bool;
END_VAR

VAR
	bCylinderCheck : BOOL := TRUE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy :=TRUE;
M_SensorUpdate();

// ============================================================
// (A) Step 切換 → Timer 完整歸零 (Fix 1)
// ============================================================
IF uiExecutingStep <> uiExecutingStep_Last THEN
	tonTimeOut(IN:=FALSE);
	tonTimeDelay(IN:=FALSE);
	uiExecutingStep_Last := uiExecutingStep;
END_IF

// ============================================================
// (B) TurnTable Interlock (Fix 3)
// Pick 下爪區間 (1200~1499) 期間 TurnTable 不可移動
// ============================================================
IF (uiExecutingStep >= 1200 AND uiExecutingStep <= 1499) THEN
	IF arAxisCtrl_gb[AxisNo.TurnTable].Admin.Axis.Status.Moving THEN
		_Error := TRUE;
		uiResumeStep := uiExecutingStep;
		strStatus := M_FormatManagedStatus(
			AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
			InnerMessage := GVL_ErrorCode.GC_MSG_0174);
		Status := strStatus;
		Error := TRUE;
	END_IF
END_IF

// ============================================================
// (C) Pause 處理 (Fix 4) - 僅在「安全 step」生效
// ============================================================
bCanPause :=
	   uiExecutingStep = 0
	OR uiExecutingStep = 100
	OR uiExecutingStep = 200
	OR uiExecutingStep = 1000
	OR uiExecutingStep = 1100
	OR uiExecutingStep = 1500
	OR uiExecutingStep = 2000
	OR uiExecutingStep = 2100
	OR uiExecutingStep = 2150
	OR uiExecutingStep = 2500
	OR uiExecutingStep = 2700;

// Pause 釋放邊緣 → 強制 timer 歸零
IF bPauseLast AND NOT Pause THEN
	tonTimeOut(IN:=FALSE);
	tonTimeDelay(IN:=FALSE);
END_IF
bPauseLast := Pause;

IF Pause AND bCanPause THEN
	bMoveConveyorForward := FALSE;
	bMoveConveyorBackrward := FALSE;
	IF __ISVALIDREF(ConveyorMotor) THEN
		ConveyorMotor.M_MotorStop();
	END_IF
	tonTimeOut(IN:=FALSE);
	tonTimeDelay(IN:=FALSE);
	Busy := TRUE;
	RETURN;
END_IF

// ============================================================
// Conveyor 連續控制 (sync 後 latched flag 控制)
// ============================================================
IF bMoveConveyorForward THEN
	IF NOT ConveyorMotor.InBackWard THEN
		ConveyorMotor.M_MoveForward();
	END_IF
END_IF

IF bMoveConveyorBackrward THEN
	IF NOT ConveyorMotor.InForWard THEN
		ConveyorMotor.M_MoveBackward();
	END_IF
END_IF

CASE uiExecutingStep OF

0: //Entry - VAR_INST reset + 流程分流
	// VAR_INST 私有給本 method,DORMANT 看不到,必須在此 reset
	bMoveConveyorForward := FALSE;
	bMoveConveyorBackrward := FALSE;

	IF GVL_Machine.PackTags[UnitNo.Allocate].Status.UnitModeCurrent <> E_UnitMode.Auto THEN
		strStatus := 'Not in Auto mode';
		_UniqueErrorCode := 'E_NOT_AUTO_MODE';
		_Error := TRUE;
	ELSIF bResumeEnabled AND uiResumeStep > 0 THEN
		// 續做模式
		IF M_GetWorkingConditions() THEN
			M_RecoveryAllObjects();
			// Safety: 若仍夾著箱,強制走 placing 流程
			IF bClipHasBox[0] OR bClipHasBox[1] THEN
				IF bClipHasBox[0] THEN
					iWorkingIndex := 0;
				ELSE
					iWorkingIndex := 1;
				END_IF
				bPickedA := UseA;
				bPickedB := UseB;
				bPlacedA := UseA AND NOT bClipHasBox[0];
				bPlacedB := UseB AND NOT bClipHasBox[1];
				uiExecutingStep := 2000;
			ELSE
				uiExecutingStep := M_GetResumeEntryStep(uiErrorStep:=uiResumeStep);
			END_IF
			bResumeEnabled := FALSE;
			uiResumeStep := 0;
		ELSE
			_Error := TRUE;
		END_IF
	ELSE
		// 正常啟動: DORMANT 已 reset 所有 FB-level flag
		IF M_GetWorkingConditions() THEN
			M_RecoveryAllObjects();
			uiExecutingStep := 100;
		ELSE
			_Error := TRUE;
		END_IF
	END_IF

100: //Check command
	IF M_CheckCommand() THEN
		uiExecutingStep:=200;
	ELSE
		_Error :=TRUE;
	END_IF

200: // TT angle gate + 確認 R 上有箱
	IF NOT M_IsTurnTableAtStation() THEN
		_Abort := TRUE;
		uiResumeStep := uiExecutingStep;
		strStatus := M_FormatManagedStatus(
			AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
			InnerMessage := GVL_ErrorCode.GC_MSG_0175);
	ELSIF (UseA AND NOT INPUT.bTurnTable_R1Detect_Sensor) OR (UseB AND NOT INPUT.bTurnTable_R2Detect_Sensor) THEN
		_Error:=TRUE;
		uiResumeStep := 0;	// 沒箱可抓 → 不可續做
		strStatus := M_FormatManagedStatus(
			AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
			InnerMessage := GVL_ErrorCode.GC_MSG_0009);
		Status := strStatus;
		Error := TRUE;
	ELSE
		IF UseA THEN
			iWorkingIndex :=0;
		ELSE
			iWorkingIndex :=1;
		END_IF
		uiExecutingStep:=1000;
	END_IF

1000: // Move OutRobot to picking pos (TurnTable R)
	arAxisCtrl_gb[AxisNo.OutRobot_X].PosMode.Position := PickingPos[iWorkingIndex].X_Pos;
	arAxisCtrl_gb[AxisNo.OutRobot_Y].PosMode.Position := PickingPos[iWorkingIndex].Y_Pos;
	uiExecutingStep:=1100;

1100: // Wait OutRobot XY arrive (pick on TT) - 修正: 等 TurnTable 靜止 (原本誤檢查 RoundBelt)
	IF (arAxisStatus_gb[AxisNo.OutRobot_X].Admin._OpModeAck = ModePosAbs AND arAxisStatus_gb[AxisNo.OutRobot_X].Admin.CmdDone)
	AND (arAxisStatus_gb[AxisNo.OutRobot_Y].Admin._OpModeAck = ModePosAbs AND arAxisStatus_gb[AxisNo.OutRobot_Y].Admin.CmdDone)
	AND NOT arAxisCtrl_gb[AxisNo.TurnTable].Admin.Axis.Status.Moving
	THEN
		uiExecutingStep:=1200;
	ELSE
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0082);
		END_IF
	END_IF

1200: // Clip down (pick) - Fix 2: 下爪前位置再確認
	IF NOT M_IsOutRobotAtPos(TargetPos:=PickingPos[iWorkingIndex]) THEN
		_Abort := TRUE;
		uiResumeStep := uiExecutingStep;
		strStatus := M_FormatManagedStatus(
			AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
			InnerMessage := GVL_ErrorCode.GC_MSG_0172);
	ELSE
		// Sync 對稱化: sync 時兩爪同動同檢查
		IF bSyncPick THEN
			Cylinders[0].M_Extend();
			Cylinders[1].M_Extend();
			bCylinderCheck := Cylinders[0].InFrontPosition AND Cylinders[1].InFrontPosition;
		ELSE
			Cylinders[iWorkingIndex].M_Extend();
			bCylinderCheck := Cylinders[iWorkingIndex].InFrontPosition;
		END_IF
		IF bCylinderCheck THEN
			uiExecutingStep:=1300;
		ELSE
			tonTimeOut(IN:=TRUE, PT:=T#15S);
			IF tonTimeOut.Q THEN
				_Abort := TRUE;
				uiResumeStep := uiExecutingStep;
				strStatus := M_FormatManagedStatus(
					AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
					InnerMessage := GVL_ErrorCode.GC_MSG_0048);
				Status := strStatus;
				Error := TRUE;
			END_IF
		END_IF
	END_IF

1300: // Clip close (pick)
	IF bSyncPick THEN
		Clips[0].M_Extend();
		Clips[1].M_Extend();
		bCylinderCheck := Clips[0].InFrontPosition AND Clips[1].InFrontPosition;
	ELSE
		Clips[iWorkingIndex].M_Extend();
		bCylinderCheck := Clips[iWorkingIndex].InFrontPosition;
	END_IF
	IF bCylinderCheck THEN
		// Safety: 標記夾到箱
		IF bSyncPick THEN
			bClipHasBox[0] := TRUE;
			bClipHasBox[1] := TRUE;
		ELSE
			bClipHasBox[iWorkingIndex] := TRUE;
		END_IF
		uiExecutingStep:=1400;
	ELSE
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0025);
			Status := strStatus;
			Error := TRUE;
		END_IF
	END_IF

1400: // Clip up (pick)
	IF bSyncPick THEN
		Cylinders[0].M_Retract();
		Cylinders[1].M_Retract();
		bCylinderCheck := Cylinders[0].InRearPosition AND Cylinders[1].InRearPosition;
	ELSE
		Cylinders[iWorkingIndex].M_Retract();
		bCylinderCheck := Cylinders[iWorkingIndex].InRearPosition;
	END_IF
	IF bCylinderCheck THEN
		uiExecutingStep:=1500;
	ELSE
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0049);
			Status := strStatus;
			Error := TRUE;
		END_IF
	END_IF

1500: // Next pick? (修雙 clip 漏放 bug, 用 bPickedA/B 旗標)
	IF bSyncPick THEN
		bPickedA := TRUE;
		bPickedB := TRUE;
	ELSIF iWorkingIndex = 0 THEN
		bPickedA := TRUE;
	ELSE
		bPickedB := TRUE;
	END_IF
	IF UseA AND NOT bPickedA THEN
		iWorkingIndex := 0;
		uiExecutingStep := 1000;
	ELSIF UseB AND NOT bPickedB THEN
		iWorkingIndex := 1;
		uiExecutingStep := 1000;
	ELSE
		// 全部 pick 完,先確認 R 上箱已離開,再進 placing
		IF UseA THEN
			iWorkingIndex := 0;
		ELSE
			iWorkingIndex := 1;
		END_IF
		uiExecutingStep := 1600;
	END_IF

1600: // Confirm box left R sensor (pick 真的有抓起來)
	IF (UseA AND INPUT.bTurnTable_R1Detect_Sensor) OR (UseB AND INPUT.bTurnTable_R2Detect_Sensor) THEN
		// 還偵測到箱 → 等 timeout 才報錯,因為氣缸抬起到感測器斷訊可能有延遲
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0016);
			Status := strStatus;
			Error := TRUE;
		END_IF
	ELSE
		uiExecutingStep := 2000;
	END_IF


2000: // Move conveyor + send OutRobot to placing pos
	IF bMotorMoveForward THEN
		bMoveConveyorForward:=TRUE;
		bMoveConveyorBackrward:=FALSE;
	ELSE
		bMoveConveyorForward:=FALSE;
		bMoveConveyorBackrward:=TRUE;
	END_IF
	arAxisCtrl_gb[AxisNo.OutRobot_X].PosMode.Position := PlacingPos[iWorkingIndex].X_Pos;
	arAxisCtrl_gb[AxisNo.OutRobot_Y].PosMode.Position := PlacingPos[iWorkingIndex].Y_Pos;
	uiExecutingStep:=2100;

2100: // Wait OutRobot XY arrive + sensor 'no box at conveyor stop' for a while
	tonTimeDelay(IN:=NOT SensorOnConveyor, PT:=T#1S);
	IF (arAxisStatus_gb[AxisNo.OutRobot_X].Admin._OpModeAck = ModePosAbs AND arAxisStatus_gb[AxisNo.OutRobot_X].Admin.CmdDone)
	AND (arAxisStatus_gb[AxisNo.OutRobot_Y].Admin._OpModeAck = ModePosAbs AND arAxisStatus_gb[AxisNo.OutRobot_Y].Admin.CmdDone)
	AND tonTimeDelay.Q
	THEN
		uiExecutingStep:=2150;
	ELSE
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0085);
		END_IF
	END_IF

2150: // Stop conveyor
	bMoveConveyorForward := FALSE;
	bMoveConveyorBackrward := FALSE;
	ConveyorMotor.M_MotorStop();
	IF ConveyorMotor.InStopped THEN
		uiExecutingStep:=2200;
	END_IF

2200: // Clip down (place) - Fix 2: 下爪前位置再確認
	IF NOT M_IsOutRobotAtPos(TargetPos:=PlacingPos[iWorkingIndex]) THEN
		_Abort := TRUE;
		uiResumeStep := uiExecutingStep;
		strStatus := M_FormatManagedStatus(
			AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
			InnerMessage := GVL_ErrorCode.GC_MSG_0173);
	ELSE
		IF bSyncPlace THEN
			Cylinders[0].M_Extend();
			Cylinders[1].M_Extend();
			bCylinderCheck := Cylinders[0].InFrontPosition AND Cylinders[1].InFrontPosition;
		ELSE
			Cylinders[iWorkingIndex].M_Extend();
			bCylinderCheck := Cylinders[iWorkingIndex].InFrontPosition;
		END_IF
		IF bCylinderCheck THEN
			uiExecutingStep:=2300;
		ELSE
			tonTimeOut(IN:=TRUE, PT:=T#15S);
			IF tonTimeOut.Q THEN
				_Abort := TRUE;
				uiResumeStep := uiExecutingStep;
				strStatus := M_FormatManagedStatus(
					AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
					InnerMessage := GVL_ErrorCode.GC_MSG_0051);
			END_IF
		END_IF
	END_IF

2300: // Clip open (place)
	IF bSyncPlace THEN
		Clips[0].M_Retract();
		Clips[1].M_Retract();
		bCylinderCheck := Clips[0].InRearPosition AND Clips[1].InRearPosition;
	ELSE
		Clips[iWorkingIndex].M_Retract();
		bCylinderCheck := Clips[iWorkingIndex].InRearPosition;
	END_IF
	IF bCylinderCheck THEN
		// Safety: 箱已放下
		IF bSyncPlace THEN
			bClipHasBox[0] := FALSE;
			bClipHasBox[1] := FALSE;
		ELSE
			bClipHasBox[iWorkingIndex] := FALSE;
		END_IF
		uiExecutingStep:=2400;
	ELSE
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0028);
		END_IF
	END_IF

2400: // Clip up (place)
	IF bSyncPlace THEN
		Cylinders[0].M_Retract();
		Cylinders[1].M_Retract();
		bCylinderCheck := Cylinders[0].InRearPosition AND Cylinders[1].InRearPosition;
	ELSE
		Cylinders[iWorkingIndex].M_Retract();
		bCylinderCheck := Cylinders[iWorkingIndex].InRearPosition;
	END_IF
	IF bCylinderCheck THEN
		uiExecutingStep:=2500;
	ELSE
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0052);
		END_IF
	END_IF

2500: // Next place? (修雙 clip 漏放 bug, 用 bPlacedA/B 旗標)
	IF bSyncPlace THEN
		bPlacedA := TRUE;
		bPlacedB := TRUE;
	ELSIF iWorkingIndex = 0 THEN
		bPlacedA := TRUE;
	ELSE
		bPlacedB := TRUE;
	END_IF
	IF UseA AND NOT bPlacedA THEN
		iWorkingIndex := 0;
		uiExecutingStep := 2000;
	ELSIF UseB AND NOT bPlacedB THEN
		iWorkingIndex := 1;
		uiExecutingStep := 2000;
	ELSE
		uiExecutingStep := 2600;
	END_IF

2600: // Move conveyor a bit until box detected at conveyor stop
	IF bMotorMoveForward THEN
		bMoveConveyorForward:=TRUE;
		bMoveConveyorBackrward:=FALSE;
	ELSE
		bMoveConveyorForward:=FALSE;
		bMoveConveyorBackrward:=TRUE;
	END_IF
	tonTimeDelay(IN:=NOT SensorOnConveyor, PT:=T#1S);
	IF tonTimeDelay.Q THEN
		uiExecutingStep:=2700;
	ELSE
		tonTimeOut(IN:=TRUE, PT:=T#15S);
		IF tonTimeOut.Q THEN
			_Abort := TRUE;
			uiResumeStep := uiExecutingStep;
			strStatus := M_FormatManagedStatus(
				AlarmId := GVL_ErrorCode.GC_ALARM_ALC_OUTROBOT_REVERSE,
				InnerMessage := GVL_ErrorCode.GC_MSG_0081);
		END_IF
	END_IF

2700: // Stop motor
	bMoveConveyorForward:=FALSE;
	bMoveConveyorBackrward:=FALSE;
	ConveyorMotor.M_MotorStop();
	IF ConveyorMotor.InStopped THEN
		uiExecutingStep:=3000;
	END_IF

3000: // Finish
	bMoveConveyorForward:=FALSE;
	bMoveConveyorBackrward:=FALSE;
	_Executed:=TRUE;

END_CASE

IF NOT Execute THEN
	eState:=STATE_RESETTING;
END_IF
IF _Error THEN
	eState:=STATE_ERROR;
END_IF
IF _Abort THEN
	eSTATE:=STATE_ABORTING;
END_IF
IF _Executed THEN
	eSTATE:=STATE_Done;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_RESETTING" Id="{d0b24ff8-a56a-4feb-b708-cdf4e67b731c}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD  M_STATE_RESETTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Error :=_Error;
Done :=_Executed;
Busy := FALSE;

// Timer 確保歸零
tonTimeOut(IN:=FALSE);
tonTimeDelay(IN:=FALSE);

CASE uiResettingStep OF

	0:
		IF __ISVALIDREF(ConveyorMotor) THEN
			ConveyorMotor.M_MotorStop();
		END_IF
		M_RecoveryAllObjects();
		uiResettingStep:=9999;

	9999:
		_ResetCompleted:=TRUE;
END_CASE

IF _ResetCompleted THEN
	eSTATE:=STATE_DORMANT;
END_IF]]></ST>
      </Implementation>
    </Method>
