<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_ShippingHoming" Id="{a389ff6d-2df6-446e-9dd8-b6fde818b220}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ShippingHoming EXTENDS FB_ActionBasic
VAR_INPUT
	xExecute 	: BOOL;
	xAbort 		: BOOL;
    FanucRobot 	: REFERENCE TO FB_FanucRobot_Basic_V2;
	Homed 		: REFERENCE TO BOOL;
	input		: REFERENCE TO ST_InputTable;
	Output		: REFERENCE TO ST_OutputTable;
	Service		: REFERENCE TO ST_ShippingService;
	Motor		: REFERENCE TO UNI_MotorList;
END_VAR
VAR_OUTPUT
	xAborted : BOOL;
	iErrorID : INT;
	ErrorMsg : STRING;
	RobotResetCMD : BOOL;
END_VAR
VAR
	StateBehaviour 		 : CBML.ETrigA;
	uiShippingHomingStep : UINT;
	FanucRobotCheckTon 	 	: TON;
	ResetRobotDelay 	 	: TON;
	TON_RobotFeedOutCommand : TON;
	TON_RobotTimeOut		: TON;
	fbExecuteEdgeDetect  :FB_EdgeDetect;
	_fbShippingRobot_TransmitCVEnd	: FB_ShippingRobot_TransmitCVEnd;
	TON_RobotRSR01_Delay	: TON;
	
	//Reboot RobotPower
	TON_RebootPowerDelay	: TON;
	TON_ConnectionTimeout	: TON;

	// 啟動延時 - 等待心跳偵測完成 (冷啟動用)
	TON_StartupDelay		: TON;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[A00_BasicUnits();
THIS^.IBehaviourModel := StateBehaviour;
StateBehaviour(xExecute := xExecute,
    xDone => xDone,
    xBusy => xBusy,
    xError => xError,
    xAbort := xAbort OR fbExecuteEdgeDetect.xFallingEdge,
    xAborted => xAborted);

//Error Msg
iErrorID := StateBehaviour._model.iErrorID;
ErrorMsg := M_GetErrorMsg(xErrorID := iErrorID);


//Make sure that C# turns off execute to shut down the service
fbExecuteEdgeDetect(xInput :=xExecute);

]]></ST>
    </Implementation>
    <Folder Name="STATE" Id="{1365c42e-775f-4446-b7f3-b637cf99fa35}" />
    <Action Name="A00_BasicUnits" Id="{65956791-bb1c-4454-8bf6-252f96cc4a15}">
      <Implementation>
        <ST><![CDATA[FanucRobotCheckTon(PT := T#90S);		//All Service TimeOut
ResetRobotDelay(PT:=T#300MS);
TON_RobotFeedOutCommand(PT:= T#5S);		//Robot FeedOut Command TimeOut
TON_RobotTimeOut(PT := T#60S);			//Robot FeedOut Service Done Time
TON_RobotRSR01_Delay(PT :=T#3S);
TON_RebootPowerDelay(PT :=T#5S);		// 電源 TRUE 維持 5 秒 (與大手臂同步，避免 24V 電容殘電造成假性斷電)
TON_ConnectionTimeout(PT :=T#60S);
TON_StartupDelay(PT :=T#5S);			// 啟動延時 5 秒 (等待心跳偵測冷啟動完成)


_fbShippingRobot_TransmitCVEnd(
	Execute:= , 
	Abort:= , 
	Reset:= , 
	ObjectName:= , 
	Busy=> , 
	Done=> , 
	Aborted=> , 
	Error=> , 
	ErrorID=> , 
	Status=> , 
	UniqueErrorCode=> , 
	Robot:= fanucrobot, 
	Info:= , 
	Stop:= , 
	INPUT:= input, 
	Motor:= Motor, 
	bCompleteRequest:= ,
	fbSHippingHomingBusy := THIS^.xBusy);]]></ST>
      </Implementation>
    </Action>
    <Method Name="CleanupAction" Id="{a9bf4c7a-fb5a-479a-be39-ca47cb1eb669}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD CleanupAction
VAR_INPUT
    xAbortProposed : BOOL;
    iErrorIDProposed: INT;
END_VAR
VAR_OUTPUT
    xComplete : BOOL := TRUE;
    xAbort: BOOL := xAbortProposed;
 	iErrorID : INT := iErrorIDProposed;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[RobotResetCMD := FALSE;
FanucRobotCheckTon.IN := FALSE;
uiShippingHomingStep := 0;]]></ST>
      </Implementation>
    </Method>
    <Method Name="CyclicAction" Id="{28efe66c-9769-402b-bc55-7d1c861b50ec}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD CyclicAction
VAR_INPUT
    itfTimingController : CBML.ITimingController;
END_VAR
VAR_OUTPUT
    xComplete : BOOL := TRUE;
    iErrorID : INT := 0;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[xComplete := FALSE;
CASE uiShippingHomingStep OF
	
	0:		//init
			TON_RobotFeedOutCommand.IN  := FALSE;
			TON_RobotTimeOut.IN 		:= FALSE;
			FanucRobotCheckTon.IN 		:= TRUE;
			uiShippingHomingStep 	    := 5;

	// ============================================================================
	// Step 5: 啟動延時 - 等待心跳偵測完成
	// - 冷啟動時，心跳偵測需要 5 秒 (10 × 0.5s) 才能判定連線狀態
	// - 必須等心跳偵測完成後，才能正確判斷機器人是否已連線，避免誤觸發電源循環
	// ============================================================================
	5:
			TON_StartupDelay.IN := TRUE;
			IF TON_StartupDelay.Q THEN
				TON_StartupDelay.IN := FALSE;
				uiShippingHomingStep := 10;
			END_IF

	10:		// 檢查機械手臂 錯誤狀態
			// 斷線判定: EIP scanner 報斷線 OR 軟體心跳 5 秒未翻轉 (iTestCnt >= 10)
			IF fanucrobot._EIPConnectionState = 8195 OR fanucrobot.iTestCnt >= 10 THEN
				FanucRobotCheckTon.IN := FALSE;					// 暫停 90 秒總超時，避免電源循環中誤觸發
				Output.bShipping_FanucRobotPower := TRUE;
				uiShippingHomingStep := 20;
			ELSIF fanucrobot.Halt THEN
				// Robot 在 Halt 狀態 → 清除 Hold 讓 Halt 解除，再 Reset 回 DORMANT
				fanucrobot.Hold := FALSE;
				fanucrobot.Reset := TRUE;
				ResetRobotDelay.IN := TRUE;
			ELSIF fanucrobot.Error THEN
				uiShippingHomingStep := 50;
			ELSIF fanucrobot._UO1.UO03_PrgRunning THEN
				// Robot 正在執行流程 → 強制停止後再切 RSR02
				fanucrobot.M_ResetAllCommand();
				fanucrobot.Hold := FALSE;
				fanucrobot.Reset := TRUE;
				ResetRobotDelay.IN := TRUE;
			ELSE
				uiShippingHomingStep := 500;
			END_IF
			IF ResetRobotDelay.Q THEN
				ResetRobotDelay.IN := FALSE;
				fanucrobot.Reset := FALSE;
				uiShippingHomingStep := 500;
			END_IF

	20:		// 電源 TRUE 維持 5 秒後切回 FALSE 重啟小手臂
			TON_RebootPowerDelay.IN :=TRUE;
			IF TON_RebootPowerDelay.Q THEN
				Output.bShipping_FanucRobotPower := FALSE;
				uiShippingHomingStep := 30;
			END_IF

	30:
			TON_RebootPowerDelay.IN  := FALSE;
			TON_ConnectionTimeout.IN := TRUE;
			IF TON_ConnectionTimeout.Q THEN
				// 超時 60 秒，連線失敗
				TON_ConnectionTimeout.IN := FALSE;
				iErrorID := 30;
				uiShippingHomingStep := 9999;
			ELSIF fanucrobot._EIPConnectionState <> 8195 AND fanucrobot.iTestCnt < 10 THEN
				// EIP 已重連 + 心跳已恢復，繼續檢查錯誤
				TON_ConnectionTimeout.IN := FALSE;
				FanucRobotCheckTon.IN := TRUE;					// 恢復 90 秒總超時監控
				uiShippingHomingStep := 50;
			END_IF
	
	50:
			IF FanucRobot.Error THEN
				RobotResetCMD := TRUE;
				ResetRobotDelay.IN:=TRUE;
			ELSE
				uiShippingHomingStep := 500;
			END_IF
			IF ResetRobotDelay.Q THEN
				ResetRobotDelay.IN :=FALSE;
				uiShippingHomingStep := 500;
			END_IF
		
		
	500:	// 手臂 RSR02 回原點
			ResetRobotDelay.IN := FALSE;
			RobotResetCMD := FALSE;
			FanucRobot.OpMode := E_FanucRobotOpMode.RSR02;
			IF FanucRobot.Error THEN
				RobotResetCMD := TRUE;		
			END_IF
			IF FanucRobot._RSR2_Completed THEN
				uiShippingHomingStep := 600;
			END_IF
			
	600:	// 回完回點後切換為 RSR01 工作模式
			FanucRobot.OpMode := E_FanucRobotOpMode.RSR01;
			IF FanucRobot._RSR1_Ready THEN
				uiShippingHomingStep := 1000;
			END_IF
			// RSR02 完成後，檢查是否還有殘留錯誤
			IF FanucRobot.Error THEN
				iErrorID := 21;		// RSR02 完成但錯誤仍存在
			END_IF
		
	1000:	// 確認手臂切換到 RSR01 模式，並且確保已回報 PLC 正在執行 RSR01
			IF FanucRobot.OpMode = E_FanucRobotOpMode.RSR01 AND 
				NOT FanucRobot._DI1.Done AND 
				FanucRobot._DI12.RSR1_Active 
			THEN
				uiShippingHomingStep := 1200;
			END_IF
			
	1200:	// 檢查手臂夾具的開合狀態
			TON_RobotRSR01_Delay.IN := FALSE;
			IF NOT fanucRobot._DI1.ClampA_Open THEN
				uiShippingHomingStep := 2000;
			ELSE
				uiShippingHomingStep := 9000;
			END_IF
			
	2000:	// 同尺寸軌道 busy Check
			TON_RobotFeedOutCommand.IN := TRUE;
			_fbShippingRobot_TransmitCVEnd.M_StartHomingFeedOut(UseA := TRUE);
			IF _fbShippingRobot_TransmitCVEnd.Busy THEN
				uiShippingHomingStep := 2100;
			END_IF
			IF TON_RobotFeedOutCommand.Q THEN
				iErrorID := 10;
			END_IF
	
	2100:	// 同尺寸軌道 done Check
			TON_RobotFeedOutCommand.IN := FALSE;
			TON_RobotTimeOut.IN := TRUE;
			IF _fbShippingRobot_TransmitCVEnd.Done THEN
				_fbShippingRobot_TransmitCVEnd.M_ResetHomingFeedOut();		
				uiShippingHomingStep := 0;
			END_IF
			IF TON_RobotTimeOut.Q THEN
				iErrorID := 11;
			END_IF

	9000:	// process done
			FanucRobotCheckTon.IN := FALSE;
			Homed := TRUE;
			xComplete := TRUE;
END_CASE

IF FanucRobotCheckTon.Q THEN
	iErrorID := 4;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="ExitAction" Id="{86b170ea-633a-43c7-8939-5f6563235fb3}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD ExitAction
VAR_INPUT
    xAfterCleanup : BOOL;
    xInCopyCode : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetErrorMsg" Id="{eeb0349d-35ae-4ab3-9b91-413106917694}">
      <Declaration><![CDATA[METHOD M_GetErrorMsg : T_MaxString
VAR_INPUT
	xErrorID: INT;
END_VAR

VAR
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE xErrorID OF
    0:
        M_GetErrorMsg := 'No Error';
    1:
        M_GetErrorMsg := 'FB_ShippingHoming ErrorID 1: Action time out';
    2:
        M_GetErrorMsg := 'FB_ShippingHoming ErrorID 2: Cylinder not ready';
    3:
        M_GetErrorMsg := 'FB_ShippingHoming ErrorID 3: Motor not ready';
    4:
		M_GetErrorMsg := 'FB_ShippingHoming ErrorID 4: FanucRobot can not homing';
	10:
		M_GetErrorMsg := 'FB_ShippingHoming ErrorID 10: Shipping FanucRobot FeedOut to SameSizeConveyor not busy';
	11:
		M_GetErrorMsg := 'FB_ShippingHoming ErrorID 11: Shipping FanucRobot FeedOut to SameSizeConveyor Done Timeout';
	20:
		M_GetErrorMsg := 'FB_ShippingHoming ErrorID 20: Occupid , AutoMode_ShippingRobot_TransmitCVEnd in Executing ';
	21:
		M_GetErrorMsg := 'FB_ShippingHoming ErrorID 21: RSR02 Complete but FanucRobot still in Error';
	30:
		M_GetErrorMsg := 'FB_ShippingHoming ErrorID 30: Reboot ShippingArea FanucRobot Connect TimeOut';

END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="ResetAction" Id="{29de0fe6-dff5-463d-8b62-34c704f43cf6}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD ResetAction
VAR_OUTPUT
    xComplete : BOOL := TRUE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[FanucRobotCheckTon.IN := FALSE;
TON_RobotRSR01_Delay.IN	:= FALSE;
TON_RebootPowerDelay.IN := FALSE;
TON_ConnectionTimeout.IN := FALSE;
TON_StartupDelay.IN		:= FALSE;
_fbShippingRobot_TransmitCVEnd.M_ResetHomingFeedOut();]]></ST>
      </Implementation>
    </Method>
    <Method Name="StartAction" Id="{f811c667-2a87-41b8-8549-fe57f7889dab}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD StartAction
VAR_OUTPUT
    xComplete : BOOL := TRUE;
	iErrorID : INT := 0;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[Homed := FALSE;
FanucRobotCheckTon.IN 		:= FALSE;
ResetRobotDelay.IN 			:= FALSE;
TON_RobotFeedOutCommand.IN 	:= FALSE;
TON_RobotTimeOut.IN 		:= FALSE;
TON_RobotRSR01_Delay.IN		:= FALSE;
TON_RebootPowerDelay.IN		:= FALSE;
TON_ConnectionTimeout.IN	:= FALSE;
TON_StartupDelay.IN			:= FALSE;
uiShippingHomingStep := 0;
_fbShippingRobot_TransmitCVEnd.M_ResetHomingFeedOut();

IF  Service.AutoMode_ShippingRobot_TransmitCVEnd.Command.Execute AND
	Service.AutoMode_ShippingRobot_TransmitCVEnd.Status.Busy AND
	Service.AutoMode_ShippingRobot_TransmitCVEnd.Status.Error 
THEN
	iErrorID := 20;
END_IF
]]></ST>
      </Implementation>
    </Method>
