<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_ShippingPlateScan" Id="{b8f3c14a-9d6b-4e7a-8c52-1f29a4b8e36d}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ShippingPlateScan EXTENDS FB_ObjectBase_V2
VAR_INPUT
	Robot			: REFERENCE TO FB_FanucRobot_Basic_V2;
	Motor			: REFERENCE TO UNI_MotorList;			// 同尺寸軌道馬達 (Phase 2:只讀 InBackWard 狀態,不直接驅動)
	Cylinder		: REFERENCE TO UNI_CylinderList;		// Press1 / Press3 一次性伸出用
	SameSizeCVRequest	: REFERENCE TO ST_SameSizeCVRequest;	// Phase 2 仲裁:寫 bScan_NeedBackward,由 FB_MachineControl.A20_ConveyorArbitration 仲裁
	SameSizeCV_Press1_AlreadyExtended : REFERENCE TO BOOL;	// 一次性 latch (Press1):FALSE = 還沒伸過,本 FB 伸出後置 TRUE;TRUE = 跳過避免重伸
	SameSizeCV_Press3_AlreadyExtended : REFERENCE TO BOOL;	// 一次性 latch (Press3):同上
	Input			: REFERENCE TO ST_InputTable;			// SameSizeCV BoxNearShipping sensor
	Side			: E_ShippingPlateSide;		// Left=0 / Right=1
	PlateIndex		: E_ShippingPlateIndex;		// Plate1..Plate4 (enum 值 = 手臂 Position)
	ReadComplete	: BOOL;						// 上位讀完 PlateHasBox 後回 TRUE
END_VAR
VAR_OUTPUT
	PlateHasBox		: BOOL;		// Robot._DI13.9 (bClampA1_Laser_DetectStatus)
	FeedBack		: BOOL;		// 做完待上位讀,等 ReadComplete (做完才給,不是掃完)
END_VAR
VAR
	Area						: E_RobotArea;
	Address_A					: INT;

	TON_RobotActionTimeOut		: TON;
	TON_CheckRobotDoneTimeOut	: TON;
	TON_ScanTimeOut				: TON;
	TON_MechTimeOut				: TON;		// 軌道機構動作 watchdog (30s)
	tonBoxArriveDelay			: TON;		// Put 階段等盒到位 debounce (1s)

	// Resume / Retry framework (對齊 FB_ShippingRobotTransfer 續做 pattern)
	uiResumeStep				: UDINT;	// retry / 續做進入點
	_bRetry						: BOOL;		// STATE_ABORTED 收到 Reset 後置 TRUE,觸發 retry
	_bAbsMoveStarted			: BOOL;		// 真的呼叫過 M_StartRobotAbsMove 才置 TRUE,防 stale Done 造成 ghost completion (對齊 FB_ShippingRobotTransfer)
	strStatus					: STRING;
	_UniqueErrorCode			: STRING;
	PreviousStrStatus			: STRING;
	PreviousErrorCode			: STRING;

	// Error blinking (Reset 後閃爍 1 秒,避開瞬間錯誤閃爍)
	trigErrorReset				: R_TRIG;
	tonErrorResetDelay			: TON;
	bErrorBlinking				: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[A00_BasicUnits();
SUPER^.A10_StateControl();
]]></ST>
    </Implementation>
    <Folder Name="Method" Id="{a26b48e0-3b91-4d33-9a55-7e2c8d1f4b6a}" />
    <Folder Name="STATE" Id="{f73d92c1-4a8b-4e5c-b182-3d6f8a9e7c14}" />
    <Action Name="A00_BasicUnits" Id="{d4e8b2a9-7f1c-4b65-9a83-2e5d6c4f1b8a}">
      <Implementation>
        <ST><![CDATA[TON_RobotActionTimeOut(PT := T#60S);
TON_CheckRobotDoneTimeOut(PT := T#30S);
TON_ScanTimeOut(PT := T#30S);
TON_MechTimeOut(PT := T#30S);
tonBoxArriveDelay(PT := T#1S);

// Phase 2:軌道驅動移到 FB_MachineControl.A20_ConveyorArbitration,本 FB 只寫 SameSizeCVRequest.bScan_NeedBackward。]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_ResolveAddress" Id="{c5a8d319-6e2f-4b7c-8d4a-9f1e3b6c5d72}" FolderPath="Method\">
      <Declaration><![CDATA[METHOD PRIVATE M_ResolveAddress : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Side → Area
CASE Side OF
	E_ShippingPlateSide.Left:
		Area := E_RobotArea.ShippingRobotLeft;
	E_ShippingPlateSide.Right:
		Area := E_RobotArea.ShippingRobotRight;
ELSE
	strStatus := 'FB_ShippingPlateScan: invalid Side enum, not can retry';
	M_ResolveAddress := FALSE;
	RETURN;
END_CASE

// PlateIndex → Address (enum value 1..4 直接 = Position)
CASE PlateIndex OF
	E_ShippingPlateIndex.Plate1: Address_A := 1;
	E_ShippingPlateIndex.Plate2: Address_A := 2;
	E_ShippingPlateIndex.Plate3: Address_A := 3;
	E_ShippingPlateIndex.Plate4: Address_A := 4;
ELSE
	strStatus := 'FB_ShippingPlateScan: invalid PlateIndex enum, not can retry';
	M_ResolveAddress := FALSE;
	RETURN;
END_CASE

// Get=TRUE 需要爪是開的 (否則手臂在抓時會撞)
IF NOT Robot._DI1.ClampA_Open THEN
	strStatus := 'FB_ShippingPlateScan: ClampA must be open for scan/get';
	M_ResolveAddress := FALSE;
	RETURN;
END_IF

M_ResolveAddress := TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTED" Id="{a1d92e34-5b8c-4f7d-8e6a-9c2b4d5e7f1a}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_ABORTED
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT _bRetry THEN
	Busy    := FALSE;
	Error   := TRUE;
	Aborted := TRUE;
	uiAbortingStep  := 0;
	_AbortCompleted := FALSE;
END_IF

IF Reset THEN
	_bRetry := TRUE;
	Error   := FALSE;
	Aborted := FALSE;
END_IF

IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF Execute AND _bRetry AND NOT Robot._DI1.Error THEN
	// 續做:從上次 uiResumeStep 標的失敗點接續
	uiExecutingStep   := uiResumeStep;
	PreviousStrStatus := strStatus;
	PreviousErrorCode := _UniqueErrorCode;
	Status            := 'FB_ShippingPlateScan: no error';
	_bRetry           := FALSE;
	_bAbsMoveStarted  := FALSE;	// retry 進 EXECUTING 前清掉,讓 step 3100 ELSIF stale-Done 防護生效
	eState            := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ABORTING" Id="{b2e83f45-6c9d-4a8b-9f7c-8d3e5a6b9c2d}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_ABORTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// 對齊 FB_ShippingRobotTransfer ABORTING:reset robot 命令 → 等 Done 降 → Robot Error Recovery 循環
CASE uiAbortingStep OF
	0:
		_Abort := FALSE;
		Abort  := FALSE;
		TON_RobotActionTimeOut.IN    := FALSE;
		TON_CheckRobotDoneTimeOut.IN := FALSE;
		TON_ScanTimeOut.IN           := FALSE;
		TON_MechTimeOut.IN           := FALSE;
		tonBoxArriveDelay.IN         := FALSE;
		// 撤銷軌道請求 (arbiter 看到沒人 request 會自動停)
		IF __ISVALIDREF(SameSizeCVRequest) THEN
			SameSizeCVRequest.bScan_NeedBackward := FALSE;
		END_IF
		_bAbsMoveStarted := FALSE;
		// 中斷 robot AbsMove 命令,避免 abort 期間 robot 還在跑舊軌跡
		Robot.M_ResetRobotAbsMove(TRUE, FALSE);
		uiAbortingStep := 50;

	50:	// 等 robot 命令真的被 reset 掉 (Done 降) 再進入錯誤檢查
		TON_CheckRobotDoneTimeOut.IN := TRUE;
		IF NOT Robot._DI1.Done THEN
			TON_CheckRobotDoneTimeOut.IN := FALSE;
			uiAbortingStep := 100;
		ELSIF TON_CheckRobotDoneTimeOut.Q THEN
			// reset 超時也繼續,後續 step 100 會處理 Robot.Error 路徑
			TON_CheckRobotDoneTimeOut.IN := FALSE;
			uiAbortingStep := 100;
		END_IF

	100:	// 看 robot 自己是否在 Error 狀態,需 robot error recovery
		IF Robot._DI1.Error THEN
			uiAbortingStep := 200;
		ELSE
			uiAbortingStep := 9999;
		END_IF

	200:	// Robot Error Recovery:對 robot 下 Reset 命令
		IF DAS_CoreSys.MachineControl.M_ShippingRobotResetCmd() THEN
			uiAbortingStep := 300;
		END_IF

	300:	// 對 robot 下 Start 命令重啟 prog
		IF DAS_CoreSys.MachineControl.M_ShippingRobotStartCmd() THEN
			uiAbortingStep := 400;
		END_IF

	400:	// 確認 robot 已脫離 error,還有就再循環一次
		IF Robot._DI1.Error THEN
			uiAbortingStep := 200;
		ELSE
			uiAbortingStep := 9999;
		END_IF

	9999:
		_AbortCompleted := TRUE;
END_CASE

IF _AbortCompleted THEN
	eState := STATE_ABORTED;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DONE" Id="{c3f94a56-7d8b-4e9c-9a3d-7e4f8b5c6d3e}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_DONE
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy   := FALSE;
_Error := Error := FALSE;
_Abort := Abort := FALSE;
Done   := TRUE;

// Phase 2:撤銷軌道請求 (arbiter 仲裁,本 FB 不直接停 motor — 其他 FB 還在 request 時不應被影響)
IF __ISVALIDREF(SameSizeCVRequest) THEN
	SameSizeCVRequest.bScan_NeedBackward := FALSE;
END_IF

IF NOT Execute THEN
	eState := STATE_RESETTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_DORMANT" Id="{d4a95b67-8e9c-4f1d-8b4e-7f5a9b6c8d4f}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_DORMANT
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy            := FALSE;
Done            := FALSE;
Aborted         := FALSE;
Error           := FALSE;
Paused          := FALSE;
ErrorID         := 0;
Status          := '';
UniqueErrorCode := '';

_Executed         := FALSE;
_Error            := FALSE;
_Abort            := FALSE;
_ResetCompleted   := FALSE;
_AbortCompleted   := FALSE;
_HoldingCompleted := FALSE;
_HeldCompleted    := FALSE;
_UnholdCompleted  := FALSE;
_bRetry           := FALSE;
_bAbsMoveStarted  := FALSE;

uiExecutingStep := 0;
uiResettingStep := 0;
uiAbortingStep  := 0;
uiHoldingStep   := 0;
uiHeldStep      := 0;
uiUnholdStep    := 0;
uiResumeStep    := 0;

TON_RobotActionTimeOut.IN    := FALSE;
TON_CheckRobotDoneTimeOut.IN := FALSE;
TON_ScanTimeOut.IN           := FALSE;
TON_MechTimeOut.IN           := FALSE;
tonBoxArriveDelay.IN         := FALSE;

// Phase 2:撤銷軌道請求
IF __ISVALIDREF(SameSizeCVRequest) THEN
	SameSizeCVRequest.bScan_NeedBackward := FALSE;
END_IF

PlateHasBox := FALSE;
FeedBack    := FALSE;

PreviousStrStatus := '';
PreviousErrorCode := '';
_UniqueErrorCode  := '0';
bErrorBlinking    := FALSE;
tonErrorResetDelay.IN := FALSE;

IF Execute THEN
	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_ERROR" Id="{e5b96c78-9f1d-4a2e-9c5f-8e6a7b8c9d5a}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_ERROR
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Error  := TRUE;
Busy   := FALSE;
_Error := FALSE;
Status := strStatus;

// Reset 上升緣 → 1 秒閃爍 + retry 觸發 (與 FB_ShippingRobotTransfer 對齊)
trigErrorReset(CLK := Reset);
IF trigErrorReset.Q THEN
	bErrorBlinking := TRUE;
END_IF
tonErrorResetDelay(IN := bErrorBlinking, PT := T#1S);
IF tonErrorResetDelay.Q THEN
	bErrorBlinking := FALSE;
END_IF
IF bErrorBlinking THEN
	Error := FALSE;
END_IF

IF NOT Execute THEN
	Error  := FALSE;
	bErrorBlinking := FALSE;
	tonErrorResetDelay.IN := FALSE;
	eState := STATE_RESETTING;
ELSIF trigErrorReset.Q AND Execute AND NOT Robot._DI1.Error THEN
	// Retry 對稱:Reset 上升緣 (edge) 才觸發,避免 Reset 持續 TRUE 多 cycle 重複切換造成 race
	uiExecutingStep   := uiResumeStep;
	PreviousStrStatus := strStatus;
	PreviousErrorCode := _UniqueErrorCode;
	Status            := 'FB_ShippingPlateScan: no error';
	Error             := FALSE;
	bErrorBlinking    := FALSE;
	tonErrorResetDelay.IN := FALSE;
	_bAbsMoveStarted  := FALSE;	// retry 進 EXECUTING 前清掉,讓 step 3100 ELSIF stale-Done 防護生效
	eState            := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_EXECUTING" Id="{f6ca7d89-a12e-4b3f-8d6a-9f7b8c9d6e5b}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_EXECUTING
VAR_INPUT
END_VAR
VAR_INST
	bScanCompleted		: BOOL;		// A2 升 → 已讀 A1 latch,防 A2 transient 重複讀
	bAllowContinue		: BOOL;		// 掃到盒子才 TRUE,送到 _DO3.bContinue 讓手臂繼續夾
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy := TRUE;

// 暫停
IF Pause THEN
	_HoldingCompleted := FALSE;
	_HeldCompleted    := FALSE;
	_UnholdCompleted  := FALSE;
	uiHoldingStep := 0;
	uiHeldStep    := 0;
	uiUnholdStep  := 0;
	eState := STATE_Holding;
	RETURN;
END_IF

CASE uiExecutingStep OF

	0:	// 命令驗證 + Side→Area + PlateIndex→Address_A
		IF M_ResolveAddress() THEN
			bScanCompleted := FALSE;
			bAllowContinue := FALSE;
			IF __ISVALIDREF(SameSizeCVRequest) THEN
				SameSizeCVRequest.bScan_NeedBackward := FALSE;
			END_IF
			uiExecutingStep := 100;
		ELSE
			Status           := strStatus;
			_UniqueErrorCode := 'E_INVALID_CMD';
			uiResumeStep     := 0;
			_Error := TRUE;
		END_IF

	100:	// Press1 + Press3 一次性伸出 (擋盒避免回流壓到前盒) — 平行處理,兩個都到位才走
			// 用 FB_MachineControl.bSameSizeCV_Press*_AlreadyExtended REFERENCE 做 latch:FALSE → 伸出 + 置 TRUE;TRUE → 跳過
		IF __ISVALIDREF(Cylinder)
		   AND __ISVALIDREF(SameSizeCV_Press1_AlreadyExtended)
		   AND __ISVALIDREF(SameSizeCV_Press3_AlreadyExtended) THEN
			IF SameSizeCV_Press1_AlreadyExtended AND SameSizeCV_Press3_AlreadyExtended THEN
				// 兩個都已 latch,直接跳
				TON_MechTimeOut.IN := FALSE;
				uiExecutingStep := 1000;
			ELSE
				TON_MechTimeOut.IN := TRUE;
				// Press1
				IF NOT SameSizeCV_Press1_AlreadyExtended THEN
					Cylinder.List.fbSameSizeCV_Press1.M_Extend();
					IF Cylinder.List.fbSameSizeCV_Press1.InFrontPosition THEN
						SameSizeCV_Press1_AlreadyExtended := TRUE;
					END_IF
				END_IF
				// Press3
				IF NOT SameSizeCV_Press3_AlreadyExtended THEN
					Cylinder.List.fbSameSizeCV_Press3.M_Extend();
					IF Cylinder.List.fbSameSizeCV_Press3.InFrontPosition THEN
						SameSizeCV_Press3_AlreadyExtended := TRUE;
					END_IF
				END_IF
				// 兩個都到位 → 跳 step 1000
				IF SameSizeCV_Press1_AlreadyExtended AND SameSizeCV_Press3_AlreadyExtended THEN
					TON_MechTimeOut.IN := FALSE;
					uiExecutingStep := 1000;
				END_IF
				IF TON_MechTimeOut.Q THEN
					uiResumeStep := 100;
					strStatus := 'FB_ShippingPlateScan Step 100: Press1/Press3 extend timeout';
					Status := strStatus;
					_UniqueErrorCode := 'E_PRESS_TIMEOUT';
					_Abort := TRUE;
				END_IF
			END_IF
		ELSE
			// ref 無效 (容錯),直接跳到正式流程
			TON_MechTimeOut.IN := FALSE;
			uiExecutingStep := 1000;
		END_IF

	1000:	// 送一次 AbsMove(BoxReady=FALSE) → 手臂走到 safe pos 等 continue 開始掃描
		TON_ScanTimeOut.IN := TRUE;		// 等 A2 掃完旗標 watchdog (給 step 1100 用)

		Robot.M_StartRobotAbsMove(
			GetBox         := TRUE,
			UseClampA      := TRUE,
			UseClampB      := FALSE,
			Area           := Area,
			ClampA_Address := Address_A,
			ClampB_Address := 0,
			BoxReady_1     := FALSE,	// 還沒掃完不下 continue
			BoxReady_2     := FALSE);
		uiExecutingStep := 1100;

		IF Robot._DI1.Error THEN
			uiResumeStep := 1000;
			strStatus := CONCAT('FB_ShippingPlateScan Step 1000: Robot error ', Robot.ErrMsg);
			Status := strStatus;
			_UniqueErrorCode := 'E_ROBOT_ERROR';
			_Abort := TRUE;
		END_IF

	1100:	// 等 A2 (掃描完成旗標) → 讀 A1 latch PlateHasBox (FeedBack 不在這給,做完才給)
		IF Robot.bClampA2_Laser_DetectStatus THEN
			PlateHasBox    := Robot.bClampA1_Laser_DetectStatus;
			bScanCompleted := TRUE;
			TON_ScanTimeOut.IN := FALSE;
			IF NOT PlateHasBox THEN
				// 沒盒 → 跳過取盒/放盒/軌道,直接 step 5000 reset robot 後收尾
				uiExecutingStep := 5000;
			ELSE
				bAllowContinue := TRUE;
				uiExecutingStep := 2000;
			END_IF
		END_IF

		// 早 fail:手臂已 Done 但 A2 從未升起 (Pause 期間手臂跑完命令 / robot prog bug)
		IF Robot._DI1.Done AND NOT bScanCompleted THEN
			uiResumeStep := 1000;
			strStatus := 'FB_ShippingPlateScan Step 1100: Robot done but scan flag (A2) never raised, can retry';
			Status := strStatus;
			_UniqueErrorCode := 'E_SCAN_MISSED';
			_Abort := TRUE;
		END_IF
		IF TON_ScanTimeOut.Q THEN
			uiResumeStep := 1000;	// retry 整個 AbsMove + 掃描流程
			strStatus := 'FB_ShippingPlateScan Step 1100: Scan complete (A2) timeout, can retry';
			Status := strStatus;
			_UniqueErrorCode := 'E_SCAN_TIMEOUT';
			_Abort := TRUE;
		END_IF
		IF Robot._DI1.Error THEN
			uiResumeStep := 1000;
			strStatus := CONCAT('FB_ShippingPlateScan Step 1100: Robot error ', Robot.ErrMsg);
			Status := strStatus;
			_UniqueErrorCode := 'E_ROBOT_ERROR';
			_Abort := TRUE;
		END_IF

	2000:	// 送一次 AbsMove(BoxReady=TRUE) → 手臂收 continue 訊號繼續夾取 → 等 Robot.Done
		TON_RobotActionTimeOut.IN := TRUE;		// 等 Robot.Done watchdog

		Robot.M_StartRobotAbsMove(
			GetBox         := TRUE,
			UseClampA      := TRUE,
			UseClampB      := FALSE,
			Area           := Area,
			ClampA_Address := Address_A,
			ClampB_Address := 0,
			BoxReady_1     := TRUE,		// 下 continue,手臂繼續夾
			BoxReady_2     := FALSE);

		IF Robot._DI1.Done THEN
			TON_RobotActionTimeOut.IN := FALSE;
			uiExecutingStep := 2100;
		END_IF

		IF TON_RobotActionTimeOut.Q THEN
			uiResumeStep := 2000;
			strStatus := 'FB_ShippingPlateScan Step 2000: Robot fetch timeout, can retry';
			Status := strStatus;
			_UniqueErrorCode := 'E_FETCH_TIMEOUT';
			_Abort := TRUE;
		END_IF
		IF Robot._DI1.Error THEN
			uiResumeStep := 2000;
			strStatus := CONCAT('FB_ShippingPlateScan Step 2000: Robot error ', Robot.ErrMsg);
			Status := strStatus;
			_UniqueErrorCode := 'E_ROBOT_ERROR';
			_Abort := TRUE;
		END_IF

	2100:	// Reset FROM AbsMove → 等 Robot.Done 降 (手臂從鐵盤離開準備放盒)
		Robot.M_ResetRobotAbsMove(TRUE, FALSE);
		TON_CheckRobotDoneTimeOut.IN := TRUE;
		IF NOT Robot._DI1.Done THEN
			TON_CheckRobotDoneTimeOut.IN := FALSE;
			uiExecutingStep := 3000;
		END_IF
		IF TON_CheckRobotDoneTimeOut.Q THEN
			uiResumeStep := 2100;
			strStatus := 'FB_ShippingPlateScan Step 2100: Wait Robot done (after fetch) timeout';
			Status := strStatus;
			_UniqueErrorCode := 'E_ROBOT_DONE_TIMEOUT';
			_Error := TRUE;
		END_IF

	// ===========================================================
	// Phase 2 (TO):放盒到同尺寸軌道 TransmitCV_End Pos 1 SameSize
	// 對齊 FB_ShippingRobotTransfer step 10300/15000/15100/20000
	// ===========================================================
	3000:	// TO 前置:請求 backward (arbiter 驅動) + 等放盒位 sensor 清空
		IF __ISVALIDREF(SameSizeCVRequest) THEN
			SameSizeCVRequest.bScan_NeedBackward := TRUE;
		END_IF
		TON_MechTimeOut.IN := TRUE;
		IF __ISVALIDREF(Motor) AND Motor.List.TransmitSameSideCV.InBackWard
		   AND NOT Input.bSameSizeCV_BoxNearShippingSensor THEN
			TON_MechTimeOut.IN := FALSE;
			uiExecutingStep := 3100;
		END_IF
		IF TON_MechTimeOut.Q THEN
			uiResumeStep := 3000;
			strStatus := 'FB_ShippingPlateScan Step 3000: SameSizeCV backward / sensor clear timeout';
			Status := strStatus;
			_UniqueErrorCode := 'E_CV_BACKWARD_TIMEOUT';
			_Abort := TRUE;
		END_IF

	3100:	// AbsMove 到 TransmitCV_End Pos 1 放盒
			// Put 場景:step 3000 已驗證軌道反轉 + sensor 清,BoxReady 直接 TRUE (對齊 FB_ShippingRobotTransfer 15000 Put 分支)
			// _bAbsMoveStarted 防 ghost completion:step 2100 ResetAbsMove 後 Done 可能殘留 TRUE
		TON_RobotActionTimeOut.IN := TRUE;
		IF NOT Robot._DI1.Done THEN
			Robot.M_StartRobotAbsMove(
				GetBox         := FALSE,
				UseClampA      := TRUE,
				UseClampB      := FALSE,
				Area           := E_RobotArea.TransmitCV_End,
				ClampA_Address := 1,
				ClampB_Address := 0,
				BoxReady_1     := TRUE,
				BoxReady_2     := FALSE);
			_bAbsMoveStarted := TRUE;
		ELSIF NOT _bAbsMoveStarted THEN
			// Done=TRUE 但從未送過 Start → stale (step 2100 殘留),清掉 robot 命令等 Done 降
			Robot.M_ResetRobotAbsMove(TRUE, FALSE);
		ELSE
			// 真的完成 (Done 從 FALSE → TRUE)
			TON_RobotActionTimeOut.IN := FALSE;
			_bAbsMoveStarted          := FALSE;
			uiExecutingStep := 3200;
		END_IF

		IF TON_RobotActionTimeOut.Q THEN
			uiResumeStep := 3100;
			strStatus := 'FB_ShippingPlateScan Step 3100: Robot put to SameSizeCV timeout';
			Status := strStatus;
			_UniqueErrorCode := 'E_PUT_TIMEOUT';
			_Abort := TRUE;
		END_IF
		IF Robot._DI1.Error THEN
			uiResumeStep := 3100;
			strStatus := CONCAT('FB_ShippingPlateScan Step 3100: Robot error ', Robot.ErrMsg);
			Status := strStatus;
			_UniqueErrorCode := 'E_ROBOT_ERROR';
			_Abort := TRUE;
		END_IF

	3200:	// Reset TO AbsMove → 等 Robot.Done 降
		Robot.M_ResetRobotAbsMove(TRUE, FALSE);
		TON_CheckRobotDoneTimeOut.IN := TRUE;
		IF NOT Robot._DI1.Done THEN
			TON_CheckRobotDoneTimeOut.IN := FALSE;
			uiExecutingStep := 3300;
		END_IF
		IF TON_CheckRobotDoneTimeOut.Q THEN
			uiResumeStep := 3200;
			strStatus := 'FB_ShippingPlateScan Step 3200: Wait Robot done (after put) timeout';
			Status := strStatus;
			_UniqueErrorCode := 'E_ROBOT_DONE_TIMEOUT';
			_Error := TRUE;
		END_IF

	3300:	// TO 後置:確保 backward 持續請求 (推走剛放的盒子,arbiter 驅動)
		IF __ISVALIDREF(SameSizeCVRequest) THEN
			SameSizeCVRequest.bScan_NeedBackward := TRUE;
		END_IF
		uiExecutingStep := 3400;

	3400:	// 等馬達 backward 起步 → 進 FeedBack (軌道不停,持續推到 STATE_DONE 才停)
		TON_MechTimeOut.IN := TRUE;
		IF __ISVALIDREF(Motor) AND Motor.List.TransmitSameSideCV.InBackWard THEN
			TON_MechTimeOut.IN := FALSE;
			uiExecutingStep := 4000;
		END_IF
		IF TON_MechTimeOut.Q THEN
			uiResumeStep := 3400;
			strStatus := 'FB_ShippingPlateScan Step 3400: SameSizeCV backward timeout';
			Status := strStatus;
			_UniqueErrorCode := 'E_CV_BACKWARD_TIMEOUT';
			_Abort := TRUE;
		END_IF

	// ===========================================================
	// 沒盒 path:跳過取盒/放盒/軌道,直接 reset robot 進收尾
	// ===========================================================
	5000:	// Reset robot 命令 → 等 Done 降 (沒盒專用)
		Robot.M_ResetRobotAbsMove(TRUE, FALSE);
		TON_CheckRobotDoneTimeOut.IN := TRUE;
		IF NOT Robot._DI1.Done THEN
			TON_CheckRobotDoneTimeOut.IN := FALSE;
			uiExecutingStep := 4000;
		END_IF
		IF TON_CheckRobotDoneTimeOut.Q THEN
			uiResumeStep := 5000;
			strStatus := 'FB_ShippingPlateScan Step 5000: Wait Robot done (no box) timeout';
			Status := strStatus;
			_UniqueErrorCode := 'E_ROBOT_DONE_TIMEOUT';
			_Error := TRUE;
		END_IF

	// ===========================================================
	// 收尾:做完才給 FeedBack → 等 ReadComplete → 清 FeedBack
	// ===========================================================
	4000:	// 整個動作完成 → FeedBack:=TRUE 通知上位讀 PlateHasBox
		FeedBack := TRUE;
		IF ReadComplete THEN
			FeedBack := FALSE;
			uiExecutingStep := 90000;
		END_IF

	90000:
		Status    := 'FB_ShippingPlateScan: Process completed';
		_Executed := TRUE;
END_CASE

// 狀態機切換
IF NOT Execute THEN
	eState := STATE_RESETTING;
ELSIF _Error THEN
	eState := STATE_ERROR;
ELSIF _Abort THEN
	eState := STATE_ABORTING;
ELSIF _Executed THEN
	eState := STATE_DONE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_HELD" Id="{a7db8e9a-b23f-4c4a-9e7b-a8c9d6e7f1c2}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_HELD
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Busy   := FALSE;
Paused := TRUE;

CASE uiHeldStep OF
	0:
		uiHeldStep := 9999;
	9999:
		_HeldCompleted := TRUE;
END_CASE

IF _HeldCompleted AND NOT Pause THEN
	eState := STATE_UnHold;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_HOLDING" Id="{b8ec9fab-c34a-4d5b-9f8c-b9d1e7f8a2d3}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_HOLDING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE uiHoldingStep OF
	0:
		TON_RobotActionTimeOut.IN    := FALSE;
		TON_CheckRobotDoneTimeOut.IN := FALSE;
		TON_ScanTimeOut.IN           := FALSE;
		uiHoldingStep := 9999;
	9999:
		_HoldingCompleted := TRUE;
END_CASE

IF _HoldingCompleted THEN
	eState := STATE_Held;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_RESETTING" Id="{c9fda1bc-d45b-4e6c-8a9d-ca2e8f9b3e4a}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_RESETTING
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE uiResettingStep OF
	0:
		TON_RobotActionTimeOut.IN    := FALSE;
		TON_CheckRobotDoneTimeOut.IN := FALSE;
		TON_ScanTimeOut.IN           := FALSE;
		TON_MechTimeOut.IN           := FALSE;
		tonBoxArriveDelay.IN         := FALSE;
		// 撤銷軌道請求 (arbiter 看到沒人 request 會自動停)
		IF __ISVALIDREF(SameSizeCVRequest) THEN
			SameSizeCVRequest.bScan_NeedBackward := FALSE;
		END_IF
		_bAbsMoveStarted := FALSE;
		PlateHasBox := FALSE;
		FeedBack    := FALSE;
		uiResettingStep := 100;

	100:
		Robot.M_ResetAllCommand();
		IF Robot.M_CheckResetAllCommand() THEN
			uiResettingStep := 9999;
		END_IF

	9999:
		_ResetCompleted := TRUE;
END_CASE

IF _ResetCompleted THEN
	eState := STATE_DORMANT;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_STATE_UNHOLD" Id="{da1eb2cd-e56c-4f7d-9b1a-db3f9a1c4f5b}" FolderPath="STATE\">
      <Declaration><![CDATA[METHOD M_STATE_UNHOLD
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE uiUnholdStep OF
	0:
		uiUnholdStep := 9999;
	9999:
		_UnholdCompleted := TRUE;
END_CASE

IF _UnholdCompleted THEN
	Paused := FALSE;
	eState := STATE_EXECUTING;
END_IF
]]></ST>
      </Implementation>
    </Method>
