      <LineId Id="3" Count="26" />
    </LineIds>
    <LineIds Name="FB_ShippingRobotTransfer.M_CheckMechanism">
      <LineId Id="18" Count="11" />
      <LineId Id="8" Count="0" />
    </LineIds>
    <LineIds Name="FB_ShippingRobotTransfer.M_CheckTransferCommand">
      <LineId Id="92" Count="65" />
      <LineId Id="82" Count="0" />
      <LineId Id="70" Count="0" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="FB_ShippingRobotTransfer.M_SensorUpdate">
      <LineId Id="1" Count="0" />
      <LineId Id="4" Count="6" />
